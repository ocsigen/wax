; Toy "calc" grammar exercising the whole stele pipeline end to end — the
; template an adopter copies. A miniature of src/lib-wasm/dune.menhir:
; menhir --list-errors and --cmly feed the stele generator, whose .messages
; output menhir --compile-errors turns into a Parser_messages module compiled
; alongside the parser. Two promoted goldens pin the result: calc.expected (the
; four message shapes — a plain Expecting list, a delimiter hint, an
; "Assuming … complete" hedge, and a hand override) and calc.stats.expected (the
; quality ratchet). Accept changes with `dune promote`.

(library
 (name calc)
 (modules parser parser_messages)
 (libraries menhirLib))

(menhir
 (modules parser))

; 1. The representative error sentences (one per error state).

(rule
 (with-stdout-to
  calc.auto.messages
  (run menhir %{dep:parser.mly} --list-errors)))

; 2. The exact grammar (productions, nullability, token aliases) for the
;    generator. --no-code-generation keeps --cmly from running the code back-end.

(rule
 (target calc.cmly)
 (deps parser.mly)
 (action
  (run menhir %{dep:parser.mly} --cmly --no-code-generation --base calc)))

; 3. The generated messages, comments stripped and sorted by sentence — the
;    stable golden projection.

(rule
 (with-stdout-to
  calc.actual
  (run
   stele
   generate
   --no-comments
   --cmly
   %{dep:calc.cmly}
   --config
   %{dep:calc.config}
   --overrides
   %{dep:calc.overrides}
   %{dep:calc.auto.messages})))

(rule
 (alias runtest)
 (action
  (diff calc.expected calc.actual)))

; The quality summary (fallback/hint counts and self-lints), pinned so a
; regression fails the build — the ratchet the README describes.

(rule
 (with-stdout-to
  calc.stats
  (run
   stele
   stats
   --cmly
   %{dep:calc.cmly}
   --config
   %{dep:calc.config}
   --overrides
   %{dep:calc.overrides}
   %{dep:calc.auto.messages})))

(rule
 (alias runtest)
 (action
  (diff calc.stats.expected calc.stats)))

; The names review: every rendered symbol with its provenance
; (alias / [names] / [class] / auto-derived / quoted-fallback) and per-position
; usage, then any [names] entries that fired in neither position. Here `stmts`
; is [names]-rendered only as an Assuming subject (0 expecting, 1 assuming) —
; the positional subtlety the mode exists to surface — and nothing is unused.

(rule
 (with-stdout-to
  calc.names
  (run
   stele
   names
   --cmly
   %{dep:calc.cmly}
   --config
   %{dep:calc.config}
   --overrides
   %{dep:calc.overrides}
   %{dep:calc.auto.messages})))

(rule
 (alias runtest)
 (action
  (diff calc.names.expected calc.names)))

; The config rot guard: a stale [class]/[names]/[opener-nets] entry must fail
; the build. calc-rot.config names a token the grammar lacks; the generator
; prints a clean one-line "stele: ... names no symbol of this grammar" error and
; exits 1 (not an uncaught-exception backtrace); its stderr is pinned so the
; guard can never silently stop firing.

(rule
 (with-stderr-to
  calc-rot.actual
  (with-accepted-exit-codes
   1
   (run
    stele
    stats
    --cmly
    %{dep:calc.cmly}
    --config
    %{dep:calc-rot.config}
    %{dep:calc.auto.messages}))))

(rule
 (alias runtest)
 (action
  (diff calc-rot.expected calc-rot.actual)))

; 4. The full messages (with comments) fed to menhir --compile-errors, producing
;    the Parser_messages module compiled into the library above — proof the
;    generated file is well-formed and links against the parser.

(rule
 (with-stdout-to
  calc.messages
  (run
   stele
   generate
   --cmly
   %{dep:calc.cmly}
   --config
   %{dep:calc.config}
   --overrides
   %{dep:calc.overrides}
   %{dep:calc.auto.messages})))

(rule
 (with-stdout-to
  parser_messages.ml
  (run menhir %{dep:parser.mly} --compile-errors %{dep:calc.messages})))

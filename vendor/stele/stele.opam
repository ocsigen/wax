# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
version: "0.1.1~dev"
synopsis: "User-friendly syntax-error messages for any Menhir grammar"
description:
  "A build-time generator that turns a Menhir grammar's --list-errors output and its .cmly into readable syntax-error messages, with a golden/census/stats workflow, a soundness oracle, and a hand-override escape hatch; plus a small runtime helper (stele.runtime) that resolves the delimiter markers the generated messages carry. Configured per grammar by a text sidecar, so the tool itself is grammar-agnostic."
maintainer: ["Jérôme Vouillon"]
authors: ["Jérôme Vouillon"]
license: "Apache-2.0"
homepage: "https://github.com/ocsigen/wax"
doc: "https://ocsigen.org/wax/"
bug-reports: "https://github.com/ocsigen/wax/issues"
depends: [
  "dune" {>= "3.20"}
  "ocaml" {>= "4.14"}
  "menhir" {build & >= "20220210"}
  "menhirSdk" {>= "20220210"}
  "menhirLib" {>= "20220210"}
  "cmdliner" {>= "2.0.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/ocsigen/wax.git"
x-maintenance-intent: ["(latest)"]

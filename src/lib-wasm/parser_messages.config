# stele generator configuration (wat grammar).
#
# This file carries the grammar-specific tables the generator used to hard-code:
# curated readable names, token classes, and the missed-hint lint's opener-name
# nets. See stele/README.md for the format. Each entry must name a symbol the
# wat grammar actually has: a stale entry fails the build (the config rot guard).
# The wax (lib-wax) copy is its own pruned file, not a shared table.

# Readable names for symbols whose auto-derived rendering would be internal
# jargon or grammatically wrong. NAME = readable phrase. A plural phrase carries
# no leading article, so the "Assuming that the X is/are complete" template picks
# the right verb.
[names]
# Value-carrying tokens: the quoted-lowercase fallback would render the *token
# name* ('int', 'float', 'id') as if it were literal syntax, but the user types
# a numeric/string literal or a $-prefixed identifier. INT and FLOAT currently
# reach no error state (NAT covers the integer positions), so they show as
# unused in `stele names`/`stele stats`; they are kept anyway so a future state
# that surfaces them reads well instead of showing the misleading 'int'/'float'.
INT = an integer
FLOAT = a float
STRING = a string
EOF = end of file
ID = an identifier ('$...')
u8 = an 8-bit unsigned integer
u32 = a 32-bit unsigned integer
u64 = a 64-bit unsigned integer
i8 = an 8-bit signed integer
i16 = a 16-bit signed integer
i32 = a 32-bit signed integer
i64 = a 64-bit signed integer
f32 = a 32-bit float
f64 = a 64-bit float
# (LPAREN_IMPORT intentionally has no [names] entry: it is a terminal aliased
# '(import', so the alias always wins in the Expecting position and it can never
# be an Assuming subject — a name here would fire in neither position. The
# earlier `an inline import` entry was verified dead and removed, step 12.)
NAT = an integer
MEM_OFFSET = a memory offset
MEM_ALIGN = a memory alignment
# Nonterminals whose auto-derived form is jargon ("a blockinstr") or wrong
# ("a mem limits", where the plurality heuristic misfires).
blockinstr = a block
# (on_clauses needs no [names] entry in the wat grammar: it is list-shaped, so
# the 3b chase renders '(on' in the Expecting position, and it is folded before
# it can be an Assuming subject. The earlier `an on-clause list` entry was
# verified dead and removed, step 12. The wax grammar's on_clauses is not
# list-shaped, so its copy keeps the entry.)
pagesize_clause = a page-size clause
result_pat = a result pattern
float_or_nan = a float or NaN
# Head noun is "list", not the plural tail: keep the article so "… is complete"
# agrees.
list_of_indices = a list of indices
# List *elements* the singularization chase lands on, whose auto-derived name is
# an abbreviation.
local_decl = a local declaration
param_group = a parameter group

# Token classes collapsed to one readable label before the <=5 cap would go here
# ([class LABEL], one member terminal per line). The wat grammar has no infix
# operator or comparison tokens, so it declares none.

# Extra name-pattern nets for the missed-hint lint, keyed by opener character.
# A token whose alias begins with the opener character is already recognized;
# these catch openers by name pattern. OPENER_CHAR KIND ARG, KIND in
# prefix|suffix|exact. All redundant with the current aliases (kept for parity
# with the pre-config behaviour and as a template for grammars without aliased
# openers).
[opener-nets]
( prefix LPAREN
( suffix _ANNOT

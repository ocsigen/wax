# stele generator configuration.
#
# This file carries the grammar-specific tables the generator used to hard-code:
# curated readable names, token classes, and the missed-hint lint's opener-name
# nets. See stele/README.md for the format. The wat (lib-wasm) and wax
# (lib-wax) copies are kept identical: an entry for a symbol a grammar does not
# have simply never fires, so one shared table is a no-op on either side.

# Readable names for symbols whose auto-derived rendering would be internal
# jargon or grammatically wrong. NAME = readable phrase. A plural phrase carries
# no leading article, so the "Assuming that the X is/are complete" template picks
# the right verb.
[names]
IDENT = an identifier
INT = an integer
FLOAT = a float
STRING = a string
CHAR = a character
EOF = end of file
u8 = an 8-bit unsigned integer
u32 = a 32-bit unsigned integer
u64 = a 64-bit unsigned integer
i8 = an 8-bit signed integer
i16 = a 16-bit signed integer
i32 = a 32-bit signed integer
i64 = a 64-bit signed integer
f32 = a 32-bit float
f64 = a 64-bit float
LPAREN_IMPORT = an inline import
NAT = an integer
MEM_OFFSET = a memory offset
MEM_ALIGN = a memory alignment
# Nonterminals whose auto-derived form is jargon ("a blockinstr") or wrong
# ("a mem limits", where the plurality heuristic misfires).
blockinstr = a block
braced_block = a block
import_kind_decl = an import declaration
on_clauses = an on-clause list
mem_limits = memory limits
mem_pagesize = a page-size clause
pagesize_clause = a page-size clause
condition_relop = a comparison operator
branch_expr = a branch expression
legacy_catch = a catch clause
legacy_catch_all = a catch-all clause
result_pat = a result pattern
float_or_nan = a float or NaN
# Head noun is "list", not the plural tail: keep the article so "… is complete"
# agrees.
list_of_indices = a list of indices
# List *elements* the singularization chase lands on, whose auto-derived name is
# an abbreviation.
local_decl = a local declaration
param_group = a parameter group
block_param_type = a parameter type

# Token classes collapsed to one readable label before the <=5 cap, so a state
# whose FOLLOW is "a closer or any operator" reads "…, or an operator." instead
# of overflowing. One member terminal per line. The wat grammar has none of
# these tokens, so its classes never fire.
[class an operator]
PLUS
MINUS
STAR
SLASH
SLASHS
SLASHU
PERCENTS
PERCENTU
AMPERSAND
PIPE
CARET
SHL
SHRS
SHRU
PLUSEQUAL
MINUSEQUAL
STAREQUAL
SLASHEQUAL
SLASHSEQUAL
SLASHUEQUAL
PERCENTSEQUAL
PERCENTUEQUAL
AMPERSANDEQUAL
PIPEEQUAL
CARETEQUAL
SHLEQUAL
SHRSEQUAL
SHRUEQUAL

[class a comparison operator]
EQUALEQUAL
BANGEQUAL
LT
LTS
LTU
LE
LES
LEU
GT
GTS
GTU
GE
GES
GEU

# Extra name-pattern nets for the missed-hint lint, keyed by opener character.
# A token whose alias begins with the opener character is already recognized;
# these catch openers by name pattern. OPENER_CHAR KIND ARG, KIND in
# prefix|suffix|exact. All redundant with the current aliases (kept for parity
# with the pre-config behaviour and as a template for grammars without aliased
# openers).
[opener-nets]
( prefix LPAREN
( suffix _ANNOT
{ exact LBRACE
[ exact LBRACKET

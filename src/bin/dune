(executable
 (name main)
 (modes exe wasm)
 (public_name wax)
 (package wax)
 (modules main mcp reference_data)
 (libraries wax_wasm wax_lang wax_conversion wax_lsp cmdliner unix yojson))

; Embed the generated language reference (docs/llms.txt) as an OCaml string, so
; `wax mcp`'s wax_reference tool can serve it with no runtime file dependency.
; Depends on docs/llms.txt (itself generated from the mdbook by docs/gen_llms),
; so editing a doc page and rebuilding re-embeds it. The quoted-string
; delimiter is chosen not to occur in the docs.

(rule
 (target reference_data.ml)
 (deps ../../docs/llms.txt)
 (action
  (with-stdout-to
   reference_data.ml
   (progn
    (echo "let content = {wax_llms_reference|")
    (cat ../../docs/llms.txt)
    (echo "|wax_llms_reference}")))))

; Install shell completions and manpages for the wax tool (cmdliner 2.x).
; `cmdliner install tool-support` runs the built binary to extract them into a
; PREFIX; we install that PREFIX's share/ subtree — bash/zsh/PowerShell
; completion definitions and man pages — under the opam share root. The generic
; per-shell completion scripts are shipped by the cmdliner package itself, not
; here; see docs/src/cli.md for how users enable completion in their shell.
;
; Skipped on native Windows: dune fails to install the directory target there
; ("<...>/cmdliner-support/share: Permission denied"), which broke the whole
; package build on the Windows CI. Both the rule and the install are gated so
; the extraction never runs on Windows either. (js_of_ocaml hit the same class
; of dune directory-target install trouble and disabled its equivalent stanza
; outright; a single-package repo like ours only needs the Windows exclusion.)

(rule
 (target
  (dir cmdliner-support))
 (enabled_if
  (<> %{os_type} Win32))
 (deps main.exe)
 (action
  (ignore-stdout
   (run cmdliner install tool-support ./main.exe:wax cmdliner-support))))

(install
 (package wax)
 (enabled_if
  (<> %{os_type} Win32))
 (section share_root)
 (dirs
  (cmdliner-support/share as .)))

; Private developer/test executables, not installed (no public names):
; run_wasm_testsuite drives the spec suite (see test/dune); fuzz_mutate is the
; AST mutator behind fuzz/mutate-wax.sh and fuzz_gen the AST generator behind
; fuzz/type-fuzz.sh.

(executables
 (names run_wasm_testsuite fuzz_mutate fuzz_gen fuzz_recover)
 (modules run_wasm_testsuite fuzz_mutate fuzz_gen fuzz_recover)
 (libraries wax_wasm wax_lang wax_conversion menhirLib re unix cmdliner))

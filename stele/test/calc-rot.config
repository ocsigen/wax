# A deliberately stale config for the rot-guard test: [class an operator] lists
# NOSUCHTOKEN, which the calc grammar does not have. Loading it must fail with a
# hard error naming the file, section, and entry (see calc-rot.expected). This
# is the config counterpart of the override rot guard.
[names]
stmts = statements

[class an operator]
PLUS
STAR
NOSUCHTOKEN

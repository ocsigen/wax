{
  "Module": {
    "prefix": "module",
    "body": ["(module", "\t$0", ")"],
    "description": "Module"
  },
  "Function": {
    "prefix": "func",
    "body": [
      "(func \\$${1:name} (param ${2:i32}) (result ${3:i32})",
      "\t$0",
      ")"
    ],
    "description": "Function definition"
  },
  "Exported function": {
    "prefix": "export",
    "body": [
      "(func \\$${1:name} (export \"${1:name}\") (param ${2:i32}) (result ${3:i32})",
      "\t$0",
      ")"
    ],
    "description": "Exported function"
  },
  "Imported function": {
    "prefix": "import",
    "body": [
      "(import \"${1:module}\" \"${2:name}\" (func \\$${3:id} (param ${4:i32}) (result ${5:i32})))$0"
    ],
    "description": "Imported function"
  },
  "Global": {
    "prefix": "global",
    "body": ["(global \\$${1:name} ${2:i32} (${2:i32}.const ${3:0}))$0"],
    "description": "Global definition"
  },
  "Memory": {
    "prefix": "memory",
    "body": ["(memory \\$${1:mem} ${2:1})$0"],
    "description": "Memory declaration"
  },
  "Struct type": {
    "prefix": "type-struct",
    "body": ["(type \\$${1:name} (struct (field ${2:i32})))$0"],
    "description": "Struct type definition"
  },
  "Array type": {
    "prefix": "type-array",
    "body": ["(type \\$${1:name} (array ${2:i32}))$0"],
    "description": "Array type definition"
  },
  "Local": {
    "prefix": "local",
    "body": ["(local \\$${1:name} ${2:i32})$0"],
    "description": "Local variable"
  },
  "If": {
    "prefix": "if",
    "body": [
      "(if (result ${1:i32})",
      "\t(then",
      "\t\t$2",
      "\t)",
      "\t(else",
      "\t\t$0",
      "\t)",
      ")"
    ],
    "description": "If / else"
  },
  "Loop": {
    "prefix": "loop",
    "body": ["(loop \\$${1:label}", "\t$0", ")"],
    "description": "Loop"
  },
  "Block": {
    "prefix": "block",
    "body": ["(block \\$${1:label}", "\t$0", ")"],
    "description": "Block"
  }
}

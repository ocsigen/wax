{
  "name": "wax",
  "displayName": "Wax",
  "description": "Syntax highlighting and formatting for Wax, a Rust-like syntax for WebAssembly.",
  "icon": "images/wax.png",
  "galleryBanner": {
    "color": "#140D26",
    "theme": "dark"
  },
  "version": "0.3.0",
  "publisher": "wax-wasm",
  "license": "Apache-2.0",
  "author": "Jérôme Vouillon",
  "bugs": {
    "url": "https://github.com/ocsigen/wax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ocsigen/wax.git",
    "directory": "editors/vscode"
  },
  "homepage": "https://ocsigen.org/wax/",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "wax",
    "webassembly",
    "wasm",
    "wat"
  ],
  "main": "./dist/extension.node.js",
  "browser": "./dist/extension.web.js",
  "activationEvents": [
    "onLanguage:wax",
    "onLanguage:wat",
    "onCommand:wax.showWat",
    "onCommand:wax.showWax"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "scripts": {
    "build": "bash ./build.sh",
    "typecheck": "tsc --noEmit",
    "test:web": "npm run build && esbuild src/test/web/index.ts --bundle --outfile=dist/test/web/index.js --format=cjs --platform=browser --external:vscode --target=es2022 && vscode-test-web --headless --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=./dist/test/web/index.js",
    "vscode:prepublish": "bash ./build.sh --minify",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.60.0",
    "@vscode/test-web": "^0.0.81",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^7.0.2"
  },
  "contributes": {
    "configurationDefaults": {
      "[wax]": {
        "editor.defaultFormatter": "wax-wasm.wax"
      },
      "[wat]": {
        "editor.defaultFormatter": "wax-wasm.wax"
      }
    },
    "languages": [
      {
        "id": "wax",
        "aliases": [
          "Wax",
          "wax"
        ],
        "extensions": [
          ".wax"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "wat",
        "aliases": [
          "WebAssembly Text",
          "wat"
        ],
        "extensions": [
          ".wat"
        ],
        "configuration": "./wat-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "wax",
        "scopeName": "source.wax",
        "path": "./syntaxes/wax.tmLanguage.json"
      },
      {
        "language": "wat",
        "scopeName": "source.wat",
        "path": "./syntaxes/wat.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "wax",
        "path": "./snippets/wax.json"
      },
      {
        "language": "wat",
        "path": "./snippets/wat.json"
      }
    ],
    "commands": [
      {
        "command": "wax.showWat",
        "title": "Show compiled WAT",
        "category": "Wax"
      },
      {
        "command": "wax.showWax",
        "title": "Show as Wax",
        "category": "Wax"
      },
      {
        "command": "wax.configureDefines",
        "title": "Configure conditional-compilation defines",
        "category": "Wax"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "wax.showWat",
          "when": "resourceLangId == wax"
        },
        {
          "command": "wax.showWax",
          "when": "resourceLangId == wat"
        },
        {
          "command": "wax.configureDefines",
          "when": "resourceLangId == wax"
        }
      ],
      "editor/title": [
        {
          "command": "wax.showWat",
          "when": "resourceLangId == wax",
          "group": "navigation"
        },
        {
          "command": "wax.showWax",
          "when": "resourceLangId == wat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Wax",
      "properties": {
        "wax.define": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Conditional-compilation defines, as passed to `-D`/`--define` (e.g. `debug=true`, `arch=wasm64`, `version=2.1.0`). Branches of `#[if]`/`#[else]` that these bindings make unreachable are dimmed as dead code in `.wax` files."
        }
      }
    }
  },
  "dependencies": {
    "vsce": "^2.15.0"
  }
}

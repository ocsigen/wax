{
  "comments": {
    "lineComment": ";;",
    "blockComment": ["(;", ";)"]
  },
  "brackets": [["(", ")"]],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "(;", "close": ";)", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["\"", "\""]
  ],
  "colorizedBracketPairs": [["(", ")"]],
  "wordPattern": "[$]?[0-9A-Za-z!#%&'*+\\-./:<=>?@\\^_`|~]+",
  "indentationRules": {
    "increaseIndentPattern": "\\([^)\"';]*$",
    "decreaseIndentPattern": "^\\s*\\)"
  }
}

#[import = ("fail", "caml_raise_constant")]
fn caml_raise_constant(&eq);
#[import = ("fail", "caml_raise_with_arg")]
fn caml_raise_with_arg(tg: &eq, arg: &eq);
#[import = ("fail", "caml_failwith")]
fn caml_failwith(&eq);
#[import = ("obj", "caml_fresh_oo_id")]
fn caml_fresh_oo_id(&eq) -> &eq;
#[import = ("obj", "cont_tag")]
const cont_tag: i32;
#[import = ("obj", "object_tag")]
const object_tag: i32;
#[import = ("obj", "caml_callback_1")]
fn caml_callback_1(&eq, &eq) -> &eq;
#[import = ("stdlib", "caml_named_value")]
fn caml_named_value(&eq) -> &?eq;
#[import = ("fail", "ocaml_exception")]
tag ocaml_exception(&eq);
#[import = ("fail", "javascript_exception")]
tag javascript_exception(&?extern);
#[if(wasi)]
fn caml_wrap_exception(&?extern) -> &eq {
    unreachable;
}
#[else]
{
    #[import = ("jslib", "caml_wrap_exception")]
    fn caml_wrap_exception(&?extern) -> &eq;
    #[import = ("bindings", "start_fiber")]
    fn start_fiber(&eq);
    #[import = ("bindings", "suspend_fiber")]
    fn suspend_fiber(f: &?func, env: &?eq) -> &?any;
    #[import = ("bindings", "resume_fiber")]
    fn resume_fiber(&?extern, &eq);
}

type block = [mut &eq];
type bytes = [mut i8];
type function_1 = fn(&eq, &eq) -> &eq;
type closure = open { func: &function_1 };
type function_3 = fn(&eq, &eq, &eq, &eq) -> &eq;
type closure_3: closure = open { .., direct: &function_3 };

// Generic fibers

type generic_fiber = open { value: mut &eq, exn: mut &eq, effect: mut &eq };

const already_resumed = "Effect.Continuation_already_resumed";

const effect_unhandled = "Effect.Unhandled";

fn raise_unhandled(eff: &eq, &eq) -> &eq {
    'null: do {
        caml_raise_with_arg(br_on_null 'null caml_named_value(effect_unhandled), eff);
    }
    caml_raise_constant([block|object_tag as &i31, effect_unhandled, caml_fresh_oo_id(0 as &i31)]);
    0 as &i31;
}

const raise_unhandled_closure: &closure = { func: raise_unhandled };

#[export]
let effect_allowed = 1;

#[export]
fn caml_continuation_use_noexc(vcont: &eq) -> &eq {
    _ =
        'used: do {
            let continuation = vcont as &block;
            let stack = br_on_cast_fail 'used &generic_fiber continuation[1];
            continuation[1] = 0 as &i31;
            return stack;
        };
    0 as &i31;
}

#[export]
fn caml_continuation_use_and_update_handler_noexc(
    continuation: &eq,
    hval: &eq,
    hexn: &eq,
    heff: &eq,
) -> &eq {
    let stack = caml_continuation_use_noexc(continuation);
    if stack is &generic_fiber {
        let tail = (continuation as &block)[2] as &generic_fiber;
        tail.value = hval;
        tail.exn = hexn;
        tail.effect = heff;
    }
    stack;
}

#[export]
fn caml_continuation_update_handler_noexc(
    continuation: &eq,
    hval: &eq,
    hexn: &eq,
    heff: &eq,
) -> &eq {
    // Peek at the stack without consuming the continuation. If it is null
    // the continuation has already been taken, so we leave it untouched.
    if (continuation as &block)[1] is &generic_fiber {
        let tail = (continuation as &block)[2] as &generic_fiber;
        tail.value = hval;
        tail.exn = hexn;
        tail.effect = heff;
    }
    continuation;
}

#[export]
fn caml_get_continuation_callstack(&eq, &eq) -> &eq {
    [block|0 as &i31];
}

#[export]
fn caml_is_continuation(v: &eq) -> i32 {
    match v {
        blk: &block => {
            return blk[0] == cont_tag as &i31;
        }
        _ => {
            0;
        }
    }
}

#[if(all(effects = "jspi", not(wasi)))]
{
    // Apply a function f to a value v, both contained in a pair (f, v)

    type pair = { f: &eq, v: &eq };

    fn apply_pair(p: &pair) -> &eq {
        let f: &eq;
        become (f as &closure).func(p.v, f := p.f);
    }

    // Low-level primitives

    // Capturing the current continuation

    type cont_func = fn(&pair, &eq);
    type continuation = open { cont_func: &cont_func };

    type called_with_continuation = fn(&continuation, &eq);

    type thunk = { func: &called_with_continuation, v: &eq };

    type cont_resume: continuation = { .., cont_resolver: &?extern };

    fn invoke_promise_resolver(p: &pair, k: &eq) {
        become resume_fiber((k as &cont_resume).cont_resolver, p);
    }

    fn apply_continuation(resolver: &extern, v: &eq) {
        let t = v as &thunk;
        become t.func({ cont_func: invoke_promise_resolver, cont_resolver: resolver }, t.v);
    }

    const unsupported =
        "Effect handlers are not supported: the JavaScript Promise Integration API is not enabled";

    fn capture_continuation(f: &called_with_continuation, v: &eq) -> &eq {
        _ =
            'unsupported: do {
                become apply_pair(
                    br_on_cast_fail 'unsupported &pair
                        suspend_fiber(apply_continuation, { func: f, v }),
                );
            };
        caml_failwith(unsupported);
        0 as &i31;
    }

    // Stack of fibers

    type fiber: generic_fiber = { .., continuation: mut &continuation, next: mut &?fiber };

    fn initial_cont(p: &pair, &eq) {
        become start_fiber(p);
    }

    const initial_cont_closure = { cont_func: initial_cont };

    let stack =
        {
            value: 0 as &i31,
            exn: 0 as &i31,
            effect: 0 as &i31,
            continuation: initial_cont_closure,
            next: null,
        };

    // Utility functions moving fibers between a continuation and the
    // current stack of fibers

    fn pop_fiber() -> &continuation {
        let f = stack.next!;
        stack.next = null;
        stack = f;
        f.continuation;
    }

    fn push_stack(head: &fiber, tail: &fiber, k: &continuation) -> &continuation {
        stack.continuation = k;
        tail.next = stack;
        stack = head;
        head.continuation;
    }

    // Resume

    type resume_state = { head: &eq, tail: &eq, dat: &pair };

    fn do_resume(k: &continuation, vp: &eq) {
        let p = vp as &resume_state;
        let head = p.head as &fiber;
        let tail: &fiber;
        tail =
            'available: do {
                _ = br_on_cast 'available &fiber p.tail;
                tail = head;
                // Pre OCaml 5.2, last was not populated.
                'done: do {
                    'loop: loop {
                        tail = br_on_null 'done tail.next;
                        br 'loop;
                    }
                }
                tail;
            };
        k = push_stack(head, tail, k);
        become k.cont_func(p.dat, k);
    }

    #[export = "%resume"]
    fn resume_prim(stack_head: &eq, f: &eq, v: &eq, stack_tail: &eq) -> &eq {
        let k: &continuation;
        let pair: &pair;
        if stack_head == 0 as &i31 {
            caml_raise_constant(caml_named_value(already_resumed)!);
        }
        become capture_continuation(
            do_resume,
            { head: stack_head, tail: stack_tail, dat: { f, v } },
        );
    }

    // Perform

    type call_handler_env: closure = { .., handler: &eq, eff: &eq, continuation: &eq };

    fn call_effect_handler(tail: &eq, venv: &eq) -> &eq {
        let env = venv as &call_handler_env;
        let handler: &closure_3;
        become handler.direct(
            env.eff,
            env.continuation,
            tail,
            handler := env.handler as &closure_3,
        );
    }

    fn do_perform(k0: &continuation, eff: &eq) {
        let handler = stack.effect;
        let last_fiber = stack;
        last_fiber.continuation = k0;
        let continuation: &block = [cont_tag as &i31, last_fiber, last_fiber];
        let k1 = pop_fiber();
        become k1.cont_func(
            { f: { func: call_effect_handler, handler, eff, continuation }, v: last_fiber },
            k1,
        );
    }

    #[export = "%perform"]
    fn f(eff: &eq) -> &eq {
        if !effect_allowed | !stack.next {
            become raise_unhandled(eff, 0 as &i31);
        }
        become capture_continuation(do_perform, eff);
    }

    type reperform = { eff: &eq, continuation: &eq, tail: &eq };

    fn do_reperform(k0: &continuation, vp: &eq) {
        let eff: &eq;
        let p = vp as &reperform;
        let continuation = p.continuation as &block;
        let tail = p.tail as &fiber;
        let handler = stack.effect;
        let last_fiber = stack;
        last_fiber.continuation = k0;
        tail.next = last_fiber;
        continuation[2] = last_fiber;
        let k1 = pop_fiber();
        become k1.cont_func(
            { f: { func: call_effect_handler, handler, eff: p.eff, continuation }, v: last_fiber },
            k1,
        );
    }

    #[export = "%reperform"]
    fn reperform(eff: &eq, continuation: &eq, tail: &eq) -> &eq {
        if !stack.next {
            become resume_prim(
                caml_continuation_use_noexc(continuation),
                raise_unhandled_closure,
                eff,
                tail,
            );
        }
        become capture_continuation(do_reperform, { eff, continuation, tail });
    }

    // Allocate a stack

    fn call_handler(f: &eq, x: &eq) {
        let continuation: &continuation;
        // Propagate a value or an exception to the parent fiber
        become continuation.cont_func({ f, v: x }, continuation := pop_fiber());
    }

    #[export]
    fn caml_start_fiber(p: &?eq) {
        // Start executing some code in a new fiber
        let res =
            try {
                try {
                    apply_pair(p as &pair);
                } catch {
                    javascript_exception => {
                        throw ocaml_exception caml_wrap_exception(_);
                    }
                }
            } catch {
                ocaml_exception => {
                    let exn = _;
                    become call_handler(stack.exn, exn);
                }
            };
        become call_handler(stack.value, res);
    }

    #[export]
    fn caml_alloc_stack(hv: &eq, hx: &eq, hf: &eq) -> &eq {
        { value: hv, exn: hx, effect: hf, continuation: initial_cont_closure, next: null };
    }

    #[export = "%with_stack"]
    fn f_2(hv: &eq, hx: &eq, hf: &eq, f: &eq, v: &eq) -> &eq {
        let stack =
            { value: hv, exn: hx, effect: hf, continuation: initial_cont_closure, next: null };
        become capture_continuation(do_resume, { head: stack, tail: stack, dat: { f, v } });
    }

    #[export = "%with_stack_bind"]
    fn f_3(hv: &eq, hx: &eq, hf: &eq, dyn: &eq, bind: &eq, f: &eq, v: &eq) -> &eq {
        let stack =
            { value: hv, exn: hx, effect: hf, continuation: initial_cont_closure, next: null };
        become capture_continuation(do_resume, { head: stack, tail: stack, dat: { f, v } });
    }
}

#[if(effects = "cps")]
{
    type function_2 = fn(&eq, &eq, &eq) -> &eq;
    type function_4 = fn(&eq, &eq, &eq, &eq, &eq) -> &eq;
    type cps_closure = open { func: &function_2 };
    type cps_closure_0 = open { func: &function_1 };
    type cps_closure_3: cps_closure = open { .., direct: &function_4 };

    type iterator: closure = { .., i: mut i32, args: &block };

    type exn_stack = { h: &eq, next: &?exn_stack };

    type cps_fiber: generic_fiber = {
        ..,
        continuation: mut &eq,
        exn_stack: mut &?exn_stack,
        next: mut &?cps_fiber
    };

    let cps_fiber_stack =
        {
            value: 0 as &i31,
            exn: 0 as &i31,
            effect: 0 as &i31,
            continuation: 0 as &i31,
            exn_stack: null,
            next: null,
        };

    #[export]
    fn caml_push_trap(h: &eq) -> &eq {
        cps_fiber_stack.exn_stack = { h, next: cps_fiber_stack.exn_stack };
        0 as &i31;
    }

    fn raise_exception(exn: &eq, &eq) -> &eq {
        throw ocaml_exception exn;
    }

    const raise_exception_closure: &eq = {closure| func: raise_exception };

    #[export]
    fn caml_pop_trap() -> &eq {
        'empty: do {
            let top = br_on_null 'empty cps_fiber_stack.exn_stack;
            cps_fiber_stack.exn_stack = top.next;
            return top.h;
        }
        raise_exception_closure;
    }

    #[export]
    fn caml_maybe_attach_backtrace(exn: &eq, &eq) -> &eq {
        exn;
    }

    fn identity(v: &eq, &eq) -> &eq {
        v;
    }

    const identity_closure: &closure = { func: identity };

    fn trampoline_iterator(f: &eq, venv: &eq) -> &eq {
        let env = venv as &iterator;
        let i = env.i;
        let args = env.args;
        env.i = i + 1;
        become (f as &cps_closure).func(
            args[i],
            if i + 1 == args.length() {
                identity_closure;
            } else {
                env;
            },
            f,
        );
    }

    fn apply_iterator(f: &eq, venv: &eq) -> &eq {
        let env = venv as &iterator;
        let i = env.i;
        let args = env.args;
        env.i = i + 1;
        become (f as &cps_closure).func(
            args[i],
            if i + 2 == args.length() {
                args[i + 1];
            } else {
                env;
            },
            f,
        );
    }

    #[export]
    fn caml_apply_continuation(args: &eq) -> &eq {
        { func: apply_iterator, i: 1, args: args as &block };
    }

    fn dummy_cps_fun(&eq, &eq, &eq) -> &eq {
        unreachable;
    }

    #[export = "caml_cps_trampoline"]
    fn caml_trampoline(f: &eq, vargs: &eq) -> &eq {
        let i: i32;
        let saved_fiber_stack = cps_fiber_stack;
        cps_fiber_stack =
            {
                value: 0 as &i31,
                exn: 0 as &i31,
                effect: 0 as &i31,
                continuation: 0 as &i31,
                exn_stack: null,
                next: null,
            };
        let args = vargs as &block;
        let res: &eq;
        let exn =
            try {
                res =
                    if args.length() == 1 {
                        (f as &cps_closure_0).func(identity_closure, f);
                    } else {
                        (f as &cps_closure).func(
                            args[1],
                            if 2 == args.length() {
                                identity_closure;
                            } else {
                                { func: trampoline_iterator, i: 2, args };
                            },
                            f,
                        );
                    };
                cps_fiber_stack = saved_fiber_stack;
                return res;
            } catch {
                ocaml_exception => {}
                javascript_exception => {
                    caml_wrap_exception(_);
                }
            };
        'loop: loop {
            'empty: do {
                let top = br_on_null 'empty cps_fiber_stack.exn_stack;
                cps_fiber_stack.exn_stack = top.next;
                f = top.h;
                try {
                    res = (f as &closure).func(exn, f);
                    cps_fiber_stack = saved_fiber_stack;
                    return res;
                } catch {
                    ocaml_exception => {
                        exn = _;
                        br 'loop;
                    }
                    javascript_exception => {
                        exn = caml_wrap_exception(_);
                        br 'loop;
                    }
                }
            }
        }
        cps_fiber_stack = saved_fiber_stack;
        throw ocaml_exception exn;
    }

    fn caml_pop_fiber() -> &eq {
        let f = cps_fiber_stack.next!;
        cps_fiber_stack.next = null;
        cps_fiber_stack = f;
        f.continuation;
    }

    #[export]
    fn caml_resume_stack(vhead: &eq, vtail: &eq, k: &eq) -> &eq {
        match vhead {
            head: &cps_fiber => {
                let tail: &cps_fiber;
                tail =
                    'available: do {
                        _ = br_on_cast 'available &cps_fiber vtail;
                        tail = head;
                        // Pre OCaml 5.2, last was not populated.
                        'done: do {
                            'loop: loop {
                                tail = br_on_null 'done tail.next;
                                br 'loop;
                            }
                        }
                        tail;
                    };
                cps_fiber_stack.continuation = k;
                tail.next = cps_fiber_stack;
                cps_fiber_stack = head;
                return head.continuation;
            }
            _ => {
                caml_raise_constant(caml_named_value(already_resumed)!);
                0 as &i31;
            }
        }
    }

    #[export]
    fn caml_perform_effect(eff: &eq, k0: &eq) -> &eq {
        if !cps_fiber_stack.next {
            become raise_unhandled(eff, 0 as &i31);
        }
        let handler = cps_fiber_stack.effect;
        let last_fiber = cps_fiber_stack;
        last_fiber.continuation = k0;
        let continuation: &block = [cont_tag as &i31, last_fiber, last_fiber];
        let k1 = caml_pop_fiber();
        become (handler as &cps_closure_3).direct(eff, continuation, last_fiber, k1, handler);
    }

    #[export]
    fn caml_reperform_effect(eff: &eq, vcont: &eq, vtail: &eq, k0: &eq) -> &eq {
        if !cps_fiber_stack.next {
            _ = caml_resume_stack(caml_continuation_use_noexc(vcont), vtail, k0);
            become raise_unhandled(eff, 0 as &i31);
        }
        let continuation = vcont as &block;
        let tail = vtail as &cps_fiber;
        let handler = cps_fiber_stack.effect;
        let last_fiber = cps_fiber_stack;
        last_fiber.continuation = k0;
        tail.next = last_fiber;
        continuation[2] = last_fiber;
        let k1 = caml_pop_fiber();
        become (handler as &cps_closure_3).direct(eff, continuation, last_fiber, k1, handler);
    }

    fn cps_call_handler(handler: &eq, x: &eq) -> &eq {
        become (handler as &cps_closure).func(x, caml_pop_fiber(), handler);
    }

    fn value_handler(x: &eq, &eq) -> &eq {
        become cps_call_handler(cps_fiber_stack.value, x);
    }

    const value_handler_closure: &closure = { func: value_handler };

    fn exn_handler(x: &eq, &eq) -> &eq {
        become cps_call_handler(cps_fiber_stack.exn, x);
    }

    const exn_handler_closure: &closure = { func: exn_handler };

    #[export]
    fn caml_alloc_stack(hv: &eq, hx: &eq, hf: &eq) -> &eq {
        {
            value: hv,
            exn: hx,
            effect: hf,
            continuation: value_handler_closure,
            exn_stack: { h: exn_handler_closure, next: null },
            next: null,
        };
    }
}

#[export]
fn caml_assume_no_perform(f: &eq) -> &eq {
    let saved_effect_allowed = effect_allowed;
    effect_allowed = 0;
    let exn: &eq;
    let res =
        try {
            caml_callback_1(f, 0 as &i31);
        } catch {
            ocaml_exception => {
                exn = _;
                effect_allowed = saved_effect_allowed;
                throw ocaml_exception exn;
            }
            javascript_exception => {
                exn = caml_wrap_exception(_);
                effect_allowed = saved_effect_allowed;
                throw ocaml_exception exn;
            }
        };
    effect_allowed = saved_effect_allowed;
    res;
}

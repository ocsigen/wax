#[import = ("fail", "caml_failwith")]
fn caml_failwith(&eq);
#[import = ("marshal", "caml_serialize_int_4")]
fn caml_serialize_int_4(&eq, i32);
#[import = ("marshal", "caml_deserialize_int_4")]
fn caml_deserialize_int_4(&eq) -> i32;
#[import = ("float", "caml_parse_float")]
fn caml_parse_float(&eq, &eq) -> &eq;
#[import = ("float", "caml_format_float")]
fn caml_format_float(&eq, &eq) -> &eq;
#[import = ("float", "caml_fma_float")]
fn caml_fma_float(&eq, &eq, &eq) -> &eq;
#[import = ("float", "caml_erf_float")]
fn caml_erf_float(f64) -> f64;
#[import = ("float", "caml_erfc_float")]
fn caml_erfc_float(f64) -> f64;
#[import = ("float", "caml_frexp_float")]
fn caml_frexp_float(&eq) -> &eq;
#[import = ("float", "caml_ldexp_float")]
fn caml_ldexp_float(f64, i32) -> f64;
#[import = ("bigarray", "caml_ba_uint8_get32")]
fn caml_ba_uint8_get32(&eq, i32) -> i32;
#[import = ("bigarray", "caml_ba_uint8_set32")]
fn caml_ba_uint8_set32(&eq, i32, i32) -> &eq;
#[import = ("string", "caml_string_get32")]
fn caml_string_get32(&eq, i32) -> i32;
#[import = ("string", "caml_bytes_get32")]
fn caml_bytes_get32(&eq, i32) -> i32;
#[import = ("string", "caml_bytes_set32")]
fn caml_bytes_set32(&eq, i32, i32) -> &eq;
#[import = ("array", "caml_make_vect")]
fn caml_make_vect(&eq, &eq) -> &eq;

type float = { f: f64 };

fn box_float(f: f64) -> &eq {
    { f: f };
}

fn unbox_float(f: &eq) -> f64 {
    (f as &float).f;
}

type block = [mut &eq];
type bytes = [mut i8];
type compare = fn(&eq, &eq, i32) -> i32;
type hash = fn(&eq) -> i32;
type fixed_length = { bsize_32: i32, bsize_64: i32 };
type serialize = fn(&eq, &eq) -> (i32, i32);
type deserialize = fn(&eq) -> (&eq, i32);
type dup = fn(&eq) -> &eq;
type custom_operations = {
    id: &bytes,
    compare: &?compare,
    compare_ext: &?compare,
    hash: &?hash,
    fixed_length: &?fixed_length,
    serialize: &?serialize,
    deserialize: &?deserialize,
    dup: &?dup
};
type custom = open { ops: &custom_operations };

#[export = "float32_ops"]
const float32_ops =
    {
        id: "_f32",
        compare: float32_cmp,
        compare_ext: null,
        hash: float32_hash,
        fixed_length: { bsize_32: 4, bsize_64: 4 },
        serialize: float32_serialize,
        deserialize: float32_deserialize,
        dup: float32_dup,
    };

type float32: custom = { ops: &custom_operations, f32: f32 };

fn box_float32(f: f32) -> &eq {
    { ops: float32_ops, f32: f };
}

fn unbox_float32(f: &eq) -> f32 {
    (f as &float32).f32;
}

fn float32_cmp(v1: &eq, v2: &eq, i32) -> i32 {
    let x = unbox_float32(v1);
    let y = unbox_float32(v2);
    (x > y) - (x < y) + ((x == x) - (y == y));
}

fn float32_hash(v: &eq) -> i32 {
    let i = unbox_float32(v).to_bits();
    // Normalize NaNs and negative zero so that equal float32 values hash
    // identically, like caml_hash_mix_float.
    if i & 0x7F800000 == 0x7F800000 {
        if i & 0x7FFFFF != 0 {
            i = 0x7F800001;
        }
    }
    if i == 0x80000000 {
        i = 0;
    }
    i;
}

fn float32_serialize(s: &eq, v: &eq) -> (i32, i32) {
    caml_serialize_int_4(s, unbox_float32(v).to_bits());
    4;
    4;
}

fn float32_deserialize(s: &eq) -> (&eq, i32) {
    box_float32(caml_deserialize_int_4(s).from_bits());
    4;
}

fn float32_dup(v: &eq) -> &eq {
    let d = v as &float32;
    { ops: d.ops, f32: d.f32 };
}

fn caml_float_of_float32(f32: &eq) -> &eq {
    box_float(unbox_float32(f32) as f64);
}

fn caml_float32_of_float(f64: &eq) -> &eq {
    box_float32(unbox_float(f64) as f32);
}

#[export = "caml_round_float32_bytecode"]
fn caml_round_float32_bytecode(x: f32) -> f32 {
    let y: f32;
    if x >= 0 {
        y = x.floor();
        if x - y >= 0.5 {
            y + 1;
        } else {
            y;
        }
    } else {
        y = x.ceil();
        if y - x >= 0.5 {
            y - 1;
        } else {
            y;
        }
    }
}

const float32_of_string = "float32_of_string";

#[export = "caml_float32_of_string"]
fn caml_float32_of_string(s: &eq) -> &eq {
    caml_float32_of_float(caml_parse_float(float32_of_string, s));
}

#[export = "caml_format_float32"]
fn caml_format_float32(s: &eq, f: &eq) -> &eq {
    caml_format_float(s, caml_float_of_float32(f));
}

#[export = "caml_float32_compare"]
fn caml_float32_compare(x: f32, y: f32) -> i32 {
    (x > y) - (x < y) + ((x == x) - (y == y));
}

#[export = "caml_modf_float32"]
fn caml_modf_float32(vx: &eq) -> &eq {
    let x = unbox_float32(vx);
    let a = x.abs();
    let i: f32;
    let f: f32;
    if a >= 0 {
        if a < inf { // normal
            i = a.floor();
            f = a - i;
            i = i.copysign(x);
            f = f.copysign(x);
        } else { // infinity
            i = x;
            f = (0).copysign(x);
        }
    } else { // zero or nan
        i = x;
        f = x;
    }
    [block|0 as &i31, box_float32(f), box_float32(i)];
}

#[export = "caml_nextafter_float32_bytecode"]
fn caml_nextafter_float32_bytecode(x: f32, y: f32) -> f32 {
    if x != x {
        return x;
    }
    if y != y {
        return y;
    }
    if x == y {
        return y;
    }
    if x == 0 {
        if y >= 0 {
            return 0x1p-149;
        } else {
            return -0x1p-149;
        }
    } else {
        let i = x.to_bits();
        let j = y.to_bits();
        if (i <s j) & (i <u j) {
            i += 1;
        } else {
            i -= 1;
        }
        return i.from_bits();
    }
}

#[export = "caml_classify_float32_bytecode"]
fn caml_classify_float32_bytecode(a: f32) -> i32 {
    a = a.abs();
    if a >= 0x1p-126 {
        if a < inf {
            0; // normal
        } else {
            3;
        } // infinity
    } else {
        if a == 0 {
            2; // zero
        } else {
            if a == a {
                1; // subnormal
            } else {
                4;
            }
        }
    }
} // nan
#[export = "caml_ldexp_float32_bytecode"]
fn caml_ldexp_float32_bytecode(x: f32, n: i32) -> f32 {
    caml_ldexp_float(x as f64, n) as f32;
}

#[export = "caml_frexp_float32"]
fn caml_frexp_float32(v: &eq) -> &eq {
    let frexp = caml_frexp_float(caml_float_of_float32(v)) as &block;
    [block|0 as &i31, caml_float32_of_float(frexp[1]), frexp[2]];
}

#[export = "caml_erf_float32_bytecode"]
fn caml_erf_float32_bytecode(x: f32) -> f32 {
    caml_erf_float(x as f64) as f32;
}

#[export = "caml_erfc_float32_bytecode"]
fn caml_erfc_float32_bytecode(x: f32) -> f32 {
    caml_erfc_float(x as f64) as f32;
}

#[export = "caml_fma_float32_bytecode"]
fn caml_fma_float32_bytecode(x: &eq, y: &eq, z: &eq) -> &eq {
    caml_float32_of_float(
        caml_fma_float(caml_float_of_float32(
                            x,
                        ), caml_float_of_float32(y), caml_float_of_float32(z)),
    );
}

const zero = { ops: float32_ops, f32: 0 };

#[export = "caml_ba_uint8_getf32"]
fn caml_ba_uint8_getf32(a: &eq, i: i32) -> f32 {
    caml_ba_uint8_get32(a, i).from_bits();
}

#[export = "caml_ba_uint8_setf32"]
fn caml_ba_uint8_setf32(a: &eq, i: i32, v: f32) -> &eq {
    caml_ba_uint8_set32(a, i, v.to_bits());
}

#[export = "caml_string_getf32"]
fn caml_string_getf32(a: &eq, i: i32) -> f32 {
    caml_string_get32(a, i).from_bits();
}

#[export = "caml_bytes_getf32"]
fn caml_bytes_getf32(a: &eq, i: i32) -> f32 {
    caml_bytes_get32(a, i).from_bits();
}

#[export = "caml_bytes_setf32"]
fn caml_bytes_setf32(a: &eq, i: i32, v: f32) -> &eq {
    caml_bytes_set32(a, i, v.to_bits());
}

// Mirrors x86 MINSS/MAXSS: returns $y when the comparison fails
// (NaN or equal, including ±0). Unlike f32.min/f32.max, which
// propagate NaN and canonicalise -0 vs +0.
#[export = "caml_simd_float32_min_bytecode"]
fn caml_simd_float32_min_bytecode(x: f32, y: f32) -> f32 {
    if x < y {
        x;
    } else {
        y;
    }
}

#[export = "caml_simd_float32_max_bytecode"]
fn caml_simd_float32_max_bytecode(x: f32, y: f32) -> f32 {
    if x > y {
        x;
    } else {
        y;
    }
}

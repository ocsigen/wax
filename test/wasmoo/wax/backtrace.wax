import "fail" fn caml_invalid_argument(&eq);
#[if(wasi)]
{
    let backtrace_status: &eq = 0 as &i31;
    fn get_backtrace_status() -> &eq {
        backtrace_status;
    }
    fn record_backtrace(b: &eq) {
        backtrace_status = b;
    }
}
#[else]
import "bindings" {
    #[import = "backtrace_status"]
    fn get_backtrace_status() -> &eq;
    fn record_backtrace(&eq);
}

type block = [mut &eq];
type bytes = [mut i8];

#[export]
fn caml_get_exception_raw_backtrace(&eq) -> &eq {
    [block|0 as &i31];
}

#[export]
fn caml_backtrace_status(&eq) -> &eq {
    get_backtrace_status();
}

#[export]
fn caml_convert_raw_backtrace(&eq) -> &eq {
    [block|0 as &i31];
}

#[export]
fn caml_raw_backtrace_next_slot(&eq) -> &eq {
    0 as &i31;
}

const raw_backtrace_slot_err = "Printexc.get_raw_backtrace_slot: index out of bounds";

#[export]
fn caml_raw_backtrace_slot(&eq, &eq) -> &eq {
    caml_invalid_argument(raw_backtrace_slot_err);
    0 as &i31;
}

#[export]
fn caml_convert_raw_backtrace_slot(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_restore_raw_backtrace(&eq, &eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_get_current_callstack(&eq) -> &eq {
    [block|0 as &i31];
}

#[export]
fn caml_ml_debug_info_status(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_record_backtrace(b: &eq) -> &eq {
    record_backtrace(b);
    0 as &i31;
}

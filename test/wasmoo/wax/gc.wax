type float = { f: f64 };
type block = [mut &eq];

#[export = "caml_gc_minor"]
fn caml_gc_minor(x: &eq) -> &eq {
    0 as &i31;
}

#[export = "caml_gc_major"]
fn caml_gc_major(x: &eq) -> &eq {
    0 as &i31;
}

#[export = "caml_gc_full_major"]
fn caml_gc_full_major(x: &eq) -> &eq {
    0 as &i31;
}

#[export = "caml_gc_compaction"]
fn caml_gc_compaction(x: &eq) -> &eq {
    0 as &i31;
}

#[export = "caml_gc_counters"]
fn caml_gc_counters(x: &eq) -> &eq {
    let f: &eq = { f: 0 };
    [block|0 as &i31, f, f, f];
}

#[export = "caml_gc_stat"]
#[export = "caml_gc_quick_stat"]
fn caml_gc_stat(x: &eq) -> &eq {
    let f: &eq = { f: 0 };
    [block|
        0 as &i31,
        f,
        f,
        f,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
    ];
}


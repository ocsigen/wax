#[import = ("obj", "caml_callback_1")]
fn caml_callback_1(&eq, &eq) -> &eq;
#[import = ("fail", "caml_invalid_argument")]
fn caml_invalid_argument(&eq);

type float = { f: f64 };
type block = [mut &eq];
type bytes = [mut i8];

#[export]
fn caml_gc_minor(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_gc_major(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_gc_full_major(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_gc_compaction(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_gc_counters(&eq) -> &eq {
    let f = { f: 0 };
    [block|0 as &i31, f, f, f];
}

#[if(ocaml_version >= (5, 5, 0))]
#[export]
#[export = "caml_gc_quick_stat"]
fn caml_gc_stat(&eq) -> &eq {
    let f = { f: 0 };
    [block|
        0 as &i31,
        f,
        f,
        f,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
    ];
}
#[else]
#[export]
#[export = "caml_gc_quick_stat"]
fn caml_gc_stat(&eq) -> &eq {
    let f = { f: 0 };
    [block|
        0 as &i31,
        f,
        f,
        f,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
    ];
}

#[export]
fn caml_gc_set(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_gc_get(&eq) -> &eq {
    [block|
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
        0 as &i31,
    ];
}


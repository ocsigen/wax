const gc_tweak_error = "Gc.Tweak: parameter not found";

#[export]
fn caml_gc_tweak_get(&eq) -> &eq {
    caml_invalid_argument(gc_tweak_error);
    0 as &i31;
}

#[export]
fn caml_gc_tweak_set(&eq, &eq) -> &eq {
    caml_invalid_argument(gc_tweak_error);
    0 as &i31;
}

#[export]
fn caml_gc_tweak_list_active(&eq) -> &eq {
    0 as &i31;
}

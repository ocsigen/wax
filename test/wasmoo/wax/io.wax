#[if(wasi)]
{
    fn ta_new(sz: i32) -> &extern {
        [bytes|0; sz] as &extern;
    }

    fn ta_copy(buf: &extern, dst: i32, src: i32, end: i32) {
        let b = buf as &any as &bytes;
        b.copy(dst, b, src, end - src);
    }

    fn caml_blit_bytes_to_dataview(s: &bytes, i: i32, buf: &extern, j: i32, l: i32) {
        (buf as &any as &bytes).copy(j, s, i, l);
    }

    fn caml_blit_dataview_to_bytes(buf: &extern, i: i32, s: &bytes, j: i32, l: i32) {
        s.copy(j, buf as &any as &bytes, i, l);
    }

    fn dv_make(b: &extern) -> &extern {
        b;
    }

    fn dv_get_ui8(a: &extern, i: i32) -> i32 {
        (a as &any as &bytes)[i] as i32_u;
    }

    fn dv_set_i8(a: &extern, i: i32, v: i32) {
        (a as &any as &bytes)[i] = v;
    }

    type dat = { array: &array, offset: i32, len: i32 };

    fn ta_blit_from_buffer(buf: &extern, i: i32, ta: &extern, j: i32, len: i32) {
        let dat = ta as &any as &dat;
        caml_blit_dataview_to_bytes(buf, i, dat.array as &bytes, dat.offset + j, len);
    }

    fn ta_blit_to_buffer(ta: &extern, i: i32, buf: &extern, j: i32, len: i32) {
        let dat = ta as &any as &dat;
        caml_blit_bytes_to_dataview(dat.array as &bytes, dat.offset + i, buf, j, len);
    }

    let caml_stdout: &eq = 0 as &i31;

    // List of all open output channels, like the C runtime's
    // caml_all_opened_channels, so flush_all / at-exit reaches every channel
    // (the registry hooks are invoked from open_descriptor_out / close_channel).
    // Kept functional (cons cells are never mutated) so a list previously
    // returned by caml_ml_out_channels_list stays valid across register/close.
    let out_channels: &eq = 0 as &i31;

    fn register_channel(ch: &eq) {
        if (ch as &channel).fd == 1 {
            caml_stdout = ch;
        }
        out_channels = [block|0 as &i31, ch, out_channels];
    }

    fn unregister_channel(ch: &eq) {
        let cur = out_channels;
        let new: &eq = 0 as &i31;
        'done: do {
            'loop: loop {
                br_if 'done cur is &i31;
                let cell = cur as &block;
                if !(cell[1] == ch) {
                    new = [block|0 as &i31, cell[1], new];
                }
                cur = cell[2];
                br 'loop;
            }
        }
        out_channels = new;
    }
    fn map_new() -> &extern {
        0 as &i31 as &extern;
    }
    fn map_get(&extern, i32) -> &fd_offset {
        { offset: 0, seeked: 0, append: 0 };
    }
    fn map_set(&extern, i32, &fd_offset) {}
    fn map_delete(&extern, i32) {}

    fn file_size(fd: i32) -> i64 {
        let buffer = get_buffer();
        let res: i32;
        'error: do {
            res = fd_seek(fd, 0, 1, buffer);
            br_if 'error res;
            let cur = m.load64(buffer);
            res = fd_seek(fd, 0, 2, buffer);
            br_if 'error res;
            let end = m.load64(buffer);
            res = fd_seek(fd, cur, 0, buffer);
            br_if 'error res;
            return end;
        }
        caml_handle_sys_error(0 as &i31, res);
        0;
    }
}
#[else]
{
    #[import = ("bindings", "map_new")]
    fn map_new() -> &extern;
    #[import = ("bindings", "map_get")]
    fn map_get(&extern, i32) -> &?fd_offset;
    #[import = ("bindings", "map_set")]
    fn map_set(&extern, i32, &fd_offset);
    #[import = ("bindings", "map_delete")]
    fn map_delete(&extern, i32);

    fn ta_blit_from_buffer(buf: &extern, i: i32, ta: &extern, j: i32, len: i32) {
        ta_set(ta, ta_subarray(buf, i, i + len), j);
    }

    fn ta_blit_to_buffer(ta: &extern, i: i32, buf: &extern, j: i32, len: i32) {
        ta_set(buf, ta_subarray(ta, i, i + len), j);
    }
}

type block = [mut &eq];
type bytes = [mut i8];
type offset_array = [mut i64];

type compare = fn(&eq, &eq, i32) -> i32;
type hash = fn(&eq) -> i32;
type fixed_length = { bsize_32: i32, bsize_64: i32 };
type serialize = fn(&eq, &eq) -> (i32, i32);
type deserialize = fn(&eq) -> (&eq, i32);
type dup = fn(&eq) -> &eq;
type custom_operations = {
    id: &bytes,
    compare: &?compare,
    compare_ext: &?compare,
    hash: &?hash,
    fixed_length: &?fixed_length,
    serialize: &?serialize,
    deserialize: &?deserialize,
    dup: &?dup
};
type custom = open { ops: &custom_operations };
type custom_with_id: custom = open { ops: &custom_operations, id: i64 };

const channel_ops: &custom_operations =
    {
        id: "_chan",
        compare: custom_compare_id,
        compare_ext: null,
        hash: custom_hash_id,
        fixed_length: null,
        serialize: null,
        deserialize: null,
        dup: null,
    };

type channel: custom_with_id = {
    ops: &custom_operations,
    id: i64,
    fd: mut i32,
    buffer: mut &extern,
    buffer_view: mut &extern,
    curr: mut i32,
    max: mut i32,
    size: mut i32,
    unbuffered: mut i32,
    output: mut &?eq,
    refill: mut &?eq
};

type fd_offset = { offset: mut i64, seeked: mut i32, append: mut i32 };

let fd_offsets: &?extern = null;

fn get_fd_offsets() -> &extern {
    if !fd_offsets {
        let m = map_new();
        map_set(m, 0, { offset: 0, seeked: 0, append: 0 });
        map_set(m, 1, { offset: 0, seeked: 0, append: 0 });
        map_set(m, 2, { offset: 0, seeked: 0, append: 0 });
        fd_offsets = m;
    }
    fd_offsets!;
}

#[export = "initialize_fd_offset"]
fn initialize_fd_offset(fd: i32, offset: i64, append: i32) {
    map_set(get_fd_offsets(), fd, { offset: offset, seeked: 0, append: append });
}

#[export = "release_fd_offset"]
fn release_fd_offset(fd: i32) {
    map_delete(get_fd_offsets(), fd);
}

const bad_file_descriptor = "Bad file descriptor";

#[export = "get_fd_offset_unchecked"]
fn get_fd_offset_unchecked(fd: i32) -> &?fd_offset {
    become map_get(get_fd_offsets(), fd);
}

fn get_fd_offset(fd: i32) -> &fd_offset {
    let res = get_fd_offset_unchecked(fd);
    if !res {
        caml_raise_sys_error(bad_file_descriptor);
    }
    res!;
}

#[export = "IO_BUFFER_SIZE"]
const IO_BUFFER_SIZE = 65536;

type open_flags = [i16];

#[if(wasi)]
//      1 O_RDONLY
//      2 O_WRONLY
//   0x10 O_CREAT
//   0x40 O_EXCL
//   0x80 O_TRUNC
//  0x100 O_APPEND
//  0x400 O_NONBLOCK
const sys_open_flags: &open_flags = [1, 2, 0x102, 0x10, 0x80, 0x40, 0, 0, 0x400];
#[else]
//   1 O_RDONLY
//   2 O_WRONLY
//   4 O_RDWR
//   8 O_APPEND
//  16 O_CREAT
//  32 O_TRUNC
//  64 O_EXCL
// 128 O_NONBLOCK
const sys_open_flags: &open_flags = [1, 2, 10, 16, 32, 64, 0, 0, 128];

#[export = "convert_flag_list"]
fn convert_flag_list(tbl: &open_flags, vflags: &eq) -> i32 {
    let flags: i32;
    'loop: loop {
        match vflags {
            cons: &block => {
                flags = flags | tbl[cons[1] as &i31 as i32_u] as i32_u;
                vflags = cons[2];
                br 'loop;
            }
            _ => {}
        }
    }
    flags;
}

#[if(wasi)]
#[export = "caml_sys_open"]
fn caml_sys_open(vpath: &eq, vflags: &eq, perm: &eq) -> &eq {
    let (path_0, path_1, path_2) = caml_sys_resolve_path(vpath);
    let buffer = get_buffer();
    let flags = convert_flag_list(sys_open_flags, vflags);
    let res =
        path_open(
            path_0,
            1, // symlink_follow
            path_1,
            path_2,
            flags >>u 4 & 0xF,
            flags & 2?0x860007c:0x820003e,
            0,
            flags >>u 8,
            buffer,
        );
    free(path_1);
    caml_handle_sys_error_if(vpath, res);
    let fd = m.load32(buffer);
    let offset: i64;
    // Like native [O_APPEND], the fd position starts at 0 (WASI's O_APPEND
    // fdflag makes each write go to EOF regardless), so [pos_out] reports 0
    // right after opening, matching native.
    initialize_fd_offset(
        fd,
        offset,
        flags & 0x100 // O_APPEND
    );
    fd as &i31;
}
#[else]
#[export = "caml_sys_open"]
fn caml_sys_open(path: &eq, vflags: &eq, perm: &eq) -> &eq {
    let flags = convert_flag_list(sys_open_flags, vflags);
    let fd: i32;
    try {
        fd = open_fn(unwrap(caml_jsstring_of_string(path)), flags, perm as &i31 as i32_u);
    } catch {
        javascript_exception => {
            caml_handle_sys_error(_);
        }
    }
    let offset: i64;
    // Like native [O_APPEND], the offset starts at 0; writes reposition to
    // EOF (see [caml_flush_partial]).
    initialize_fd_offset(
        fd,
        offset,
        flags & 8 // O_APPEND
    );
    fd as &i31;
}

#[if(wasi)]
#[export = "caml_sys_close"]
fn caml_sys_close(vfd: &eq) -> &eq {
    let fd = vfd as &i31 as i32_u;
    release_fd_offset(fd);
    let res = fd_close(fd);
    caml_handle_sys_error_if(0 as &i31, res);
    0 as &i31;
}
#[else]
#[export = "caml_sys_close"]
fn caml_sys_close(vfd: &eq) -> &eq {
    let res: i32;
    let fd = vfd as &i31 as i32_u;
    release_fd_offset(fd);
    try {
        close(fd);
    } catch {
        javascript_exception => {
            caml_handle_sys_error(_);
        }
    }
    0 as &i31;
}

#[export = "caml_sys_io_buffer_size"]
fn caml_sys_io_buffer_size(&eq) -> &eq {
    IO_BUFFER_SIZE as &i31;
}

#[export = "caml_ml_set_channel_name"]
fn caml_ml_set_channel_name(&eq, &eq) -> &eq {
    0 as &i31;
}

#[if(wasi)]
{
    // Channel output/refill hooks redirect I/O to a JavaScript callback.
    // The WASI runtime reads and writes through real file descriptors and
    // ignores these hooks, so the setters raise rather than silently doing
    // nothing.
    #[export = "caml_ml_set_channel_output"]
    fn caml_ml_set_channel_output(ch: &eq, f: &eq) -> &eq {
        caml_invalid_argument("caml_ml_set_channel_output not supported with WASI");
        0 as &i31;
    }

    #[export = "caml_ml_set_channel_refill"]
    fn caml_ml_set_channel_refill(ch: &eq, f: &eq) -> &eq {
        caml_invalid_argument("caml_ml_set_channel_refill not supported with WASI");
        0 as &i31;
    }
}
#[else]
{
    #[export = "caml_ml_set_channel_output"]
    fn caml_ml_set_channel_output(ch: &eq, f: &eq) -> &eq {
        (ch as &channel).output = f;
        0 as &i31;
    }

    #[export = "caml_ml_set_channel_refill"]
    fn caml_ml_set_channel_refill(ch: &eq, f: &eq) -> &eq {
        (ch as &channel).refill = f;
        0 as &i31;
    }
}

#[if(wasi)]
fn push_channel(l: &eq, ch: &eq) -> &eq {
    'continue: do {
        br_if 'continue !(ch is &channel);
        let c = ch as &channel;
        br_if 'continue c.fd == -1;
        l = [block|0 as &i31, ch, l];
    }
    l;
}

#[if(wasi)]
#[export = "caml_ml_out_channels_list"]
fn caml_ml_out_channels_list(&eq) -> &eq {
    out_channels;
}
#[else]
#[export = "caml_ml_out_channels_list"]
fn caml_ml_out_channels_list(&eq) -> &eq {
    become caml_list_of_js_array(wrap(channel_list()));
}

#[export = "caml_ml_open_descriptor_in"]
fn caml_ml_open_descriptor_in(fd: &eq) -> &eq {
    let buffer = ta_new(IO_BUFFER_SIZE);
    {
        ops: channel_ops,
        id: custom_next_id(),
        fd: fd as &i31 as i32_u,
        buffer: buffer,
        buffer_view: dv_make(buffer),
        curr: 0,
        max: 0,
        size: IO_BUFFER_SIZE,
        unbuffered: 0,
        output: null,
        refill: null,
    };
}

#[export = "caml_stderr"]
let caml_stderr: &eq = 0 as &i31;

#[export = "caml_ml_open_descriptor_out"]
fn caml_ml_open_descriptor_out(fd: &eq) -> &eq {
    let buffer = ta_new(IO_BUFFER_SIZE);
    let res: &eq =
        {
            ops: channel_ops,
            id: custom_next_id(),
            fd: fd as &i31 as i32_u,
            buffer: buffer,
            buffer_view: dv_make(buffer),
            curr: 0,
            max: -1,
            size: IO_BUFFER_SIZE,
            unbuffered: 0,
            output: null,
            refill: null,
        };
    register_channel(res);
    if fd == 2 as &i31 {
        caml_stderr = res;
    }
    res;
}

#[export = "caml_ml_set_binary_mode"]
fn caml_ml_set_binary_mode(&eq, &eq) -> &eq {
    0 as &i31;
}

#[export = "caml_ml_is_binary_mode"]
fn caml_ml_is_binary_mode(&eq) -> &eq {
    1 as &i31;
}

#[export = "caml_channel_descriptor"]
fn caml_channel_descriptor(ch: &eq) -> &eq {
    let fd = (ch as &channel).fd;
    if fd == -1 {
        caml_raise_sys_error("bad file descriptor");
    }
    fd as &i31;
}

#[export = "caml_ml_close_channel"]
fn caml_ml_close_channel(vch: &eq) -> &eq {
    let ch = vch as &channel;
    // output channels: any output will trigger a flush since the
    // buffer is non-empty (curr > 0) and full (curr = size)
    // input channels: any input will trigger a read since the buffer
    // is empty (curr = max)
    ch.curr = 1;
    ch.max = 1;
    ch.size = 1;
    let fd = ch.fd;
    if fd != -1 {
        ch.fd = -1;
        unregister_channel(ch);
        release_fd_offset(fd);
        let res: i32;
        #[if(wasi)]
        {
            res = fd_close(fd);
            caml_handle_sys_error_if(0 as &i31, res);
        }
        #[else]
        {
            try {
                close(fd);
            } catch {
                javascript_exception => {
                    // ignore exception
                    _ = _;
                }
            }
        }
    }
    0 as &i31;
}

#[if(wasi)]
fn read(fd: i32, buf: &extern, pos: i32, n: i32) -> i32 {
    let buffer = get_buffer();
    let nread = buffer;
    let iovs = buffer + 4;
    buffer = buffer + 12;
    m.store32(iovs, buffer);
    m.store32(iovs, n, 4, 4);
    let iovs_len = 1;
    let res = fd_read(fd, iovs, iovs_len, nread);
    caml_handle_sys_error_if(0 as &i31, res);
    n = m.load32(nread);
    let s = buf as &any as &bytes;
    blit_memory_to_substring(buffer, s, pos, n);
    n;
}

fn caml_do_read(ch: &channel, pos: i32, len: i32) -> i32 {
    let fd = ch.fd;
    let fd_offset: &fd_offset;
    let offset: i64;
    let n: i32;
    #[if(wasi)]
    {
        n = read(fd, ch.buffer, pos, len);
    }
    #[else]
    {
        fd_offset = get_fd_offset(fd);
        offset = fd_offset.offset;
        try {
            n =
                if fd_offset.seeked => i32 {
                    read(fd, ch.buffer, pos, len, offset);
                } else {
                    read'(fd, ch.buffer, pos, len, null);
                };
        } catch {
            javascript_exception => {
                caml_handle_sys_error(_);
            }
        }
        fd_offset.offset = offset + n as i64_u;
    }
    n;
}

#[if(wasi)]
// The refill hook is not supported with WASI (see
// caml_ml_set_channel_refill), so this always reads from the fd.
fn caml_do_read_or_refill(ch: &channel, pos: i32, len: i32) -> i32 {
    become caml_do_read(ch, pos, len);
}
#[else]
fn caml_do_read_or_refill(ch: &channel, pos: i32, len: i32) -> i32 {
    let f = ch.refill;
    if !f {
        return caml_do_read(ch, pos, len);
    }
    let str = caml_js_fun_call(f!, [block|0 as &i31]) as &bytes;
    let str_len = str.length();
    if !str_len {
        ch.refill = null;
        return 0;
    }
    // Grow the channel buffer if the refilled data does not fit, so that
    // no bytes are dropped (the JS runtime does the same), preserving the
    // bytes already buffered before $pos.
    if pos + str_len >u ch.size {
        let new_size = pos + str_len;
        let new_buffer = ta_new(new_size);
        ta_set(new_buffer, ch.buffer, 0);
        ch.buffer = new_buffer;
        ch.buffer_view = dv_make(new_buffer);
        ch.size = new_size;
    }
    caml_blit_bytes_to_dataview(str, 0, ch.buffer_view, pos, str_len);
    // Advance the channel offset so that pos_in/pos_out stay consistent.
    let fd_offset = get_fd_offset(ch.fd);
    fd_offset.offset = fd_offset.offset + str_len as i64_u;
    str_len;
}

fn caml_refill(ch: &channel) -> i32 {
    let view = ch.buffer_view;
    let n = caml_do_read_or_refill(ch, 0, ch.size);
    if !n {
        caml_raise_end_of_file();
    }
    ch.max = n;
    ch.curr = 1;
    return dv_get_ui8(view, 0);
}

#[export = "caml_getblock"]
fn caml_getblock(vch: &eq, s: &bytes, pos: i32, len: i32) -> i32 {
    if !len {
        return 0;
    }
    let ch = vch as &channel;
    let avail = ch.max - ch.curr;
    if avail {
        if len >u avail {
            len = avail;
        }
        caml_blit_dataview_to_bytes(ch.buffer_view, ch.curr, s, pos, len);
        ch.curr = ch.curr + len;
        return len;
    }
    let nread = caml_do_read_or_refill(ch, 0, ch.size);
    ch.max = nread;
    if len >u nread {
        len = nread;
    }
    caml_blit_dataview_to_bytes(ch.buffer_view, 0, s, pos, len);
    ch.curr = len;
    len;
}

fn caml_getblock_typed_array(vch: &eq, d: &extern, pos: i32, len: i32) -> i32 {
    if !len {
        return 0;
    }
    let ch = vch as &channel;
    let avail = ch.max - ch.curr;
    if avail {
        if len >u avail {
            len = avail;
        }
        ta_blit_from_buffer(ch.buffer, ch.curr, d, pos, len);
        ch.curr = ch.curr + len;
        return len;
    }
    let nread = caml_do_read_or_refill(ch, 0, ch.size);
    ch.max = nread;
    if len >u nread {
        len = nread;
    }
    ta_blit_from_buffer(ch.buffer, 0, d, pos, len);
    ch.curr = len;
    len;
}

#[export = "caml_really_getblock"]
fn caml_really_getblock(ch: &eq, s: &bytes, pos: i32, len: i32) -> i32 {
    let n = len;
    while n {
        let read = caml_getblock(ch, s, pos, n);
        if !read {
            return len - n;
        }
        pos = pos + read;
        n = n - read;
    }
    len;
}

#[export = "caml_ml_input"]
fn caml_ml_input(vch: &eq, vs: &eq, vpos: &eq, vlen: &eq) -> &eq {
    let ch = vch as &channel;
    let s = vs as &bytes;
    let pos = vpos as &i31 as i32_u;
    let len = vlen as &i31 as i32_u;
    let buf = ch.buffer_view;
    let curr = ch.curr;
    let avail = ch.max - curr;
    if len >u avail {
        if avail >u 0 {
            len = avail;
        } else {
            let nread = caml_do_read_or_refill(ch, 0, ch.size);
            ch.max = nread;
            curr = 0;
            if len >u nread {
                len = nread;
            }
        }
    }
    // Re-read the buffer view: a refill may have grown (reallocated) it.
    buf = ch.buffer_view;
    caml_blit_dataview_to_bytes(buf, curr, s, pos, len);
    ch.curr = curr + len;
    len as &i31;
}

fn caml_getch(ch: &channel) -> i32 {
    let curr = ch.curr;
    if curr >=u ch.max {
        become caml_refill(ch);
    }
    ch.curr = curr + 1;
    become dv_get_ui8(ch.buffer_view, curr);
}

#[export = "caml_ml_input_char"]
fn caml_ml_input_char(ch: &eq) -> &eq {
    caml_getch(ch as &channel) as &i31;
}

#[export = "caml_ml_input_int"]
fn caml_ml_input_int(vch: &eq) -> &eq {
    let ch = vch as &channel;
    let res = caml_getch(ch) << 24;
    res = res | caml_getch(ch) << 16;
    res = res | caml_getch(ch) << 8;
    return (res | caml_getch(ch)) as &i31;
}

#[export = "caml_ml_pos_in"]
fn caml_ml_pos_in(vch: &eq) -> &eq {
    let ch = vch as &channel;
    (caml_ml_get_channel_offset(ch) as i32 - (ch.max - ch.curr)) as &i31;
}

#[export = "caml_ml_pos_in_64"]
fn caml_ml_pos_in_64(vch: &eq) -> &eq {
    let ch = vch as &channel;
    caml_copy_int64(caml_ml_get_channel_offset(ch) - (ch.max - ch.curr) as i64_s);
}

#[export = "caml_ml_pos_out"]
fn caml_ml_pos_out(vch: &eq) -> &eq {
    let ch = vch as &channel;
    (caml_ml_get_channel_offset(ch) as i32 + ch.curr) as &i31;
}

#[export = "caml_ml_pos_out_64"]
fn caml_ml_pos_out_64(vch: &eq) -> &eq {
    let ch = vch as &channel;
    caml_copy_int64(caml_ml_get_channel_offset(ch) + ch.curr as i64_s);
}

#[if(wasi)]
fn caml_seek_in(ch: &channel, dest: i64) -> &eq {
    let fd = ch.fd;
    let buffer = get_buffer();
    // ZZZ store current offset in channel do avoid some syscalls?
    let res = fd_seek(fd, dest, 0, buffer);
    caml_handle_sys_error_if(0 as &i31, res);
    ch.curr = 0;
    ch.max = 0;
    0 as &i31;
}
#[else]
fn caml_seek_in(ch: &channel, dest: i64) -> &eq {
    let fd = ch.fd;
    let fd_offset = get_fd_offset(fd);
    let offset = fd_offset.offset;
    if (dest >=s offset - ch.max as i64_s) & (dest <=s offset) {
        ch.curr = ch.max - (offset - dest) as i32;
    } else {
        if dest <s 0 {
            caml_raise_sys_error("Invalid argument");
        }
        fd_offset.offset = dest;
        fd_offset.seeked = 1;
        ch.curr = 0;
        ch.max = 0;
    }
    0 as &i31;
}

#[export = "caml_ml_seek_in"]
fn caml_ml_seek_in(ch: &eq, dest: &eq) -> &eq {
    become caml_seek_in(ch as &channel, dest as &i31 as i32_s as i64_s);
}

#[export = "caml_ml_seek_in_64"]
fn caml_ml_seek_in_64(ch: &eq, dest: &eq) -> &eq {
    become caml_seek_in(ch as &channel, Int64_val(dest));
}

#[export = "caml_ml_seek_out"]
fn caml_ml_seek_out(vch: &eq, voffset: &eq) -> &eq {
    let ch = vch as &channel;
    caml_flush(ch);
    let fd_offset: &fd_offset;
    let offset: i64;
    let buffer: i32;
    let res: i32;
    #[if(wasi)]
    {
        buffer = get_buffer();
        res = fd_seek(ch.fd, voffset as &i31 as i32_s as i64_s, 0, buffer);
        caml_handle_sys_error_if(0 as &i31, res);
    }
    #[else]
    {
        // ZZZ Check for error
        fd_offset = get_fd_offset(ch.fd);
        offset = voffset as &i31 as i32_s as i64_s;
        if offset <s 0 {
            caml_raise_sys_error("Invalid argument");
        }
        fd_offset.offset = offset;
        fd_offset.seeked = 1;
    }
    0 as &i31;
}

#[export = "caml_ml_seek_out_64"]
fn caml_ml_seek_out_64(vch: &eq, voffset: &eq) -> &eq {
    let ch = vch as &channel;
    caml_flush(ch);
    let fd_offset: &fd_offset;
    let offset: i64;
    let buffer: i32;
    let res: i32;
    #[if(wasi)]
    {
        buffer = get_buffer();
        res = fd_seek(ch.fd, Int64_val(voffset), 0, buffer);
        caml_handle_sys_error_if(0 as &i31, res);
    }
    #[else]
    {
        // ZZZ Check for error
        fd_offset = get_fd_offset(ch.fd);
        offset = Int64_val(voffset);
        if offset <s 0 {
            caml_raise_sys_error("Invalid argument");
        }
        fd_offset.offset = offset;
        fd_offset.seeked = 1;
    }
    0 as &i31;
}

#[export = "caml_ml_input_scan_line"]
fn caml_ml_input_scan_line(vch: &eq) -> &eq {
    let ch = vch as &channel;
    let p = ch.curr;
    'loop: loop {
        if p >=u ch.max {
            let n: i32;
            if ch.curr {
                n = ch.curr;
                ta_copy(ch.buffer, 0, n, ch.max);
                ch.curr = 0;
                ch.max = ch.max - n;
                p = p - n;
            }
            if ch.max >=u ch.size {
                return (ch.curr - ch.size) as &i31;
            }
            n = caml_do_read_or_refill(ch, ch.max, ch.size - ch.max);
            if !n {
                return (ch.curr - ch.max) as &i31;
            }
            ch.max = ch.max + n;
        }
        if
            10 // '\n'
                == dv_get_ui8(ch.buffer_view, p) {
            return (1 + (p - ch.curr)) as &i31;
        }
        p = p + 1;
        br 'loop;
    }
    unreachable;
}

fn caml_flush(ch: &channel) {
    'loop: loop {
        br_if 'loop !caml_flush_partial(ch);
    }
}

#[export = "caml_flush_if_unbuffered"]
fn caml_flush_if_unbuffered(vch: &eq) {
    let ch = vch as &channel;
    if ch.unbuffered {
        caml_flush(ch);
    }
}

#[export = "caml_ml_flush"]
fn caml_ml_flush(vch: &eq) -> &eq {
    let ch = vch as &channel;
    if ch.fd != -1 {
        caml_flush(ch);
    }
    0 as &i31;
}

#[if(wasi)]
fn write(fd: i32, buf: &extern, pos: i32, n: i32) -> i32 {
    let buffer = get_buffer();
    let nwritten = buffer;
    let iovs = buffer + 4;
    buffer = buffer + 12;
    m.store32(iovs, buffer);
    m.store32(iovs, n, 4, 4);
    let iovs_len = 1;
    let s = buf as &any as &bytes;
    blit_substring_to_memory(buffer, s, pos, n);
    let res = fd_write(fd, iovs, iovs_len, nwritten);
    caml_handle_sys_error_if(0 as &i31, res);
    m.load32(nwritten);
}

#[if(wasi)]
{
    #[export = "write_all_to_fd"]
    fn write_all_to_fd(fd: i32, v: &eq) {
        let len = (v as &bytes).length();
        let buffer = get_buffer();
        let nwritten = buffer;
        let iovs = buffer + 4;
        buffer = buffer + 12;
        let buf = write_string_to_memory(buffer, IO_BUFFER_SIZE, v);
        let remaining = buf;
        'write: loop {
            m.store32(iovs, remaining);
            m.store32(iovs, len, 4, 4);
            let res = fd_write(fd, iovs, 1, nwritten);
            if !res {
                len = len - m.load32(nwritten);
                remaining = remaining + m.load32(nwritten);
                br_if 'write len;
            }
        }
        release_memory(buffer, buf);
    }

    fn caml_flush_partial(ch: &channel) -> i32 {
        let fd_offset: &fd_offset;
        let offset: i64;
        let tmp: &bytes;
        let towrite = ch.curr;
        if towrite >u 0 {
            let buf = ch.buffer;
            let fd = ch.fd;
            let written = write(fd, buf, 0, towrite);
            if towrite >u written {
                ta_copy(buf, 0, written, towrite);
            }
            towrite = towrite - written;
            ch.curr = towrite;
        }
        !towrite;
    }
}
#[else]
fn caml_flush_partial(ch: &channel) -> i32 {
    let towrite = ch.curr;
    if towrite >u 0 {
        let buf = ch.buffer;
        if !ch.output {
            let fd = ch.fd;
            let fd_offset = get_fd_offset(fd);
            let offset = fd_offset.offset;
            // [O_APPEND]: every write goes to the end of the file,
            // regardless of the current offset (which [seek] may have
            // moved). Reposition to EOF before writing, like fs_node.js:
            // the OS append flag alone is not portable for a positioned
            // write (it appends on Linux but not macOS).
            if fd_offset.append {
                offset = file_size(fd);
            }
            let written: i32;
            try {
                written =
                    if fd_offset.seeked => i32 {
                        write(fd, buf, 0, towrite, offset);
                    } else {
                        write'(fd, buf, 0, towrite, null);
                    };
            } catch {
                javascript_exception => {
                    caml_handle_sys_error(_);
                }
            }
            fd_offset.offset = offset + written as i64_u;
            if towrite >u written {
                ta_copy(buf, 0, written, towrite);
            }
            towrite = towrite - written;
            ch.curr = towrite;
        } else {
            let tmp: &bytes = [0; towrite];
            caml_blit_dataview_to_bytes(ch.buffer_view, 0, tmp, 0, towrite);
            _ = caml_js_fun_call(ch.output!, [block|0 as &i31, caml_jsbytes_of_string(tmp)]);
            ch.curr = 0;
            towrite = 0;
        }
    }
    !towrite;
}

fn caml_putblock(ch: &channel, s: &bytes, pos: i32, len: i32) -> i32 {
    let curr = ch.curr;
    let free = ch.size - curr;
    if len >=u free {
        len = free;
    }
    let buf = ch.buffer_view;
    caml_blit_bytes_to_dataview(s, pos, buf, curr, len);
    ch.curr = curr + len;
    if len >=u free {
        _ = caml_flush_partial(ch);
    }
    len;
}

fn caml_putblock_typed_array(ch: &channel, d: &extern, pos: i32, len: i32) -> i32 {
    let curr = ch.curr;
    let free = ch.size - curr;
    if len >=u free {
        len = free;
    }
    let buf = ch.buffer;
    ta_blit_to_buffer(d, pos, buf, curr, len);
    ch.curr = curr + len;
    if len >=u free {
        _ = caml_flush_partial(ch);
    }
    len;
}

#[export = "caml_really_putblock"]
fn caml_really_putblock(ch: &eq, s: &bytes, pos: i32, len: i32) {
    while len {
        let written = caml_putblock(ch as &channel, s, pos, len);
        pos = pos + written;
        len = len - written;
    }
}

fn caml_really_putblock_typed_array(ch: &eq, d: &extern, pos: i32, len: i32) {
    while len {
        let written = caml_putblock_typed_array(ch as &channel, d, pos, len);
        pos = pos + written;
        len = len - written;
    }
}

#[export = "caml_ml_output"]
#[export = "caml_ml_output_bytes"]
fn caml_ml_output(ch: &eq, s: &eq, vpos: &eq, vlen: &eq) -> &eq {
    let pos = vpos as &i31 as i32_u;
    let len = vlen as &i31 as i32_u;
    while len >u 0 {
        let written = caml_putblock(ch as &channel, s as &bytes, pos, len);
        pos = pos + written;
        len = len - written;
    }
    caml_flush_if_unbuffered(ch);
    0 as &i31;
}

fn caml_putch(ch: &channel, c: i32) {
    if ch.curr >=u ch.size {
        _ = caml_flush_partial(ch);
    }
    let curr = ch.curr;
    dv_set_i8(ch.buffer_view, curr, c);
    ch.curr = curr + 1;
}

#[export = "caml_ml_output_char"]
fn caml_ml_output_char(ch: &eq, c: &eq) -> &eq {
    caml_putch(ch as &channel, c as &i31 as i32_u);
    caml_flush_if_unbuffered(ch);
    0 as &i31;
}

#[export = "caml_ml_output_int"]
fn caml_ml_output_int(vch: &eq, vn: &eq) -> &eq {
    let ch = vch as &channel;
    let n = vn as &i31 as i32_u;
    caml_putch(ch, n >>u 24);
    caml_putch(ch, n >>u 16);
    caml_putch(ch, n >>u 8);
    caml_putch(ch, n);
    caml_flush_if_unbuffered(ch);
    0 as &i31;
}

#[export = "caml_ml_is_buffered"]
fn caml_ml_is_buffered(ch: &eq) -> &eq {
    !(ch as &channel).unbuffered as &i31;
}

#[export = "caml_ml_set_buffered"]
fn caml_ml_set_buffered(vch: &eq, mode: &eq) -> &eq {
    let ch = vch as &channel;
    if mode as &i31 as i32_s {
        ch.unbuffered = 0;
    } else {
        ch.unbuffered = 1;
        if ch.fd != -1 {
            caml_flush(ch);
        }
    }
    0 as &i31;
}

#[export = "caml_ml_channel_size"]
fn caml_ml_channel_size(vch: &eq) -> &eq {
    // ZZZ check for overflow
    file_size(caml_ml_get_channel_fd(vch)) as i32 as &i31;
}

#[export = "caml_ml_channel_size_64"]
fn caml_ml_channel_size_64(vch: &eq) -> &eq {
    caml_copy_int64(file_size(caml_ml_get_channel_fd(vch)));
}

#[export = "caml_ml_get_channel_fd"]
fn caml_ml_get_channel_fd(vch: &eq) -> i32 {
    (vch as &channel).fd;
}

#[export = "caml_ml_set_channel_fd"]
fn caml_ml_set_channel_fd(vch: &eq, fd: i32) {
    (vch as &channel).fd = fd;
}

#[if(wasi)]
#[export = "caml_ml_get_channel_offset"]
fn caml_ml_get_channel_offset(ch: &eq) -> i64 {
    let fd = (ch as &channel).fd;
    let buffer = get_buffer();
    let res = fd_seek(fd, 0, 1, buffer);
    caml_handle_sys_error_if(0 as &i31, res);
    m.load64(buffer);
}
#[else]
#[export = "caml_ml_get_channel_offset"]
fn caml_ml_get_channel_offset(ch: &eq) -> i64 {
    get_fd_offset((ch as &channel).fd).offset;
}

#[export = "caml_ml_output_bigarray"]
fn caml_ml_output_bigarray(ch: &eq, a: &eq, vpos: &eq, vlen: &eq) -> &eq {
    let d = caml_ba_get_data(a);
    let pos = vpos as &i31 as i32_u;
    let len = vlen as &i31 as i32_u;
    caml_really_putblock_typed_array(ch, d, pos, len);
    0 as &i31;
}

#[export = "caml_ml_input_bigarray"]
fn caml_ml_input_bigarray(ch: &eq, a: &eq, vpos: &eq, vlen: &eq) -> &eq {
    let d = caml_ba_get_data(a);
    let pos = vpos as &i31 as i32_u;
    let len = vlen as &i31 as i32_u;
    caml_getblock_typed_array(ch, d, pos, len) as &i31;
}

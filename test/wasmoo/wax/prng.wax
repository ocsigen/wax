import "bigarray" fn caml_ba_get_view(&eq) -> &extern;
#[if(wasi)]
{
    import "bigarray" {
        fn dv_get_i64(&extern, i32, i32) -> i64;
        fn dv_set_i64(&extern, i32, i64, i32);
    }
    const littleEndian = 1;
}
#[else]
import "bindings" {
    fn dv_get_i64(&?extern, i32, i32) -> i64;
    fn dv_set_i64(&?extern, i32, i64, i32);
    const littleEndian: i32;
}

#[export]
fn caml_lxm_next(v: &eq) -> i64 {
    let view = caml_ba_get_view(v);
    let a = dv_get_i64(view, 0, littleEndian);
    let s = dv_get_i64(view, 8, littleEndian);
    let q0 = dv_get_i64(view, 16, littleEndian);
    let q1 = dv_get_i64(view, 24, littleEndian);
    let z = s + q0;
    z = (z ^ z >>u 32) * 0xdaba0b6eb09322e3;
    z = (z ^ z >>u 32) * 0xdaba0b6eb09322e3;
    z ^= z >>u 32;
    s = s * 0xd1342543de82ef95 + a;
    dv_set_i64(view, 8, s, littleEndian);
    q1 ^= q0;
    q0 = q0.rotl(24);
    q0 = q0 ^ q1 ^ q1 << 16;
    q1 = q1.rotl(37);
    dv_set_i64(view, 16, q0, littleEndian);
    dv_set_i64(view, 24, q1, littleEndian);
    return z;
}

#[import = ("bindings", "ta_get_i32")]
fn ta_get_i32(&extern, i32) -> i32;
#[import = ("bindings", "ta_set_i32")]
fn ta_set_i32(&extern, i32, i32);
#[import = ("bigarray", "caml_ba_get_data")]
fn caml_ba_get_data(&eq) -> &extern;

#[export = "caml_lxm_next"]
fn caml_lxm_next(v: &eq) -> i64 {
    let data = caml_ba_get_data(v);
    let a = ta_get_i32(data, 0) as i64_u | ta_get_i32(data, 1) as i64_u << 32;
    let s = ta_get_i32(data, 2) as i64_u | ta_get_i32(data, 3) as i64_u << 32;
    let q0 = ta_get_i32(data, 4) as i64_u | ta_get_i32(data, 5) as i64_u << 32;
    let q1 = ta_get_i32(data, 6) as i64_u | ta_get_i32(data, 7) as i64_u << 32;
    let z = s + q0;
    z = (z ^ z >>u 32) * 0xdaba0b6eb09322e3;
    z = (z ^ z >>u 32) * 0xdaba0b6eb09322e3;
    z = z ^ z >>u 32;
    s = s * 0xd1342543de82ef95 + a;
    ta_set_i32(data, 2, s as i32);
    ta_set_i32(data, 3, (s >>u 32) as i32);
    q1 = q1 ^ q0;
    q0 = q0.rotl(24);
    q0 = q0 ^ q1 ^ q1 << 16;
    q1 = q1.rotl(37);
    ta_set_i32(data, 4, q0 as i32);
    ta_set_i32(data, 5, (q0 >>u 32) as i32);
    ta_set_i32(data, 6, q1 as i32);
    ta_set_i32(data, 7, (q1 >>u 32) as i32);
    return z;
}

#[import = ("obj", "object_tag")]
const object_tag: i32;
#[import = ("obj", "forward_tag")]
const forward_tag: i32;
#[import = ("obj", "abstract_tag")]
const abstract_tag: i32;
#[import = ("jsstring", "jsstring_test")]
fn jsstring_test(&?any) -> i32;
#[import = ("jsstring", "jsstring_hash")]
fn jsstring_hash(i32, &?any) -> i32;

type block = [mut &eq];
type bytes = [mut i8];
type float = { f: f64 };
type js = { js: &?any };

type compare = fn(&eq, &eq, i32) -> i32;
type hash = fn(&eq) -> i32;
type fixed_length = { bsize_32: i32, bsize_64: i32 };
type serialize = fn(&eq, &eq) -> (i32, i32);
type deserialize = fn(&eq) -> (&eq, i32);
type dup = fn(&eq) -> &eq;
type custom_operations = {
    id: &bytes,
    compare: &?compare,
    compare_ext: &?compare,
    hash: &?hash,
    fixed_length: &?fixed_length,
    serialize: &?serialize,
    deserialize: &?deserialize,
    dup: &?dup
};
type custom = open { ops: &custom_operations };

#[export = "caml_hash_mix_int"]
fn caml_hash_mix_int(h: i32, d: i32) -> i32 {
    ((d * 0xcc9e2d51).rotl(15) * 0x1b873593 ^ h).rotl(13) * 5 + 0xe6546b64;
}

#[export = "caml_hash_mix_final"]
fn caml_hash_mix_final(h: i32) -> i32 {
    h = h ^ h >>u 16;
    h = h * 0x85ebca6b;
    h = h ^ h >>u 13;
    h = h * 0xc2b2ae35;
    h ^ h >>u 16;
}

#[export = "caml_hash_mix_int64"]
fn caml_hash_mix_int64(h: i32, d: i64) -> i32 {
    become caml_hash_mix_int(caml_hash_mix_int(h, d as i32), (d >>u 32) as i32);
}

#[export = "caml_hash_mix_double"]
fn caml_hash_mix_double(h: i32, d: f64) -> i32 {
    let i = d.to_bits();
    if i & 0x7FF0000000000000 == 0x7ff0000000000000 {
        if i & 0xFFFFFFFFFFFFF != 0 {
            i = 0x7ff0000000000001;
        }
    }
    if i == 0x8000000000000000 {
        i = 0;
    }
    become caml_hash_mix_int64(h, i);
}

#[export = "caml_hash_mix_float"]
fn caml_hash_mix_float(h: i32, d: f32) -> i32 {
    let i = d.to_bits();
    if i & 0x7F800000 == 0x7F800000 {
        if i & 0x7FFFFF != 0 {
            i = 0x7F800001;
        }
    }
    if i == 0x80000000 {
        i = 0;
    }
    become caml_hash_mix_int(h, i);
}

#[export = "caml_hash_mix_float16"]
fn caml_hash_mix_float16(h: i32, i: i32) -> i32 {
    if i & 0x7c00 == 0x7c00 {
        if i & 0x03ff {
            i = 0x7C01;
        }
    }
    if i == 0x8000 {
        i = 0;
    }
    become caml_hash_mix_int(h, i);
}

#[export = "caml_hash_mix_string"]
fn caml_hash_mix_string(h: i32, s: &bytes) -> i32 {
    let len = s.length();
    let i = 0;
    while i + 4 <=u len {
        h =
            caml_hash_mix_int(
                h,
                s[i] as i32_u | s[i + 1] as i32_u << 8
                    | (s[i + 2] as i32_u << 16 | s[i + 3] as i32_u << 24),
            );
        i = i + 4;
    }
    let w = 0;
    dispatch (len & 3) [ 'l_2 'l_3 'l_4 else 'l_5 ] {
        'l_5: {
            w = s[i + 2] as i32_u << 16;
        }
        'l_4: {
            w = w | s[i + 1] as i32_u << 8;
        }
        'l_3: {
            w = w | s[i] as i32_u;
            h = caml_hash_mix_int(h, w);
        }
        'l_2: {
            h ^ len;
        }
    }
}

const HASH_QUEUE_SIZE = 256;
const MAX_FORWARD_DEREFERENCE = 1000;

const caml_hash_queue: &block = [0 as &i31; HASH_QUEUE_SIZE];

type float_array = [mut f64];

#[export = "caml_hash"]
#[export = "caml_hash_exn"]
fn caml_hash(count: &eq, limit: &eq, seed: &eq, obj: &eq) -> &eq {
    let sz = limit as i32_u;
    if sz >u HASH_QUEUE_SIZE {
        sz = HASH_QUEUE_SIZE;
    }
    let num = count as i32_u;
    let h = seed as i32_s;
    caml_hash_queue[0] = obj;
    let rd = 0;
    let wr = 1;
    'loop: loop {
        if (rd <u wr) & (num >u 0) {
            let v = caml_hash_queue[rd];
            rd = rd + 1;
            'again: do {
                let i: i32;
                let len: i32;
                match v {
                    iv: &i31 => {
                        h = caml_hash_mix_int(h, (iv as i32_s << 1) + 1);
                        num = num - 1;
                        br 'loop;
                    }
                    sv: &bytes => {
                        h = caml_hash_mix_string(h, sv);
                        num = num - 1;
                        br 'loop;
                    }
                    bv: &block => {
                        let tg = bv[0] as i32_u;
                        if tg == forward_tag {
                            i = 0;
                            'forward: loop {
                                v = bv[1];
                                _ =
                                    'not_block': do {
                                        bv = br_on_cast_fail 'not_block' &block v;
                                        br_if 'again bv[0] != forward_tag as &i31;
                                        i = i + 1;
                                        br_if 'loop i == MAX_FORWARD_DEREFERENCE;
                                        br 'forward;
                                    };
                                br 'again;
                            }
                        }
                        if tg == object_tag {
                            h = caml_hash_mix_int(h, bv[2] as i32_s);
                            br 'loop;
                        }
                        // abstract tag: block contents unknown, do nothing
                        br_if 'loop tg == abstract_tag;
                        len = bv.length();
                        h = caml_hash_mix_int(h, len - 1 << 10 | tg);
                        i = 1;
                        'block_iter: loop {
                            br_if 'loop i >=u len;
                            br_if 'loop wr >=u sz;
                            caml_hash_queue[wr] = bv[i];
                            wr = wr + 1;
                            i = i + 1;
                            br 'block_iter;
                        }
                        unreachable;
                    }
                    flv: &float => {
                        h = caml_hash_mix_double(h, flv.f);
                        num = num - 1;
                        br 'loop;
                    }
                    fa: &float_array => {
                        // mix the elements directly, no header
                        len = fa.length();
                        i = 0;
                        'fa_iter: loop {
                            if i <u len {
                                h = caml_hash_mix_double(h, fa[i]);
                                num = num - 1;
                                i = i + 1;
                                br_if 'fa_iter num >s 0;
                            }
                        }
                        br 'loop;
                    }
                    cv: &custom => {
                        h = caml_hash_mix_int(h, (br_on_null 'loop cv.ops.hash)(v));
                        num = num - 1;
                        br 'loop;
                    }
                    _ => {
                        let str: &?any;
                        #[if(not(wasi))]
                        {
                            _ =
                                'not_jsstring: do &?any {
                                    str = (br_on_cast_fail 'not_jsstring &js v).js;
                                    _ = br_if 'not_jsstring (0 as &i31, !jsstring_test(str));
                                    h = jsstring_hash(h, str);
                                    // count the string against the budget, like every other
                                    // hashed leaf (and like the JS runtime)
                                    num = num - 1;
                                    0 as &i31;
                                };
                        }
                        // closures and continuations and other js values are ignored
                        br 'loop;
                    }
                }
            }
        }
    }
    // clear the queue to avoid a memory leak
    caml_hash_queue.fill(0, 0 as &i31, wr);
    (caml_hash_mix_final(h) & 0x3FFFFFFF) as &i31;
}

#[export = "caml_string_hash"]
fn caml_string_hash(vh: &eq, vs: &eq) -> &eq {
    (caml_hash_mix_final(caml_hash_mix_string(vh as i32_s, vs as &bytes)) & 0x3FFFFFFF) as &i31;
}

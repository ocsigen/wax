        let n: i32;
        if len >u 0 {
            let numbytes = len >u IO_BUFFER_SIZE?IO_BUFFER_SIZE:len;
            caml_blit_bytes_to_dataview(s, pos, buf_view, 0, numbytes);
            try {
                n =
                    if fd_offset.seeked {
                        write(fd, buf, 0, numbytes, offset);
                    } else {
                        write'(fd, buf, 0, numbytes, null);
                    };
            } catch {
                javascript_exception => {
                    caml_unix_error(_, null);
                }
            }
            offset = offset + n as i64_u;
            fd_offset.offset = offset;
        }
        n as &i31;
    }

    #[export = "unix_read"]
    #[export = "caml_unix_read"]
    fn unix_read(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq) -> &eq {
        let fd = vfd as i32_u;
        let pos = vpos as i32_u;
        let len = vlen as i32_u;
        if len >u IO_BUFFER_SIZE {
            len = IO_BUFFER_SIZE;
        }
        let buf = get_io_buffer();
        let buf_view = io_buffer_view!;
        let fd_offset = get_fd_offset(fd);
        let offset = fd_offset.offset;
        let n: i32;
        try {
            n =
                if fd_offset.seeked {
                    read(fd, buf, 0, len, offset);
                } else {
                    read'(fd, buf, 0, len, null);
                };
        } catch {
            javascript_exception => {
                caml_unix_error(_, null);
            }
        }
        offset = offset + n as i64_u;
        fd_offset.offset = offset;
        caml_blit_dataview_to_bytes(buf_view, 0, vbuf as &bytes, pos, n);
        n as &i31;
    }

    #[export = "unix_write_bigarray"]
    #[export = "caml_unix_write_bigarray"]
    fn unix_write_bigarray(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq, vsingle: &eq) -> &eq {
        let fd = vfd as i32_u;
        let buf = caml_ba_get_data(vbuf);
        let pos = vpos as i32_u;
        let len = vlen as i32_u;
        let fd_offset = get_fd_offset(fd);
        let offset = fd_offset.offset;
        // [O_APPEND]: every write goes to the end of the file, regardless of the
        // current offset.
        if fd_offset.append {
            offset = file_size(fd);
        }
        let written: i32;
        'loop: loop {
            if len >u 0 {
                let n: i32;
                try {
                    n =
                        if fd_offset.seeked {
                            write(fd, buf, pos, len, offset);
                        } else {
                            write'(fd, buf, pos, len, null);
                        };
                } catch {
                    javascript_exception => {
                        caml_unix_error(_, null);
                    }
                }
                offset = offset + n as i64_u;
                fd_offset.offset = offset;
                written = written + n;
                pos = pos + n;
                len = len - n;
                br_if 'loop vsingle == 0 as &i31;
            }
        }
        written as &i31;
    }

    #[export = "unix_read_bigarray"]
    #[export = "caml_unix_read_bigarray"]
    fn unix_read_bigarray(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq) -> &eq {
        let fd = vfd as i32_u;
        let buf = caml_ba_get_data(vbuf);
        let pos = vpos as i32_u;
        let len = vlen as i32_u;
        let fd_offset = get_fd_offset(fd);
        let offset = fd_offset.offset;
        let n: i32;
        try {
            n =
                if fd_offset.seeked {
                    read(fd, buf, pos, len, offset);
                } else {
                    read'(fd, buf, pos, len, null);
                };
        } catch {
            javascript_exception => {
                caml_unix_error(_, null);
            }
        }
        offset = offset + n as i64_u;
        fd_offset.offset = offset;
        n as &i31;
    }
}

#[if(wasi)]
fn lseek(fd: &eq, offset: i64, cmd: &eq) -> i64 {
    let buffer = get_buffer();
    let res = fd_seek(fd as i32_u, offset, cmd as i32_u, buffer);
    caml_unix_error_if(res, "lseek", no_arg);
    m.load64(buffer);
}
#[else]
{
    fn lseek_exn(errno: i32) -> &eq {
        [block|0 as &i31, get_unix_error_exn(), errno as &i31, "lseek", no_arg];
    }

    fn lseek(vfd: &eq, offset: i64, cmd: &eq) -> i64 {
        let fd = vfd as i32_u;
        let fd_offset =
            'non_null: do {
                br_on_non_null 'non_null get_fd_offset_unchecked(fd);
                throw ocaml_exception lseek_exn(3);
            }; // EBADF
        if cmd == 1 as &i31 {
            offset = fd_offset.offset + offset;
        } else {
            if cmd == 2 as &i31 {
                offset = file_size(fd) + offset;
            }
        }
        if offset <s 0 {
            throw ocaml_exception lseek_exn(12);
        } // EINVAL
        fd_offset.offset = offset;
        fd_offset.seeked = 1;
        offset;
    }
}

#[export = "unix_lseek"]
#[export = "caml_unix_lseek"]
fn unix_lseek(fd: &eq, ofs: &eq, cmd: &eq) -> &eq {
    lseek(fd, ofs as i64_s, cmd) as &i31;
}

#[export = "unix_lseek_64"]
#[export = "caml_unix_lseek_64"]
fn unix_lseek_64(fd: &eq, ofs: &eq, cmd: &eq) -> &eq {
    become caml_copy_int64(lseek(fd, Int64_val(ofs), cmd));
}

#[if(wasi)]
#[export = "unix_fsync"]
#[export = "caml_unix_fsync"]
fn unix_fsync(fd: &eq) -> &eq {
    let res = fd_sync(fd as i32_u);
    caml_unix_error_if(res, "fsync", no_arg);
    0 as &i31;
}
#[else]
#[export = "unix_fsync"]
#[export = "caml_unix_fsync"]
fn unix_fsync(fd: &eq) -> &eq {
    try {
        fsync(fd);
    } catch {
        javascript_exception => {
            caml_unix_error(_, null);
        }
    }
    0 as &i31;
}

const out_channel_of_descr = "out_channel_of_descr";
const in_channel_of_descr = "in_channel_of_descr";

fn channel_of_descr_name(out: i32) -> &eq {
    out?out_channel_of_descr:in_channel_of_descr;
}

#[if(wasi)]
fn caml_unix_check_stream_semantics(fd: &eq, out: i32) {
    let s: &block;
    let file_type: i32;
    let buffer = get_buffer();
    let res = fd_filestat_get(fd as i32_u, buffer);
    caml_unix_error_if(res, channel_of_descr_name(out), no_arg);
    let kind = m.load8(buffer, 1, 16) as i32_u;
    dispatch kind [ 'ok 'bad 'ok 'bad 'ok 'bad 'ok else 'bad ] {
        'bad: {
            caml_unix_error(28 /* EINVAL */ , channel_of_descr_name(out), no_arg);
        }
        'ok: {}
    }
}
#[else]
fn caml_unix_check_stream_semantics(fd: &eq, out: i32) {
    let s =
        try {
            fstat(fd, 0);
        } catch {
            javascript_exception => {
                caml_unix_error(_, channel_of_descr_name(out));
                0 as &i31;
            }
        } as &block;
    let kind = s[3] as i32_u;
    dispatch kind [ 'ok 'bad 'ok 'bad 'bad else 'ok ] {
        'bad: {
            throw ocaml_exception
                [block|
                    0 as &i31,
                    get_unix_error_exn(),
                    12 // EINVAL
                        as &i31,
                    channel_of_descr_name(out),
                    no_arg,
                ];
        }
        'ok: {}
    }
}

#[export = "unix_inchannel_of_filedescr"]
#[export = "win_inchannel_of_filedescr"]
#[export = "caml_unix_inchannel_of_filedescr"]
fn unix_inchannel_of_filedescr(fd: &eq) -> &eq {
    caml_unix_check_stream_semantics(fd, 0);
    become caml_ml_open_descriptor_in(fd);
}

#[export = "unix_outchannel_of_filedescr"]
#[export = "win_outchannel_of_filedescr"]
#[export = "caml_unix_outchannel_of_filedescr"]
fn unix_outchannel_of_filedescr(fd: &eq) -> &eq {
    caml_unix_check_stream_semantics(fd, 1);
    become caml_ml_open_descriptor_out(fd);
}

#[if(wasi)]
#[export = "unix_close"]
#[export = "caml_unix_close"]
fn unix_close(fd: &eq) -> &eq {
    let res = fd_close(fd as i32_u);
    caml_unix_error_if(res, "close", no_arg);
    0 as &i31;
}
#[else]
#[export = "unix_close"]
#[export = "caml_unix_close"]
fn unix_close(fd: &eq) -> &eq {
    release_fd_offset(fd as i32_u);
    try {
        close(fd);
    } catch {
        javascript_exception => {
            caml_unix_error(_, null);
        }
    }
    0 as &i31;
}


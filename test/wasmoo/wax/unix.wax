#[if(wasi)]
{
    const truncate_str = "truncate";

    fn truncate_impl(path: &eq, len: i64) -> &eq {
        let res: i32;
        'error: do {
            let (p_fd, p_addr, p_len) = unix_resolve_path(truncate_str, path);
            let buffer = get_buffer();
            res =
                path_open(
                    p_fd,
                    1, // symlink_follow
                    p_addr,
                    p_len,
                    0,
                    0x400040, // allow fd_filestat_set_size and fd_write
                    0,
                    0,
                    buffer,
                );
            free(p_addr);
            br_if 'error res;
            let fd = m.load32(buffer);
            res = fd_filestat_set_size(fd, len);
            if res {
                _ = fd_close(fd);
                br 'error;
            }
            res = fd_close(fd);
            br_if 'error res;
            return 0 as &i31;
        }
        caml_unix_error(res, truncate_str, path);
        return 0 as &i31;
    }

    #[export = "unix_truncate"]
    #[export = "caml_unix_truncate"]
    fn unix_truncate(path: &eq, len: &eq) -> &eq {
        become truncate_impl(path, len as i64_s);
    }

    #[export = "unix_truncate_64"]
    #[export = "caml_unix_truncate_64"]
    fn unix_truncate_64(path: &eq, len: &eq) -> &eq {
        become truncate_impl(path, Int64_val(len));
    }
}

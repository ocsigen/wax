#[if(wasi)]
#[export = "caml_unix_mktime"]
#[export = "unix_mktime"]
fn caml_unix_mktime(v: &eq) -> &eq {
    let t = v as &block;
    let tm = get_buffer();
    m.store32(tm, t[1] as i32_s);
    m.store32(tm, t[2] as i32_s, 4, 4);
    m.store32(tm, t[3] as i32_s, 4, 8);
    m.store32(tm, t[4] as i32_s, 4, 12);
    m.store32(tm, t[5] as i32_s, 4, 16);
    m.store32(tm, t[6] as i32_s, 4, 20);
    m.store32(tm, t[7] as i32_s, 4, 24);
    m.store32(tm, t[8] as i32_s, 4, 28);
    m.store32(tm, -1, 4, 32);
    let time = mktime(tm);
    if time == -1 {
        caml_unix_error(68 /* ERANGE */ , "mktime", no_arg);
    }
    [block|0 as &i31, { f: time as f64_s }, alloc_tm(tm)];
}
#[else]
#[export = "caml_unix_mktime"]
#[export = "unix_mktime"]
fn caml_unix_mktime(v: &eq) -> &eq {
    let tm = v as &block;
    let t =
        mktime(
            tm[6] as i32_s + 1900,
            tm[5] as i32_s,
            tm[4] as i32_s,
            tm[3] as i32_s,
            tm[2] as i32_s,
            tm[1] as i32_s,
        ) / 1000;
    [block|0 as &i31, { f: t }, localtime(t)];
}

#[if(wasi)]
{
    const utimes_str = "utimes";

    #[export = "unix_utimes"]
    #[export = "caml_unix_utimes"]
    fn unix_utimes(path: &eq, atime: &eq, mtime: &eq) -> &eq {
        let (p_fd, p_addr, p_len) = unix_resolve_path(utimes_str, path);
        let at = (atime as &float).f;
        let mt = (mtime as &float).f;
        let set_to_now = (at == 0) & (mt == 0);
        let atim: i64;
        let mtim: i64;
        if !set_to_now {
            atim = (at * 1e9) as i64_s;
            mtim = (mt * 1e9) as i64_s;
        }
        let res =
            path_filestat_set_times(
                p_fd,
                1, // symlink_follow, like every other path op and native
                p_addr,
                p_len,
                atim,
                mtim,
                5 << set_to_now,
            );
        free(p_addr);
        caml_unix_error_if(res, utimes_str, path);
        0 as &i31;
    }
}
#[else]
#[export = "unix_utimes"]
#[export = "caml_unix_utimes"]
fn unix_utimes(path: &eq, atime: &eq, mtime: &eq) -> &eq {
    let at = (atime as &float).f;
    let mt = (mtime as &float).f;
    if (at == 0) & (mt == 0) {
        at = gettimeofday();
        mt = at;
    }
    try {
        utimes(unwrap(caml_jsstring_of_string(path)), at, mt);
    } catch {
        javascript_exception => {
            caml_unix_error(_, null);
        }
    }
    0 as &i31;
}

#[if(wasi)]
{
    const file_kinds: &constr_table = [3, 3, 2, 1, 0, 6, 6, 4];

    fn alloc_stat(large: i32, p: i32) -> &eq {
        [block|
            0 as &i31,
            m.load64(p) as &i31,
            m.load64(p, 8, 8) as &i31,
            file_kinds[m.load8(p, 1, 16) as i32_u] as i32_s as &i31,
            384 /*0600*/ as &i31,
            m.load64(p, 8, 24) as &i31,
            1 as &i31,
            1 as &i31,
            0 as &i31,
            if large {
                caml_copy_int64(m.load64(p, 8, 32));
            } else {
                m.load64(p, 8, 32) as &i31;
            },
            { f: 1e-9 * m.load64(p, 8, 40) as f64_s },
            { f: 1e-9 * m.load64(p, 8, 48) as f64_s },
            { f: 1e-9 * m.load64(p, 8, 56) as f64_s },
        ];
    }
}

#[export = "caml_alloc_stat"]
fn caml_alloc_stat(
    large: i32,
    dev: i32,
    ino: i32,
    kind: i32,
    perm: i32,
    nlink: i32,
    uid: i32,
    gid: i32,
    rdev: i32,
    size: i64,
    atime: f64,
    mtime: f64,
    ctime: f64,
) -> &eq {
    [block|
        0 as &i31,
        dev as &i31,
        ino as &i31,
        kind as &i31,
        perm as &i31,
        nlink as &i31,
        uid as &i31,
        gid as &i31,
        rdev as &i31,
        if large {
            caml_copy_int64(size);
        } else {
            size as &i31;
        },
        { f: atime },
        { f: mtime },
        { f: ctime },
    ];
}

#[if(wasi)]
{
    fn stat(path: &eq, large: i32, follow: i32, name: &eq) -> &eq {
        let (p_fd, p_addr, p_len) = unix_resolve_path(name, path);
        let buffer = get_buffer();
        let res =
            path_filestat_get(
                p_fd,
                follow, // symlink_follow
                p_addr,
                p_len,
                buffer,
            );
        free(p_addr);
        caml_unix_error_if(res, name, path);
        become alloc_stat(large, buffer);
    }

    const stat_str = "stat";

    #[export = "unix_stat"]
    #[export = "caml_unix_stat"]
    fn unix_stat(path: &eq) -> &eq {
        become stat(path, 0, 1, stat_str);
    }

    #[export = "unix_stat_64"]
    #[export = "caml_unix_stat_64"]
    fn unix_stat_64(path: &eq) -> &eq {
        become stat(path, 1, 1, stat_str);

        let buffer = get_buffer();
        let res = fd_filestat_get(fd as i32_u, buffer);
        caml_unix_error_if(res, "fstat", no_arg);
        become alloc_stat(large, buffer);
    }

    #[export = "unix_fstat"]
    #[export = "caml_unix_fstat"]

type bytes = [mut i8];
type block = [mut &eq];
type float = { f: f64 };
type float_array = [mut f64];
type js = { js: &?any };

type fd_offset = { offset: mut i64, seeked: mut i32, append: mut i32 };

let unix_error_exn: &eq = 0 as &i31;

const unix_error_str = "Unix.Unix_error";

const unix_error_not_initialized =
    "Exception Unix.Unix_error not initialized, please link unix.cma";

fn get_unix_error_exn() -> &eq {
    if unix_error_exn is &i31 {
        let exn = caml_named_value(unix_error_str);
        if !exn {
            caml_invalid_argument(unix_error_not_initialized);
        }
        unix_error_exn = exn!;
    }
    unix_error_exn;
}

const no_arg = "";

#[if(wasi)]
{
    #[export = "unix_resolve_path"]
    fn unix_resolve_path(cmd: &eq, path: &eq) -> (i32, i32, i32) {
        let (res_0, res_1, res_2) = wasi_resolve_path(path);
        if res_0 <s 0 {
            caml_unix_error(
                44, // ENOENT
                cmd,
                path,
            );
        }
        res_0;
        res_1;
        res_2;
    }

    // Resolve $path, invoke a path-based syscall $f on it, free the
    // resolved buffer and raise a Unix_error labelled $cmd on failure.
    fn unix_path_op(cmd: &eq, path: &eq, f: &path_op) -> &eq {
        let (p_fd, p_addr, p_len) = unix_resolve_path(cmd, path);
        let res = f(p_fd, p_addr, p_len);
        free(p_addr);
        caml_unix_error_if(res, cmd, path);
        0 as &i31;
    }

    type constr_table = [i8];
    const error_codes: &constr_table =
        [
            -1,
            0,
            1,
            50,
            51,
            49,
            2,
            39,
            3,
            -1,
            4,
            -1,
            5,
            55,
            63,
            56,
            6,
            41,
            7,
            -1,
            8,
            9,
            10,
            65,
            -1,
            -1,
            38,
            11,
            12,
            13,
            58,
            14,
            66,
            15,
            16,
            42,
            -1,
            17,
            52,
            54,
            53,
            18,
            57,
            19,
            20,
            21,
            22,
            -1,
            23,
            -1,
            44,
            24,
            25,
            59,
            26,
            27,
            -1,
            40,
            47,
            28,
            29,
            67,
            -1,
            30,
            31,
            -1,
            45,
            43,
            32,
            33,
            34,
            35,
            -1,
            62,
            -1,
            36,
            -1,
        ];

    // Names of the Unix.error variants, in declaration order. Used as the
    // message for variants that have no WASI errno equivalent (EWOULDBLOCK,
    // ESHUTDOWN, ...), matching the JS runtime's "unix_error[errno]" fallback
    // instead of reporting "Unknown error -1".
    const error_names: &block =
        [
            "E2BIG",
            "EACCES",
            "EAGAIN",
            "EBADF",
            "EBUSY",
            "ECHILD",
            "EDEADLK",
            "EDOM",
            "EEXIST",
            "EFAULT",
            "EFBIG",
            "EINTR",
            "EINVAL",
            "EIO",
            "EISDIR",
            "EMFILE",
            "EMLINK",
            "ENAMETOOLONG",
            "ENFILE",
            "ENODEV",
            "ENOENT",
            "ENOEXEC",
            "ENOLCK",
            "ENOMEM",
            "ENOSPC",
            "ENOSYS",
            "ENOTDIR",
            "ENOTEMPTY",
            "ENOTTY",
            "ENXIO",
            "EPERM",
            "EPIPE",
            "ERANGE",
            "EROFS",
            "ESPIPE",
            "ESRCH",
            "EXDEV",
            "EWOULDBLOCK",
            "EINPROGRESS",
            "EALREADY",
            "ENOTSOCK",
            "EDESTADDRREQ",
            "EMSGSIZE",
            "EPROTOTYPE",
            "ENOPROTOOPT",
            "EPROTONOSUPPORT",
            "ESOCKTNOSUPPORT",
            "EOPNOTSUPP",
            "EPFNOSUPPORT",
            "EAFNOSUPPORT",
            "EADDRINUSE",
            "EADDRNOTAVAIL",
            "ENETDOWN",
            "ENETUNREACH",
            "ENETRESET",
            "ECONNABORTED",
            "ECONNRESET",
            "ENOBUFS",
            "EISCONN",
            "ENOTCONN",
            "ESHUTDOWN",
            "ETOOMANYREFS",
            "ETIMEDOUT",
            "ECONNREFUSED",
            "EHOSTDOWN",
            "EHOSTUNREACH",
            "ELOOP",
            "EOVERFLOW",
        ];

    fn caml_unix_error_of_code(errcode: i32) -> &eq {
        if errcode <=u 76 {
            let err = error_codes[errcode] as i32_s;
            if err != -1 {
                return err as &i31;
            }
        }
        [block|0 as &i31, errcode as &i31];
    }

    fn caml_unix_error(errcode: i32, cmd_name: &eq, cmd_arg: &eq) {
        throw ocaml_exception
            [block|
                0 as &i31,
                get_unix_error_exn(),
                caml_unix_error_of_code(errcode),
                cmd_name,
                cmd_arg,
            ];
    }

    fn caml_unix_error_if(errcode: i32, cmd_name: &eq, cmd_arg: &eq) {
        if errcode {
            caml_unix_error(errcode, cmd_name, cmd_arg);
        }
    }

    #[export = "unix_error_message"]
    #[export = "caml_unix_error_message"]
    fn unix_error_message(err: &eq) -> &eq {
        let i: i32;
        let errcode: i32;
        let n: i32;
        if err is &i31 {
            n = err as i32_u;
            'loop: loop {
                if errcode <u error_codes.length() {
                    if n != error_codes[errcode] as i32_s {
                        errcode = errcode + 1;
                        br 'loop;
                    }
                } else {
                    errcode = -1;
                }
            }
        } else {
            errcode = (err as &block)[1] as i32_u;
        }
        if errcode >=u error_messages.length() {
            // A known variant with no WASI errno equivalent (EWOULDBLOCK, ...)
            // is reported by its name, like the JS runtime, rather than as
            // "Unknown error -1". EUNKNOWNERR(n) (a block) still falls through.
            if err is &i31 & (n <u error_names.length()) {
                return error_names[n];
            }
            become caml_string_concat("Unknown error ", caml_format_int("%d", errcode as &i31));
        }
        error_messages[errcode];
    }
}
#[else]
{
    const unix_error: &eq = { js: unix_error_js };

    fn ensure_string(s: &eq) -> &eq {
        _ =
            'not_jsstring: do {
                let str = (br_on_cast_fail 'not_jsstring &js s).js;
                _ = br_if 'not_jsstring (0 as &i31, !jsstring_test(str));
                return caml_string_of_jsstring(s);
            };
        return no_arg;
    }

    const code_str = "code";
    const errno_str = "errno";
    const indexOf = "indexOf";
    const syscall = "syscall";
    const path = "path";

    fn caml_unix_error(exception: &?extern, cmd: &?eq) {
        let exn = wrap(exception as &?any);
        let code = caml_js_get(exn, code_str);
        let variant = caml_js_meth_call(unix_error, indexOf, [block|0 as &i31, code]);
        if variant == -1 as &i31 {
            let errno = caml_js_get(exn, errno_str);
            errno =
                if errno is &i31 {
                    0 - errno as i32_s;
                } else {
                    9999;
                } as &i31;
            variant = [block|0 as &i31, errno];
        }
        throw ocaml_exception
            [block|
                0 as &i31,
                get_unix_error_exn(),
                variant,
                if !cmd {
                    ensure_string(caml_js_get(exn, syscall));
                } else {
                    cmd!;
                },
                ensure_string(caml_js_get(exn, path)),
            ];
    }

    #[export = "unix_error_message"]
    #[export = "caml_unix_error_message"]
    fn unix_error_message(err: &eq) -> &eq {
        let errno =
            if err is &i31 {
                err as i32_u;
            } else {
                0 - (err as &block)[1] as i32_u;
            };
        become caml_string_of_jsstring(wrap(caml_strerror(errno)));
    }
}

#[if(wasi)]
#[export = "unix_gettimeofday"]
#[export = "caml_unix_gettimeofday"]
fn unix_gettimeofday(&eq) -> &eq {
    let buffer = get_buffer();
    let res = clock_time_get(0, 1000, buffer);
    caml_unix_error_if(res, "gettimeofday", no_arg);
    { f: m.load64(buffer) as f64_u * 1e-9 };
}
#[else]
#[export = "unix_gettimeofday"]
#[export = "caml_unix_gettimeofday"]
fn unix_gettimeofday(&eq) -> &eq {
    { f: gettimeofday() };
}

#[if(wasi)]
#[export = "unix_times"]
#[export = "caml_unix_times"]
fn unix_times(&eq) -> &eq {
    let buffer = get_buffer();
    let res = clock_time_get(2, 1, buffer);
    // wasmtime does not support the CPU-time clock, so use the
    // monotonic clock instead as a fallback
    if res == 8 {
        res = clock_time_get(1, 1, buffer);
    }
    caml_unix_error_if(res, "time", no_arg);
    [float_array|m.load64(buffer) as f64_u * 1e-9, 0, 0, 0];
}
#[else]
{
    #[export = "caml_alloc_times"]
    fn caml_alloc_times(u: f64, s: f64) -> &eq {
        [float_array|u, s, 0, 0];
    }

    #[export = "unix_times"]
    #[export = "caml_unix_times"]
    fn unix_times(&eq) -> &eq {
        become times();
    }
}

#[if(wasi)]
fn alloc_tm(tm: i32) -> &eq {
    [block|
        0 as &i31,
        m.load32(tm) as &i31,
        m.load32(tm, 4, 4) as &i31,
        m.load32(tm, 4, 8) as &i31,
        m.load32(tm, 4, 12) as &i31,
        m.load32(tm, 4, 16) as &i31,
        m.load32(tm, 4, 20) as &i31,
        m.load32(tm, 4, 24) as &i31,
        m.load32(tm, 4, 28) as &i31,
        (m.load32(tm, 4, 32)?1:0) as &i31,
    ];
}
#[else]
#[export = "caml_alloc_tm"]
fn caml_alloc_tm(
    sec: i32,
    min: i32,
    hour: i32,
    mday: i32,
    mon: i32,
    year: i32,
    wday: i32,
    yday: i32,
    isdst: i32,
) -> &eq {
    [block|
        0 as &i31,
        sec as &i31,
        min as &i31,
        hour as &i31,
        mday as &i31,
        mon as &i31,
        year as &i31,
        wday as &i31,
        yday as &i31,
        isdst as &i31,
    ];
}

#[if(wasi)]
#[export = "caml_unix_gmtime"]
#[export = "unix_gmtime"]
fn caml_unix_gmtime(t: &eq) -> &eq {
    let buffer = get_buffer();
    m.store64(buffer, (t as &float).f as i64_s);
    let tm = gmtime(buffer);
    if !tm {
        caml_unix_error(28 /* EINVAL */ , "gmtime", no_arg);
    }
    become alloc_tm(tm);
}
#[else]
#[export = "caml_unix_gmtime"]
#[export = "unix_gmtime"]
fn caml_unix_gmtime(t: &eq) -> &eq {
    gmtime((t as &float).f);
}

#[if(wasi)]
#[export = "caml_unix_localtime"]
#[export = "unix_localtime"]
fn caml_unix_localtime(t: &eq) -> &eq {
    let buffer = get_buffer();
    m.store64(buffer, (t as &float).f as i64_s);
    let tm = localtime(buffer);
    if !tm {
        caml_unix_error(28 /* EINVAL */ , "localtime", no_arg);
    }
    become alloc_tm(tm);
}
#[else]
#[export = "caml_unix_localtime"]
#[export = "unix_localtime"]
fn caml_unix_localtime(t: &eq) -> &eq {

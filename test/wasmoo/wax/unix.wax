    0 as &i31;
}
#[else]
{}

#[if(wasi)]
{
    // WASI has no notion of user/group ids; return 1 like the JS runtime's
    // fallback when [process.getuid] and friends are unavailable.
    #[export = "unix_getuid"]
    #[export = "caml_unix_getuid"]
    fn unix_getuid(&eq) -> &eq {
        1 as &i31;
    }
    #[export = "unix_geteuid"]
    #[export = "caml_unix_geteuid"]
    fn unix_geteuid(&eq) -> &eq {
        1 as &i31;
    }
    #[export = "unix_getgid"]
    #[export = "caml_unix_getgid"]
    fn unix_getgid(&eq) -> &eq {
        1 as &i31;
    }
    #[export = "unix_getegid"]
    #[export = "caml_unix_getegid"]
    fn unix_getegid(&eq) -> &eq {
        1 as &i31;
    }
}
#[else]
{
    // On Node, return the real ids (the bindings fall back to 1 in a browser
    // or wherever [process.getuid] is missing), matching runtime/js/unix.js.
    #[export = "unix_getuid"]
    #[export = "caml_unix_getuid"]
    fn unix_getuid(&eq) -> &eq {
        getuid() as &i31;
    }
    #[export = "unix_geteuid"]
    #[export = "caml_unix_geteuid"]
    fn unix_geteuid(&eq) -> &eq {
        geteuid() as &i31;
    }
    #[export = "unix_getgid"]
    #[export = "caml_unix_getgid"]
    fn unix_getgid(&eq) -> &eq {
        getgid() as &i31;
    }
    #[export = "unix_getegid"]
    #[export = "caml_unix_getegid"]
    fn unix_getegid(&eq) -> &eq {
        getegid() as &i31;
    }
}


type flags = [i16];

#[if(wasi)]
{
    //    0x1 O_RDONLY
    //    0x2 O_WRONLY
    //    0x3 O_RDWR
    //  0x400 O_NONBLOCK
    //  0x100 O_APPEND
    //   0x10 O_CREAT
    //   0x80 O_TRUNC
    //   0x40 O_EXCL
    //      0 O_NOCTTY
    //  0x200 O_DSYNC
    // 0x1000 O_SYNC
    //  0x800 O_RSYNC
    const unix_open_flags: &flags =
        [1, 2, 3, 0x400, 0x100, 0x10, 0x80, 0x40, 0, 0x200, 0x1000, 0x800, 0, 0, 0];

    const open_str = "open";

    #[export = "unix_open"]
    #[export = "caml_unix_open"]
    fn unix_open(vpath: &eq, vflags: &eq, perm: &eq) -> &eq {
        let offset: i64;
        let (path_fd, path_addr, path_len) = unix_resolve_path(open_str, vpath);
        let buffer = get_buffer();
        let flags = convert_flag_list(unix_open_flags, vflags);
        let res =
            path_open(
                path_fd,
                1, // symlink_follow
                path_addr,
                path_len,
                flags >>u 4 & 0xF,
                flags & 3 == 3?0x860007e:flags & 2?0x860007c:0x820003e,
                0,
                flags >>u 8,
                buffer,
            );
        free(path_addr);
        caml_unix_error_if(res, open_str, vpath);
        m.load32(buffer) as &i31;
    }
}
#[else]
{
    //    1 O_RDONLY
    //    2 O_WRONLY
    //    4 O_RDWR
    //    8 O_APPEND
    //   16 O_CREAT
    //   32 O_TRUNC
    //   64 O_EXCL
    //  128 O_NONBLOCK
    //  256 O_NOCTTY
    //  512 O_DSYNC
    // 1024 O_SYNC
    const unix_open_flags: &flags = [1, 2, 4, 128, 8, 16, 32, 64, 256, 512, 1024, 0, 0, 0, 0];

    #[export = "unix_open"]
    #[export = "caml_unix_open"]
    fn unix_open(path: &eq, vflags: &eq, perm: &eq) -> &eq {
        let flags = convert_flag_list(unix_open_flags, vflags);
        let fd: i32;
        try {
            fd = open_fn(unwrap(caml_jsstring_of_string(path)), flags, perm as i32_u);
        } catch {
            javascript_exception => {
                caml_unix_error(_, null);
            }
        }
        let offset: i64;
        // Like native [O_APPEND], the offset starts at 0; writes reposition to
        // EOF (see [unix_write]).
        initialize_fd_offset(
            fd,
            offset,
            flags & 8 // O_APPEND
        );
        fd as &i31;
    }
}

let io_buffer: &?extern = null;
let io_buffer_view: &?extern = null;

fn get_io_buffer() -> &extern {
    if !io_buffer {
        let buf = ta_new(IO_BUFFER_SIZE);
        io_buffer = buf;
        io_buffer_view = dv_make(buf);
    }
    io_buffer!;
}

fn get_fd_offset(fd: i32) -> &fd_offset {
    'null: do {
        return br_on_null 'null get_fd_offset_unchecked(fd);
    }
    { offset: 0, seeked: 0, append: 0 };
}

#[if(wasi)]
{
    #[export = "unix_write"]
    #[export = "caml_unix_write"]
    fn unix_write(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq) -> &eq {
        let fd = vfd as i32_u;
        let s = vbuf as &bytes;
        let pos = vpos as i32_u;
        let len = vlen as i32_u;
        let buffer = get_buffer();
        let nwritten = buffer;
        let iovs = buffer + 4;
        buffer = buffer + 12;
        m.store32(iovs, buffer);
        let iovs_len = 1;
        let written: i32;
        while len >u 0 {
            let numbytes = len >u IO_BUFFER_SIZE?IO_BUFFER_SIZE:len;
            blit_substring_to_memory(buffer, s, pos, numbytes);
            m.store32(iovs, numbytes, 4, 4);
            let res = fd_write(fd, iovs, iovs_len, nwritten);
            caml_unix_error_if(res, "write", no_arg);
            let n = m.load32(nwritten);
            written = written + n;
            pos = pos + n;
            len = len - n;
        }
        written as &i31;
    }

    #[export = "unix_single_write"]
    #[export = "caml_unix_single_write"]
    fn unix_single_write(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq) -> &eq {
        let written: i32;
        let n: i32;
        let fd = vfd as i32_u;
        let s = vbuf as &bytes;
        let pos = vpos as i32_u;
        let len = vlen as i32_u;
        if !len {
            return 0 as &i31;
        }
        let buffer = get_buffer();
        let nwritten = buffer;
        let iovs = buffer + 4;
        buffer = buffer + 12;
        m.store32(iovs, buffer);
        let iovs_len = 1;
        let numbytes = len >u IO_BUFFER_SIZE?IO_BUFFER_SIZE:len;
        blit_substring_to_memory(buffer, s, pos, numbytes);
        m.store32(iovs, numbytes, 4, 4);
        let res = fd_write(fd, iovs, iovs_len, nwritten);
        caml_unix_error_if(res, "write", no_arg);
        m.load32(nwritten) as &i31;
    }

    #[export = "unix_read"]
    #[export = "caml_unix_read"]
    fn unix_read(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq) -> &eq {
        let fd = vfd as i32_u;
        let pos = vpos as i32_u;
        let len = vlen as i32_u;
        if len >u IO_BUFFER_SIZE {
            len = IO_BUFFER_SIZE;
        }
        let buffer = get_buffer();
        let nread = buffer;
        let iovs = buffer + 4;
        buffer = buffer + 12;
        m.store32(iovs, buffer);
        m.store32(iovs, len, 4, 4);
        let iovs_len = 1;
        let res = fd_read(fd, iovs, iovs_len, nread);
        caml_unix_error_if(res, "read", no_arg);
        let n = m.load32(nread);
        blit_memory_to_substring(buffer, vbuf as &bytes, pos, n);
        n as &i31;
    }

    type dat = { array: &array, offset: i32, len: i32 };

    #[export = "unix_write_bigarray"]
    #[export = "caml_unix_write_bigarray"]
    fn unix_write_bigarray(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq, vsingle: &eq) -> &eq {
        let fd = vfd as i32_u;
        let dat = caml_ba_get_data(vbuf) as &dat;
        let buf = dat.array as &bytes;
        let pos = vpos as i32_u + dat.offset;
        let len = vlen as i32_u;
        let buffer = get_buffer();
        let nwritten = buffer;
        let iovs = buffer + 4;
        buffer = buffer + 12;
        m.store32(iovs, buffer);
        let iovs_len = 1;
        let written: i32;
        'loop: loop {
            if len >u 0 {
                let numbytes = len >u IO_BUFFER_SIZE?IO_BUFFER_SIZE:len;
                blit_substring_to_memory(buffer, buf, pos, numbytes);
                m.store32(iovs, numbytes, 4, 4);
                let res = fd_write(fd, iovs, iovs_len, nwritten);
                caml_unix_error_if(res, "write", no_arg);
                let n = m.load32(nwritten);
                written = written + n;
                pos = pos + n;
                len = len - n;
                br_if 'loop vsingle == 0 as &i31;
            }
        }
        written as &i31;
    }

    #[export = "unix_read_bigarray"]
    #[export = "caml_unix_read_bigarray"]
    fn unix_read_bigarray(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq) -> &eq {
        let fd = vfd as i32_u;
        let dat = caml_ba_get_data(vbuf) as &dat;
        let buf = dat.array as &bytes;
        let pos = vpos as i32_u + dat.offset;
        let len = vlen as i32_u;
        if len >u IO_BUFFER_SIZE {
            len = IO_BUFFER_SIZE;
        }
        let buffer = get_buffer();
        let nread = buffer;
        let iovs = buffer + 4;
        buffer = buffer + 12;
        m.store32(iovs, buffer);
        m.store32(iovs, len, 4, 4);
        let iovs_len = 1;
        let res = fd_read(fd, iovs, iovs_len, nread);
        caml_unix_error_if(res, "read", no_arg);
        let n = m.load32(nread);
        blit_memory_to_substring(buffer, buf, pos, n);
        n as &i31;
    }
}
#[else]
{
    #[export = "unix_write"]
    #[export = "caml_unix_write"]
    fn unix_write(vfd: &eq, vbuf: &eq, vpos: &eq, vlen: &eq) -> &eq {
        let fd = vfd as i32_u;
        let s = vbuf as &bytes;
        let pos = vpos as i32_u;
        let len = vlen as i32_u;
        let buf = get_io_buffer();
        let buf_view = io_buffer_view!;
        let fd_offset = get_fd_offset(fd);
        let offset = fd_offset.offset;
        // [O_APPEND]: every write goes to the end of the file, regardless of the
        // current offset.
        if fd_offset.append {
            offset = file_size(fd);
        }
        let written: i32;
        while len >u 0 {
            let numbytes = len >u IO_BUFFER_SIZE?IO_BUFFER_SIZE:len;
            caml_blit_bytes_to_dataview(s, pos, buf_view, 0, numbytes);
            let n: i32;
            try {
                n =
                    if fd_offset.seeked {
                        write(fd, buf, 0, numbytes, offset);
                    } else {
                        write'(fd, buf, 0, numbytes, null);
                    };
            } catch {
                javascript_exception => {
                    caml_unix_error(_, null);
                }
            }
            offset = offset + n as i64_u;
            fd_offset.offset = offset;
            written = written + n;
            pos = pos + n;
            len = len - n;
        }
        written as &i31;
    }


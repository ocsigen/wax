#[if(wasi)]
{
    type directory = {
        fd: i32,
        buffer: mut i32,
        size: mut i32,
        pos: mut i32,
        available: mut i32,
        cookie: mut i64,
        // "." / ".." still to emit (2: both, 1: just "..", 0: none); the
        // host directory stream may omit them, so they are synthesized
        dots: mut i32
    };

    const opendir_str = "opendir";

    #[export = "unix_opendir"]
    #[export = "caml_unix_opendir"]
    fn unix_opendir(name: &eq) -> &eq {
        let (p_fd, p_addr, p_len) = unix_resolve_path(opendir_str, name);
        let buffer = get_buffer();
        let res =
            path_open(
                p_fd,
                1, // symlink_follow
                p_addr,
                p_len,
                2, // O_DIRECTORY
                0x4000, // allow fd_readdir
                0,
                0,
                buffer,
            );
        free(p_addr);
        caml_unix_error_if(res, opendir_str, name);
        {
            fd: m.load32(buffer),
            buffer: checked_malloc(512),
            size: 512,
            pos: 0,
            available: 0,
            cookie: 0,
            dots: 2,
        };
    }

    fn is_dot_entry(addr: i32, len: i32) -> i32 {
        // "." has length 1, ".." length 2, both made of '.' (0x2e)
        if len == 1 {
            return m.load8(addr) as i32_u == 0x2e;
        }
        if len == 2 {
            return (m.load8(addr) as i32_u == 0x2e) & (m.load8(addr, 1, 1) as i32_u == 0x2e);
        }
        0;
    }

    fn readdir_helper(vdir: &eq) -> &eq {
        let dir = vdir as &directory;
        // Emit the synthesized "." / ".." before the host entries, like native
        // readdir and the js backend. Host-provided "." / ".." are skipped below
        // so they are never duplicated on hosts that do report them.
        'no_dots: do {
            br_if 'no_dots !dir.dots;
            if dir.dots == 2 {
                dir.dots = 1;
                return ".";
            } else {
                dir.dots = 0;
                return "..";
            }
        }
        'loop: loop {
            let entry_size: i32;
            'refill: do {
                let left = dir.available - dir.pos;
                br_if 'refill left <u 24;
                let entry = dir.buffer + dir.pos;
                let namelen = m.load32(entry, 4, 16);
                entry_size = namelen + 24;
                br_if 'refill left <u entry_size;
                dir.pos = dir.pos + entry_size;
                dir.cookie = m.load64(entry);
                // skip a host-provided "." / ".." (already synthesized above)
                br_if 'loop is_dot_entry(entry + 24, namelen);
                become blit_memory_to_string(entry + 24, namelen);
            }
            // refill
            if dir.size <u entry_size {
                // the entry does not fit
                let buf = checked_malloc(entry_size);
                free(dir.buffer);
                dir.buffer = buf;
                dir.size = entry_size;
                // discard the stale buffer contents: the grown buffer must be
                // refilled from $cookie, and a stale $available would otherwise
                // falsely trigger the short-read termination below
                dir.available = 0;
            }
            'done: do {
                br_if 'done (0 != dir.available) & (dir.available <u dir.size);
                let buffer = get_buffer();
                let res = fd_readddir(dir.fd, dir.buffer, dir.size, dir.cookie, buffer);
                caml_unix_error_if(res, "readdir", no_arg);
                let available = m.load32(buffer);
                br_if 'done !available;
                dir.pos = 0;
                dir.available = available;
                br 'loop;
            }
        }
        // done
        caml_raise_end_of_file();
        0 as &i31;
    }

    #[export = "unix_closedir"]
    #[export = "caml_unix_closedir"]
    fn unix_closedir(vdir: &eq) -> &eq {
        let dir = vdir as &directory;
        let buf = dir.buffer;
        let res: i32;
        'error: do {
            if !buf {
                res = 8; // EBADF
                br 'error;
            }
            free(buf);
            dir.buffer = 0;
            // Reset the read position so that a readdir on the closed
            // directory does not parse leftover dirents out of the freed
            // buffer (now address 0); instead it falls through to
            // fd_readdir on the closed fd and fails with EBADF.
            dir.pos = 0;
            dir.available = 0;
            // drop the pending "." / ".." so a readdir on the closed handle fails
            dir.dots = 0;
            res = fd_close(dir.fd);
            br_if 'error res;
            return 0 as &i31;
        }
        caml_unix_error(res, "closedir", no_arg);
        0 as &i31;
    }

    #[export = "unix_rewinddir"]
    #[export = "caml_unix_rewinddir"]
    fn unix_rewinddir(vdir: &eq) -> &eq {
        let dir = vdir as &directory;
        dir.cookie = 0;
        dir.pos = 0;
        dir.available = 0;
        dir.dots = 2;
        0 as &i31;
    }
}
#[else]
{
    #[export = "unix_opendir"]
    #[export = "caml_unix_opendir"]
    fn unix_opendir(name: &eq) -> &eq {
        try {
            wrap(opendir(unwrap(caml_jsstring_of_string(name))));
        } catch {
            javascript_exception => {
                caml_unix_error(_, null);
                0 as &i31;
            }
        }
    }

    fn throw_ebadf(cmd: &eq) {
        throw ocaml_exception
            [block|
                0 as &i31,
                get_unix_error_exn(),
                3 // EBADF
                    as &i31,
                cmd,
                no_arg,
            ];
    }

    fn readdir_helper(dir: &eq) -> &eq {
        'end: do {
            return
                try {
                    caml_string_of_jsstring(wrap(br_on_null 'end readdir(unwrap(dir))));
                } catch {
                    javascript_exception => {
                        _ = _;
                        throw_ebadf("readdir");
                        0 as &i31;
                    }
                };
        }
        caml_raise_end_of_file();
        0 as &i31;
    }

    #[export = "unix_closedir"]
    #[export = "caml_unix_closedir"]
    #[export = "win_findclose"]
    #[export = "caml_unix_findclose"]
    fn unix_closedir(dir: &eq) -> &eq {
        try {
            closedir(unwrap(dir));
        } catch {
            javascript_exception => {
                _ = _;
                throw_ebadf("closedir");
            }
        }
        0 as &i31;
    }

    #[export = "unix_rewinddir"]
    #[export = "caml_unix_rewinddir"]
    fn unix_rewinddir(&eq) -> &eq {
        caml_invalid_argument("rewinddir not implemented");
        0 as &i31;
    }
}

#[export = "unix_readdir"]
#[export = "caml_unix_readdir"]
fn unix_readdir(dir: &eq) -> &eq {
    'return: do {
        br_on_non_null 'return readdir_helper(dir);
        caml_raise_end_of_file();
        0 as &i31;
    }
}

#[export = "win_findnext"]
#[export = "caml_unix_findnext"]
fn win_find_next(dir: &eq) -> &eq {
    // Like native [win_findnext] and the JS runtime, raise End_of_file at
    // the end without closing the handle -- the caller closes it through
    // [findclose]. [readdir_helper] already raises End_of_file (it never
    // returns null), so the final raise here is just the type-level tail.
    'return: do {
        br_on_non_null 'return readdir_helper(dir);
        caml_raise_end_of_file();
        0 as &i31;
    }
}

#[export = "win_findfirst"]
#[export = "caml_unix_findfirst"]
fn win_findfirst(vpath: &eq) -> &eq {
    let p = vpath as &bytes;
    let len = p.length() - 3;
    let p': &bytes = [0; len];
    p'.copy(0, p, 0, len);
    let dir = unix_opendir(p');
    [block|0 as &i31, win_find_next(dir), dir];
}


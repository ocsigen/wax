#[if(wasi)]
{
    const link_str = "link";

    #[export = "unix_link"]
    #[export = "caml_unix_link"]
    fn unix_link(follow: &eq, o: &eq, n: &eq) -> &eq {
        // Resolve both paths without raising, so that the first buffer is
        // always freed below even if resolving the second path fails.
        let (op_fd, op_addr, op_len) = wasi_resolve_path(o);
        let (np_fd, np_addr, np_len) = wasi_resolve_path(n);
        let flags: i32;
        if follow is &block {
            flags = (follow as &block)[1] as i32_u;
        }
        let arg = o;
        let res = 44; // ENOENT
        'error: do {
            br_if 'error op_fd <s 0;
            arg = n;
            br_if 'error np_fd <s 0;
            arg = o;
            res = path_link(op_fd, flags, op_addr, op_len, np_fd, np_addr, np_len);
        }
        free(op_addr);
        free(np_addr);
        caml_unix_error_if(res, link_str, arg);
        0 as &i31;
    }
}
#[else]
#[export = "unix_link"]
#[export = "caml_unix_link"]
fn unix_link(follow: &eq, d: &eq, s: &eq) -> &eq {
    if follow is &block {
        throw ocaml_exception
            [block|
                0 as &i31,
                get_unix_error_exn(),
                25 // ENOSYS
                    as &i31,
                "link",
                no_arg,
            ];
    }
    try {
        link(unwrap(caml_jsstring_of_string(d)), unwrap(caml_jsstring_of_string(s)));
    } catch {
        javascript_exception => {
            caml_unix_error(_, null);
        }
    }
    0 as &i31;
}


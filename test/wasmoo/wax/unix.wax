#[export = "caml_unix_time"]
#[export = "unix_time"]
fn caml_unix_time(&eq) -> &eq {
    let buffer = get_buffer();
    let res = clock_time_get(0, 1000, buffer);
    caml_unix_error_if(res, "time", no_arg);
    { f: (m.load64(buffer) as f64_u * 1e-9).floor() };
}
#[else]
#[export = "caml_unix_time"]
#[export = "unix_time"]
fn caml_unix_time(&eq) -> &eq {

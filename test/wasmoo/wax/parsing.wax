#[import = ("jslib", "wrap")]
fn wrap(&?any) -> &eq;
#[import = ("jslib", "caml_string_of_jsstring")]
fn caml_string_of_jsstring(&eq) -> &eq;
#[import = ("io", "caml_stderr")]
let caml_stderr: &eq;
#[import = ("io", "caml_ml_open_descriptor_out")]
fn caml_ml_open_descriptor_out(&eq) -> &eq;
#[import = ("io", "caml_ml_output")]
fn caml_ml_output(&eq, &eq, &eq, &eq) -> &eq;
#[import = ("io", "caml_ml_flush")]
fn caml_ml_flush(&eq) -> &eq;
#[import = ("ints", "caml_format_int")]
fn caml_format_int(&eq, &eq) -> &eq;
#[import = ("float", "caml_format_float")]
fn caml_format_float(&eq, &eq) -> &eq;

type float = { f: f64 };
type block = [mut &eq];
type string = [mut i8];

fn get(a: &eq, i: i32) -> i32 {
    let s = a as &string;
    i = i + i;
    (s[i] as i32_u | s[i + 1] as i32_u << 8).extend16_s();
}

let caml_parser_trace = 0;

const ERRCODE = 256;

const START = 0;
const TOKEN_READ = 1;
const STACKS_GROWN_1 = 2;
const STACKS_GROWN_2 = 3;
const SEMANTIC_ACTION_COMPUTED = 4;
const ERROR_DETECTED = 5;
const loop_2 = 6;
const testshift = 7;
const shift = 8;
const shift_recover = 9;
const reduce = 10;

const READ_TOKEN = 0;
const RAISE_PARSE_ERROR = 1;
const GROW_STACKS_1 = 2;
const GROW_STACKS_2 = 3;
const COMPUTE_SEMANTIC_ACTION = 4;
const CALL_ERROR_FUNCTION = 5;

const env_s_stack = 1;
const env_v_stack = 2;
const env_symb_start_stack = 3;
const env_symb_end_stack = 4;
const env_stacksize = 5;
const env_stackbase = 6;
const env_curr_char = 7;
const env_lval = 8;
const env_symb_start = 9;
const env_symb_end = 10;
const env_asp = 11;
const env_rule_len = 12;
const env_rule_number = 13;
const env_sp = 14;
const env_state = 15;
const env_errflag = 16;

const tbl_transl_const = 2;
const tbl_transl_block = 3;
const tbl_lhs = 4;
const tbl_len = 5;
const tbl_defred = 6;
const tbl_dgoto = 7;
const tbl_sindex = 8;
const tbl_rindex = 9;
const tbl_gindex = 10;
const tbl_tablesize = 11;
const tbl_table = 12;
const tbl_check = 13;
const tbl_names_const = 15;
const tbl_names_block = 16;

fn strlen(s: &string, p: i32) -> i32 {
    let i = p;
    'loop: loop { if s[i] as i32_u != 0 { i = i + 1; br 'loop; } }
    i - p;
}

data unknown_token = "<unknown token>";
fn token_name(vnames: &eq, number: i32) -> &eq {
    let names = vnames as &string;
    let i: i32;
    'loop: loop {
        if !(names[i] as i32_u) { return [string|unknown_token @ 0; 15]; }
        if number != 0 {
            i = i + (strlen(names, i) + 1);
            number = number - 1;
            br 'loop;
        }
    }
    let len = strlen(names, i);
    let name = [string|0; len];
    name.copy(0, names, i, len);
    name;
}

fn output(x: &eq) {
    let s = x as &string;
    _ = caml_ml_output(caml_stderr, s, 0 as &i31, s.length() as &i31);
}

fn output_nl() {
    _ = caml_ml_output(caml_stderr, string#"\n", 0 as &i31, 1 as &i31);
    _ = caml_ml_flush(caml_stderr);
}

fn output_int(x: i32) { output(caml_format_int(string#"%d", x as &i31)); }

data State = "State ";
data read_token = ": read token ";

fn print_token(tables: &block, state: i32, tok: &eq) {
    if tok is &i31 {
        output([string|State @ 0; 6]);
        output_int(state);
        output([string|read_token @ 0; 13]);
        output(token_name(tables[tbl_names_const], tok as &i31 as i32_u));
        output_nl();
    } else {
        output([string|State @ 0; 6]);
        output_int(state);
        output([string|read_token @ 0; 13]);
        let b = tok as &block;
        output(token_name(tables[tbl_names_block], b[0] as &i31 as i32_u));
        output
            (string#"(" // "("
            );
        let v = b[1];
        if v is &i31 {
            output_int(v as &i31 as i32_s);
        } else {
            if v is &string {
                output(v);
            } else {
                if v is &float {
                    output(caml_format_float(string#"%g", v));
                } else { output(string#"_"); }
            }
        } // '_'
        output
            (string#")" // ")"
            );
        output_nl();
    }
}

data recovering_in_state = "Recovering in state ";
data discarding_state = "Discarding state ";
data no_more_states_to_discard = "No more states to discard";
data discarding_last_token_read = "Discarding last token read";
data shift_to_state = ": shift to state ";
data reduce_by_rule = ": reduce by rule ";

#[export = "caml_parse_engine"]
fn caml_parse_engine(vtables: &eq, venv: &eq, vcmd: &eq, varg: &eq) -> &eq {
    let tables = vtables as &block;
    let tbl_defred_2 = tables[tbl_defred] as &string;
    let tbl_sindex_2 = tables[tbl_sindex] as &string;
    let tbl_check_2 = tables[tbl_check] as &string;
    let tbl_rindex_2 = tables[tbl_rindex] as &string;
    let tbl_table_2 = tables[tbl_table] as &string;
    let tbl_len_2 = tables[tbl_len] as &string;
    let tbl_lhs_2 = tables[tbl_lhs] as &string;
    let tbl_gindex_2 = tables[tbl_gindex] as &string;
    let tbl_dgoto_2 = tables[tbl_dgoto] as &string;
    let env = venv as &block;
    let cmd = vcmd as &i31 as i32_s;
    let sp = env[env_sp] as &i31 as i32_s;
    let state = env[env_state] as &i31 as i32_s;
    let errflag = env[env_errflag] as &i31 as i32_s;
    let res: i32;
    'exit: do {
        'next: loop {
            'default: do {
                'SEMANTIC_ACTION_COMPUTED: do {
                    'STACKS_GROWN_2: do {
                        let n: i32;
                        let n1: i32;
                        let n2: i32;
                        let state1: i32;
                        'reduce: do {
                            'STACKS_GROWN_1: do {
                                'shift_recover: do {
                                    'shift: do {
                                        'ERROR_DETECTED: do {
                                            'testshift: do {
                                                'TOKEN_READ: do {
                                                    'loop: do {
                                                        'START: do {
                                                            br_table
                                                                [ 'START
                                                                    'TOKEN_READ
                                                                    'STACKS_GROWN_1
                                                                    'STACKS_GROWN_2
                                                                    'SEMANTIC_ACTION_COMPUTED
                                                                    'ERROR_DETECTED
                                                                    'loop
                                                                    'testshift
                                                                    'shift
                                                                    'shift_recover
                                                                    'reduce
                                                                    else
                                                                    'default
                                                                    ]
                                                                cmd;
                                                        }
                                                        // START:
                                                        state = 0;
                                                        errflag = 0;
                                                    }
                                                    // Fall through
                                                    // loop:
                                                    n =
                                                        get
                                                            (tbl_defred_2,
                                                             state);
                                                    if n != 0 {
                                                        cmd = reduce;
                                                        br 'next;
                                                    }
                                                    if
                                                        env[env_curr_char]
                                                            as &i31 as i32_s
                                                            >=s 0
                                                    {
                                                        cmd = testshift;
                                                        br 'next;
                                                    }
                                                    res = READ_TOKEN;
                                                    br 'exit;
                                                }
                                                // TOKEN_READ:
                                                'cont: do {
                                                    let arg: &block;
                                                    _ =
                                                        'not_block: do &eq {
                                                            arg =
                                                                br_on_cast_fail
                                                                    'not_block
                                                                    &block
                                                                    varg;
                                                            env
                                                                [env_curr_char]
                                                                =
                                                                (tables
                                                                    [tbl_transl_block]
                                                                    as &block)
                                                                    [
                                                                    arg[0]
                                                                    as &i31
                                                                    as i32_u
                                                                    + 1];
                                                            env[env_lval] =
                                                                arg[1];
                                                            br 'cont;
                                                        };
                                                    env[env_curr_char] =
                                                        (tables
                                                             [tbl_transl_const]
                                                             as &block)
                                                            [varg as &i31
                                                                 as i32_u + 1];
                                                    env[env_lval] = 0 as &i31;
                                                }
                                                if caml_parser_trace {
                                                    print_token
                                                        (tables, state, varg);
                                                }
                                            }
                                            // Fall through
                                            // testshift:
                                            n1 = get(tbl_sindex_2, state);
                                            n2 =
                                                n1 +
                                                    env[env_curr_char]
                                                        as &i31 as i32_s;
                                            if (n1 != 0) & (n2 >=s 0) {
                                                if
                                                    n2 <=s
                                                        tables[tbl_tablesize]
                                                            as &i31 as i32_s
                                                {
                                                    if
                                                        get(tbl_check_2, n2)
                                                            as &i31 ==
                                                            env
                                                                [env_curr_char]
                                                    {
                                                        cmd = shift;
                                                        br 'next;
                                                    }
                                                }
                                            }
                                            n1 = get(tbl_rindex_2, state);
                                            n2 =
                                                n1 +
                                                    env[env_curr_char]
                                                        as &i31 as i32_s;
                                            if (n1 != 0) & (n2 >=s 0) {
                                                if
                                                    n2 <=s
                                                        tables[tbl_tablesize]
                                                            as &i31 as i32_s
                                                {
                                                    if
                                                        get(tbl_check_2, n2)
                                                            as &i31 ==
                                                            env
                                                                [env_curr_char]
                                                    {
                                                        n =
                                                            get
                                                                (tbl_table_2,
                                                                 n2);
                                                        cmd = reduce;
                                                        br 'next;
                                                    }
                                                }
                                            }
                                            if errflag <=s 0 {
                                                res = CALL_ERROR_FUNCTION;
                                                br 'exit;
                                            }
                                        }
                                        // Fall through
                                        // ERROR_DETECTED:
                                        if errflag <s 3 {
                                            errflag = 3;
                                            'loop2: loop {
                                                state1 =
                                                    (env[env_s_stack]
                                                         as &block)
                                                        [sp + 1] as &i31
                                                        as i32_s;
                                                n1 =
                                                    get(tbl_sindex_2, state1);
                                                n2 = n1 + ERRCODE;
                                                if (n1 != 0) & (n2 >=s 0) {
                                                    if
                                                        n2 <=s
                                                            tables
                                                                [tbl_tablesize]
                                                                as &i31
                                                                as i32_s
                                                    {
                                                        if
                                                            get
                                                                (tbl_check_2,
                                                                 n2)
                                                                == ERRCODE
                                                        {
                                                            if
                                                                caml_parser_trace
                                                            {
                                                                output
                                                                    (
                                                                    [string|
                                                                    recovering_in_state
                                                                    @
                                                                    0;
                                                                    20]);
                                                                output_int
                                                                    (
                                                                    state1);
                                                                output_nl();
                                                            }
                                                            cmd =
                                                                shift_recover;
                                                            br 'next;
                                                        }
                                                    }
                                                }
                                                if caml_parser_trace {
                                                    output
                                                        ([string|
                                                             discarding_state
                                                             @
                                                             0;
                                                             17]);
                                                    output_int(state1);
                                                    output_nl();
                                                }
                                                if
                                                    sp <=s
                                                        env[env_stackbase]
                                                            as &i31 as i32_s
                                                {
                                                    if caml_parser_trace {
                                                        output
                                                            ([string|
                                                                 no_more_states_to_discard
                                                                 @
                                                                 0;
                                                                 25]);
                                                        output_nl();
                                                    }
                                                    return
                                                        RAISE_PARSE_ERROR
                                                            as &i31;
                                                }
                                                sp = sp - 1;
                                                br 'loop2;
                                            }
                                        } else {
                                            if
                                                env[env_curr_char] ==
                                                    0 as &i31
                                            {
                                                return
                                                    RAISE_PARSE_ERROR as &i31;
                                            }
                                            if caml_parser_trace {
                                                output
                                                    ([string|
                                                         discarding_last_token_read
                                                         @
                                                         0;
                                                         26]);
                                                output_nl();
                                            }
                                            env[env_curr_char] = -1 as &i31;
                                            cmd = loop_2;
                                            br 'next;
                                        }
                                    }
                                    // shift:
                                    env[env_curr_char] = -1 as &i31;
                                    if errflag >s 0 {
                                        errflag = errflag - 1;
                                    }
                                }
                                // Fall through
                                // shift_recover:
                                if caml_parser_trace {
                                    output([string|State @ 0; 6]);
                                    output_int(state);
                                    output([string|shift_to_state @ 0; 17]);
                                    output_int(get(tbl_table_2, n2));
                                    output_nl();
                                }
                                state = get(tbl_table_2, n2);
                                sp = sp + 1;
                                if sp >=s env[env_stacksize] as &i31 as i32_s
                                {
                                    res = GROW_STACKS_1;
                                    br 'exit;
                                }
                            }
                            // Fall through
                            // STACKS_GROWN_1:
                            (env[env_s_stack] as &block)[sp + 1] =
                                state as &i31;
                            (env[env_v_stack] as &block)[sp + 1] =
                                env[env_lval];
                            (env[env_symb_start_stack] as &block)[sp + 1] =
                                env[env_symb_start];
                            (env[env_symb_end_stack] as &block)[sp + 1] =
                                env[env_symb_end];
                            cmd = loop_2;
                            br 'next;
                        }
                        // reduce:
                        if caml_parser_trace {
                            output([string|State @ 0; 6]);
                            output_int(state);
                            output([string|reduce_by_rule @ 0; 17]);
                            output_int(n);
                            output_nl();
                        }
                        let m = get(tbl_len_2, n);
                        env[env_asp] = sp as &i31;
                        env[env_rule_number] = n as &i31;
                        env[env_rule_len] = m as &i31;
                        sp = sp + (1 - m);
                        m = get(tbl_lhs_2, n);
                        state1 =
                            (env[env_s_stack] as &block)[sp] as &i31 as i32_s;
                        n1 = get(tbl_gindex_2, m);
                        n2 = n1 + state1;
                        'cont: do {
                            if (n1 != 0) & (n2 >=s 0) {
                                if
                                    n2 <=s
                                        tables[tbl_tablesize] as &i31
                                            as i32_s
                                {
                                    if get(tbl_check_2, n2) == state1 {
                                        state = get(tbl_table_2, n2);
                                        br 'cont;
                                    }
                                }
                            }
                            state = get(tbl_dgoto_2, m);
                        }
                        if sp >=s env[env_stacksize] as &i31 as i32_s {
                            res = GROW_STACKS_2;
                            br 'exit;
                        }
                    }
                    // Fall through
                    // STACKS_GROWN_2:
                    res = COMPUTE_SEMANTIC_ACTION;
                    br 'exit;
                }
                // SEMANTIC_ACTION_COMPUTED:
                (env[env_s_stack] as &block)[sp + 1] = state as &i31;
                (env[env_v_stack] as &block)[sp + 1] = varg;
                let asp = env[env_asp] as &i31 as i32_s;
                (env[env_symb_end_stack] as &block)[sp + 1] =
                    (env[env_symb_end_stack] as &block)[asp + 1];
                if sp >s asp {
                    // This is an epsilon production. Take symb_start equal to symb_end.
                    (env[env_symb_start_stack] as &block)[sp + 1] =
                        (env[env_symb_end_stack] as &block)[asp + 1];
                }
                cmd = loop_2;
                br 'next;
            }
            // default:
            return RAISE_PARSE_ERROR as &i31;
        }
    }
    // SAVE
    env[env_sp] = sp as &i31;
    env[env_state] = state as &i31;
    env[env_errflag] = errflag as &i31;
    res as &i31;
}

#[export = "caml_set_parser_trace"]
fn caml_set_parser_trace(x: &eq) -> &eq {
    let oldflag = caml_parser_trace;
    caml_parser_trace = x as &i31 as i32_s;
    oldflag as &i31;
}

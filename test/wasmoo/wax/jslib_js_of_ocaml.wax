#[if(not(wasi))]
{
    import "jslib" {
        fn wrap(&?any) -> &eq;
        fn unwrap(&eq) -> &?any;
        fn caml_js_global(&eq) -> &eq;
        fn caml_js_get(&eq, &eq) -> &eq;
        fn caml_js_new(&eq, &eq) -> &eq;
        fn caml_js_from_array(&eq) -> &eq;
    }
    import "js"
    #[import = "caml_js_html_entities"]
    fn caml_js_html_entities_js(&?any) -> &?any;

    type block = [mut &eq];
    type bytes = [mut i8];

    #[export]
    fn caml_js_html_entities(v: &eq) -> &eq {
        become wrap(caml_js_html_entities_js(unwrap(v)));
    }

    const console = "console";

    #[export]
    fn caml_js_get_console(&eq) -> &eq {
        become caml_js_get(caml_js_global(0 as &i31), console);
    }

    const XMLHttpRequest = "XMLHttpRequest";

    #[export]
    fn caml_xmlhttprequest_create(&eq) -> &eq {
        become caml_js_new(
            caml_js_get(caml_js_global(0 as &i31), XMLHttpRequest),
            [block|0 as &i31],
        );
    }
}

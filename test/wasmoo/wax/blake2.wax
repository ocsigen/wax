#[if(ocaml_version >= (5, 2, 0))]
{
    #[import = ("blake2", "blake2_memory")]
    memory m: i32 [1];
    #[import = ("blake2", "blake2_state_buf")]
    fn state_buf() -> i32;
    #[import = ("blake2", "blake2_key_buf")]
    fn key_buf() -> i32;
    #[import = ("blake2", "blake2_out_buf")]
    fn out_buf() -> i32;
    #[import = ("blake2", "blake2_chunk_buf")]
    fn chunk_buf() -> i32;
    #[import = ("blake2", "blake2_chunk_buf_size")]
    fn chunk_buf_size() -> i32;
    #[import = ("blake2", "blake2_init")]
    fn blake2_init(i32, i32);
    #[import = ("blake2", "blake2_update")]
    fn blake2_update(i32);
    #[import = ("blake2", "blake2_finalize")]
    fn blake2_finalize(i32);

    type bytes = [mut i8];

    // Must match BLAKE2_STATE_SIZE in blake2_wrap.c.  A _Static_assert there
    // rejects shrinking blake2b_state past this value at C compile time.
    const blake2_state_size = 248;

    // BLAKE2B_KEYBYTES: the width of $key_buf and the maximum key length.
    const blake2_key_size = 64;

    // Blit a slice of a GC byte array into linear memory.
    fn bytes_to_mem(src: &bytes, src_ofs: i32, dst: i32, len: i32) {
        'done: do {
            let i: i32;
            'cont: loop {
                br_if 'done i == len;
                m.store8(dst + i, src[src_ofs + i] as i32_u);
                i = i + 1;
                br 'cont;
            }
        }
    }

    // Blit a slice of linear memory into a GC byte array.
    fn mem_to_bytes(src: i32, dst: &bytes, dst_ofs: i32, len: i32) {
        'done: do {
            let i: i32;
            'cont: loop {
                br_if 'done i == len;
                dst[dst_ofs + i] = m.load8(src + i) as i32_u;
                i = i + 1;
                br 'cont;
            }
        }
    }

    // Allocate a fresh state byte array and run blake2_init into it.
    fn do_create(hashlen: i32, key: &bytes) -> &bytes {
        let state: &bytes = [0; blake2_state_size];
        // BLAKE2b keys are at most BLAKE2B_KEYBYTES (64), the width of $key_buf.
        // Truncate a longer key to its 64-byte prefix (matching the JS runtime)
        // so the blit and blake2_init stay in bounds.
        let keylen = key.length();
        if keylen >u blake2_key_size {
            keylen = blake2_key_size;
        }
        bytes_to_mem(key, 0, key_buf(), keylen);
        blake2_init(hashlen, keylen);
        mem_to_bytes(state_buf(), state, 0, blake2_state_size);
        state;
    }

    // Feed input through the fixed-size chunk buffer.
    fn do_update(state: &bytes, buf: &bytes, ofs: i32, len: i32) {
        bytes_to_mem(state, 0, state_buf(), blake2_state_size);
        let chunk_max = chunk_buf_size();
        'done: do {
            'cont: loop {
                br_if 'done !len;
                let chunk = len >u chunk_max?chunk_max:len;
                bytes_to_mem(buf, ofs, chunk_buf(), chunk);
                blake2_update(chunk);
                ofs = ofs + chunk;
                len = len - chunk;
                br 'cont;
            }
        }
        mem_to_bytes(state_buf(), state, 0, blake2_state_size);
    }

    // Run blake2_finalize and copy the digest into a fresh byte array.
    fn do_final(state: &bytes, hashlen: i32) -> &bytes {
        bytes_to_mem(state, 0, state_buf(), blake2_state_size);
        blake2_finalize(hashlen);
        let output: &bytes = [0; hashlen];
        mem_to_bytes(out_buf(), output, 0, hashlen);
        output;
    }

    #[export = "caml_blake2_create"]
    fn caml_blake2_create(hashlen: &eq, key: &eq) -> &eq {
        do_create(hashlen as &i31 as i32_u, key as &bytes);
    }

    #[export = "caml_blake2_update"]
    fn caml_blake2_update(ctx: &eq, buf: &eq, ofs: &eq, len: &eq) -> &eq {
        do_update(ctx as &bytes, buf as &bytes, ofs as &i31 as i32_u, len as &i31 as i32_u);
        0 as &i31;
    }

    #[export = "caml_blake2_final"]
    fn caml_blake2_final(ctx: &eq, hashlen: &eq) -> &eq {
        do_final(ctx as &bytes, hashlen as &i31 as i32_u);
    }

    #[export = "caml_blake2_string"]
    #[export = "caml_blake2_bytes"]
    fn caml_blake2_string(hashlen: &eq, key: &eq, buf: &eq, ofs: &eq, len: &eq) -> &eq {
        let hl = hashlen as &i31 as i32_u;
        let state = do_create(hl, key as &bytes);
        do_update(state, buf as &bytes, ofs as &i31 as i32_u, len as &i31 as i32_u);
        do_final(state, hl);
    }
}

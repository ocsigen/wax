const toString = "toString";

#[if(wasi)]
{
    #[export]
    fn caml_handle_sys_error(arg: &eq, errno: i32) {
        let msg =
            if errno >=u error_messages.length() {
                "unknown system error";
            } else {
                error_messages[errno];
            };
        if arg is &bytes {
            msg = caml_string_concat(arg, caml_string_concat(": ", msg));
        }
        caml_raise_sys_error(msg);
    }

    #[export]
    fn caml_handle_sys_error_if(arg: &eq, errno: i32) {
        if errno {
            caml_handle_sys_error(arg, errno);
        }
    }
}
#[else]
#[export]
fn caml_handle_sys_error(exn: &?extern) {
    caml_raise_sys_error(
        caml_string_of_jsstring(caml_js_meth_call(wrap(exn as &?any), toString, [block|0 as &i31])),
    );
}

#[import = ("io", "caml_channel_descriptor")]
fn caml_channel_descriptor(&eq) -> &eq;

type block = [mut &eq];
type bytes = [mut i8];
type float = { f: f64 };

#[export]
tag ocaml_exit();

#[export]
#[export = "unix_exit"]
#[export = "caml_unix_exit"]
fn caml_sys_exit(code: &eq) -> &eq {
    exit(code as i32_s);
    // Fallback: try to exit through an exception
    throw ocaml_exit;
}

#[if(wasi)]
{
    let environment = 0;
    let environment_count = 0;
    let environment_data = 0;

    fn initialize_env() {
        if !environment {
            let buffer = get_buffer();
            let res = environ_sizes_get(buffer, buffer + 4);
            if res {
                caml_handle_sys_error(0 as &i31, res);
            }
            let env = checked_malloc(m.load32(buffer) << 2);
            let dat = checked_malloc(m.load32(buffer, 4, 4));
            res = environ_get(env, dat);
            if res {
                free(env);
                free(dat);
                caml_handle_sys_error(0 as &i31, res);
            }
            environment = env;
            environment_data = dat;
            environment_count = m.load32(buffer);
        }
    }

    fn caml_getenv(name: &eq) -> &?eq {
        initialize_env();
        let var = name as &bytes;
        let len = var.length();
        'not_found: do {
            let i: i32;
            while i <u len : (i += 1) {
                br_if 'not_found
                    61 // '='
                        == var[i] as i32_u;
            }
            i = 0;
            while i <u environment_count : (i += 1) {
                let s = m.load32(environment + (i << 2));
                let j = 0;
                'next: do {
                    while j <u len : (j += 1) {
                        let c = m.load8(s + j) as i32_u;
                        br_if 'next !c;
                        br_if 'next c != var[j] as i32_u;
                    }
                    br_if 'next
                        61 // '='
                            != m.load8(s + j) as i32_u;
                    s += j + 1;
                    become blit_memory_to_string(s, strlen(s));
                }
            }
        }
        null;
    }
}
#[else]
fn caml_getenv(name: &eq) -> &?eq {
    let res = getenv(unwrap(caml_jsstring_of_string(name)));
    if !jsstring_test(res) {
        return null;
    }
    become caml_string_of_jsstring(wrap(res));
}

#[export]
#[export = "caml_sys_unsafe_getenv"]
fn caml_sys_getenv(name: &eq) -> &eq {
    let res = caml_getenv(name);
    if !res {
        caml_raise_not_found();
    }
    res!;
}

#[export]
fn caml_sys_getenv_opt(name: &eq) -> &eq {
    let res = caml_getenv(name);
    if !res {
        return 0 as &i31;
    }
    [block|0 as &i31, res!];
}

#[if(wasi)]
{
    let argv: &?block = null;

    #[export]
    fn caml_sys_argv(&eq) -> &eq {
        'init: do {
            return br_on_null 'init argv;
        }
        let res: i32;
        let argv_ptr: i32;
        let argv_buf: i32;
        'error: do {
            let buffer = get_buffer();
            res = args_sizes_get(buffer, buffer + 4);
            br_if 'error res;
            let argc = m.load32(buffer);
            argv_ptr = checked_malloc(argc << 2);
            argv_buf = checked_malloc(m.load32(buffer, 4, 4));
            res = args_get(argv_ptr, argv_buf);
            br_if 'error res;
            let args: &block = [0 as &i31; argc + 1];
            let i: i32;
            while i <u argc : (i += 1) {
                let arg = m.load32(argv_ptr + (i << 2));
                args[i + 1] = blit_memory_to_string(arg, strlen(arg));
            }
            argv = args;
            free(argv_ptr);
            free(argv_buf);
            return args;
        }
        // error path: free any buffers already allocated (free(0) is a no-op
        // when reached before the allocations)
        free(argv_ptr);
        free(argv_buf);
        caml_handle_sys_error(0 as &i31, res);
        [block|];
    }

    #[export]
    fn caml_sys_executable_name(&eq) -> &eq {
        (caml_sys_argv(0 as &i31) as &block)[1];
    }
}
#[else]
{
    #[export]
    fn caml_sys_argv(&eq) -> &eq {
        // ZZZ
        caml_js_to_string_array(argv_fn());
    }

    #[export]
    fn caml_sys_executable_name(&eq) -> &eq {
        (caml_js_to_string_array(argv_fn()) as &block)[1];
    }
}

#[export]
fn caml_sys_proc_self_exe(&eq) -> &eq {
    0 as &i31;
}

#[if(wasi)]
#[export]
#[export = "caml_sys_time_include_children"]
fn caml_sys_time(&eq) -> &eq {
    let buffer = get_buffer();
    let res = clock_time_get(2, 1, buffer);
    // wasmtime does not support the CPU-time clock, so use the
    // monotonic clock instead as a fallback
    if res == 8 {
        res = clock_time_get(1, 1, buffer);
    }
    if res {
        caml_handle_sys_error(0 as &i31, res);
    }
    { f: m.load64(buffer) as f64_u * 1e-9 };
}
#[else]
#[export]
#[export = "caml_sys_time_include_children"]
fn caml_sys_time(&eq) -> &eq {
    { f: time() * 0.001 };
}

#[if(wasi)]
#[export]
fn caml_sys_system_command(&eq) -> &eq {
    caml_invalid_argument("Sys.command not implemented");
    return 0 as &i31;
}
#[else]
#[export]
fn caml_sys_system_command(cmd: &eq) -> &eq {
    try {
        return system(unwrap(caml_jsstring_of_string(cmd)));
    } catch {
        javascript_exception => {
            caml_handle_sys_error(_);
        }
    }
    return 0 as &i31;
}

#[if(wasi)]
#[export]
fn caml_sys_random_seed(&eq) -> &eq {
    let r: &extern;
    let n = 12;
    let buffer = get_buffer();
    let res = random_get(buffer, n << 2);
    if res {
        caml_handle_sys_error(0 as &i31, res);
    }
    let a: &block = [0 as &i31; n + 1];
    let i: i32;
    while i <u n : (i += 1) {
        a[i + 1] = m.load32(buffer + (i << 2)) as &i31;
    }
    a;
}
#[else]
#[export]
fn caml_sys_random_seed(&eq) -> &eq {
    let r = random_seed();
    let n = ta_length(r);
    let a: &block = [0 as &i31; n + 1];
    let i: i32;
    while i <u n : (i += 1) {
        a[i + 1] = ta_get_i32(r, i) as &i31;
    }
    a;
}


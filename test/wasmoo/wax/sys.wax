{
    #[import = ("wasi_snapshot_preview1", "random_get")]
    fn random_get(i32, i32) -> i32;
    #[import = ("wasi_snapshot_preview1", "clock_time_get")]
    fn clock_time_get(i32, i64, i32) -> i32;

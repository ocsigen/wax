    #[import = ("wasi_snapshot_preview1", "environ_get")]
    fn environ_get(i32, i32) -> i32;
    #[import = ("wasi_snapshot_preview1", "environ_sizes_get")]
    fn environ_sizes_get(i32, i32) -> i32;
    #[import = ("wasi_snapshot_preview1", "proc_exit")]
    fn exit(i32);
    #[import = ("libc", "memory")]
    memory m: i32 [2];
    #[import = ("libc", "free")]
    fn free(i32);
    #[import = ("libc", "strlen")]

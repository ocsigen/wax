#[import = ("fail", "caml_invalid_argument")]
fn caml_invalid_argument(&eq);
#[import = ("fail", "caml_failwith")]
fn caml_failwith(&eq);

type string = [mut i8];
type block = [mut &eq];

type char_table = [i8];
type int_array = [mut i32];

const re_word_letters =
    [char_table|
        0x00,
        0x00,
        0x00,
        0x00, // 0x00-0x1F: none
        0x00,
        0x00,
        0xFF,
        0x03, // 0x20-0x3F: digits 0-9
        0xFE,
        0xFF,
        0xFF,
        0x87, // 0x40-0x5F: A to Z, _
        0xFE,
        0xFF,
        0xFF,
        0x07, // 0x60-0x7F: a to z
        0x00,
        0x00,
        0x00,
        0x00, // 0x80-0x9F: none
        0x00,
        0x00,
        0x00,
        0x00, // 0xA0-0xBF: none
        0xFF,
        0xFF, // 0xC0-0xDF:
        0x7F,
        0xFF, // Latin-1 accented uppercase
        0xFF,
        0xFF, // 0xE0-0xFF:
        0x7F,
        0xFF]; // Latin-1 accented lowercase
type stack = open { f: &?stack };
type pos: stack = { pos_previous: &?stack, pc: i32, pos: i32 };
type undo: stack = { undo_previous: &?stack, tbl: &int_array, idx: i32, val: i32 };

fn is_word_letter(c: i32) -> i32 {
    1 & re_word_letters[c >>u 3] as i32_u >>u (c & 7);
}

fn in_bitset(s: &string, c: i32) -> i32 {
    1 & s[c >>u 3] as i32_u >>u (c & 7);
}

fn re_match(vre: &eq, s: &string, pos: i32, accept_partial_match: i32) -> &eq {
    let len = s.length();
    let re = vre as &block;
    let prog = re[1] as &block;
    let cpool = re[2] as &block;
    let normtable = re[3] as &string;
    let numgroups = re[4] as &i31 as i32_s;
    let numregisters = re[5] as &i31 as i32_s;
    let group_start = [int_array|-1; numgroups];
    let group_end = [int_array|-1; numgroups];
    let re_register = [int_array|-1; numregisters];
    let pc = 1;
    group_start[0] = pos;
    'reject: do {
        let i: i32;
        let j: i32;
        'ACCEPT: do {
            'continue: loop {
                let stack: &?stack;
                'backtrack: do {
                    'prefix_match: do {
                        let instr: i32;
                        let arg: i32;
                        'CHECKPROGRESS: do {
                            'SETMARK: do {
                                'PUSHBACK: do {
                                    'GOTO: do {
                                        let set: &string;
                                        'SIMPLEPLUS: do {
                                            'SIMPLESTAR: do {
                                                'SIMPLEOPT: do {
                                                    'REFGROUP: do {
                                                        'ENDGROUP: do {
                                                            'BEGGROUP: do {
                                                                'WORDBOUNDARY: do {
                                                                    'EOL: do {
                                                                        'BOL: do {
                                                                            'CHARCLASS: do {
                                                                                let s': &string;
                                                                                let l: i32;
                                                                                'STRINGNORM: do {
                                                                                    'STRING: do {
                                                                                        'CHARNORM:
                                                                                        do {
                                                                                          'CHAR: do
                                                                                          {
                                                                                          instr =
                                                                                          prog[pc]
                                                                                          as &i31
                                                                                          as i32_s;
                                                                                          pc =
                                                                                          pc + 1;
                                                                                          br_table
                                                                                          [ 'CHAR
                                                                                          'CHARNORM
                                                                                          'STRING
                                                                                          'STRINGNORM
                                                                                          'CHARCLASS
                                                                                          'BOL 'EOL
                                                                                          'WORDBOUNDARY
                                                                                          'BEGGROUP
                                                                                          'ENDGROUP
                                                                                          'REFGROUP
                                                                                          'ACCEPT
                                                                                          'SIMPLEOPT
                                                                                          'SIMPLESTAR
                                                                                          'SIMPLEPLUS
                                                                                          'GOTO
                                                                                          'PUSHBACK
                                                                                          'SETMARK
                                                                                          else
                                                                                          'CHECKPROGRESS
                                                                                          ]
                                                                                          instr &
                                                                                          0xff;
                                                                                          }
                                                                                          // CHAR
                                                                                          br_if
                                                                                          'prefix_match
                                                                                          pos ==
                                                                                          len;
                                                                                          arg =
                                                                                          instr >>u
                                                                                          8;
                                                                                          br_if
                                                                                          'backtrack
                                                                                          arg !=
                                                                                          s[pos]
                                                                                          as i32_u;
                                                                                          pos =
                                                                                          pos + 1;
                                                                                          br
                                                                                          'continue;
                                                                                        }
                                                                                        // CHARNORM
                                                                                        br_if
                                                                                          'prefix_match
                                                                                          pos ==
                                                                                          len;
                                                                                        arg =
                                                                                          instr >>u
                                                                                          8;
                                                                                        br_if
                                                                                          'backtrack
                                                                                          arg !=
                                                                                          normtable
                                                                                          [s[pos]
                                                                                          as i32_u]
                                                                                          as i32_u;
                                                                                        pos =
                                                                                          pos + 1;
                                                                                        br
                                                                                          'continue;
                                                                                    }
                                                                                    // STRING
                                                                                    arg =
                                                                                        instr >>u 8;
                                                                                    s' =
                                                                                        cpool
                                                                                          [arg + 1]
                                                                                          as
                                                                                          &string;
                                                                                    i = 0;
                                                                                    l = s'.length();
                                                                                    'loop: loop {
                                                                                        if i <u l {
                                                                                          br_if
                                                                                          'prefix_match
                                                                                          pos ==
                                                                                          len;
                                                                                          br_if
                                                                                          'backtrack
                                                                                          s'[i]
                                                                                          as i32_u
                                                                                          !=
                                                                                          s[pos]
                                                                                          as i32_u;
                                                                                          pos =
                                                                                          pos + 1;
                                                                                          i = i + 1;
                                                                                          br 'loop;
                                                                                        }
                                                                                    }
                                                                                    br 'continue;
                                                                                }
                                                                                // STRINGNORM
                                                                                arg = instr >>u 8;
                                                                                s' =
                                                                                    cpool[arg + 1]
                                                                                        as &string;
                                                                                i = 0;
                                                                                l = s'.length();
                                                                                'loop: loop {
                                                                                    if i <u l {
                                                                                        br_if
                                                                                          'prefix_match
                                                                                          pos ==
                                                                                          len;
                                                                                        br_if
                                                                                          'backtrack
                                                                                          s'[i]
                                                                                          as i32_u
                                                                                          !=
                                                                                          normtable
                                                                                          [s[pos]
                                                                                          as i32_u]
                                                                                          as i32_u;
                                                                                        pos =
                                                                                          pos + 1;
                                                                                        i = i + 1;
                                                                                        br 'loop;
                                                                                    }
                                                                                }
                                                                                br 'continue;
                                                                            }
                                                                            // CHARCLASS
                                                                            br_if 'prefix_match
                                                                                pos == len;
                                                                            arg = instr >>u 8;
                                                                            br_if 'backtrack
                                                                                !in_bitset(
                                                                                     cpool[arg + 1]
                                                                                         as &string,
                                                                                     s[pos] as i32_u
                                                                                 );
                                                                            pos = pos + 1;
                                                                            br 'continue;
                                                                        }
                                                                        // BOL
                                                                        br_if 'continue !pos;
                                                                        br_if 'continue
                                                                            10 // '\n'
                                                                                ==
                                                                                s[pos - 1] as i32_u;
                                                                        br 'backtrack;
                                                                    }
                                                                    // EOL
                                                                    br_if 'continue pos == len;
                                                                    br_if 'continue
                                                                        10 // '\n'
                                                                            == s[pos] as i32_u;
                                                                    br 'backtrack;
                                                                }
                                                                // WORDBOUNDARY
                                                                if !pos {
                                                                    br_if 'prefix_match pos == len;
                                                                    br_if 'continue
                                                                        is_word_letter(
                                                                            s[pos] as i32_u
                                                                        );
                                                                    br 'backtrack;
                                                                } else {
                                                                    if pos == len {
                                                                        br_if 'continue
                                                                            is_word_letter(
                                                                                s[pos - 1] as i32_u
                                                                            );
                                                                        br 'backtrack;
                                                                    } else {
                                                                        br_if 'continue
                                                                            is_word_letter(
                                                                                s[pos - 1] as i32_u
                                                                            ) !=
                                                                                is_word_letter(
                                                                                    s[pos] as i32_u
                                                                                );
                                                                        br 'backtrack;
                                                                    }
                                                                }
                                                            }
                                                            // BEGGROUP
                                                            arg = instr >>u 8;
                                                            stack =
                                                                {undo|
                                                                    undo_previous: stack,
                                                                    tbl: group_start,
                                                                    idx: arg,
                                                                    val: group_start[arg]
                                                                };
                                                            group_start[arg] = pos;
                                                            br 'continue;
                                                        }
                                                        // ENDGROUP
                                                        arg = instr >>u 8;
                                                        stack =
                                                            {undo|
                                                                undo_previous: stack,
                                                                tbl: group_end,
                                                                idx: arg,
                                                                val: group_end[arg]
                                                            };
                                                        group_end[arg] = pos;
                                                        br 'continue;
                                                    }
                                                    // REFGROUP
                                                    arg = instr >>u 8;
                                                    i = group_start[arg];
                                                    j = group_end[arg];
                                                    br_if 'backtrack (i <s 0) | (j <s 0);
                                                    'loop: loop {
                                                        if i <u j {
                                                            br_if 'prefix_match pos == len;
                                                            br_if 'backtrack
                                                                s[i] as i32_u != s[pos] as i32_u;
                                                            pos = pos + 1;
                                                            i = i + 1;
                                                            br 'loop;
                                                        }
                                                    }
                                                    br 'continue;
                                                }
                                                // SIMPLEOPT
                                                arg = instr >>u 8;
                                                if pos <u len {
                                                    if
                                                        in_bitset(
                                                            cpool[arg + 1] as &string,
                                                            s[pos] as i32_u
                                                        ) {
                                                        pos = pos + 1;
                                                    }
                                                }
                                                br 'continue;
                                            }
                                            // SIMPLESTAR
                                            arg = instr >>u 8;
                                            set = cpool[arg + 1] as &string;
                                            'loop: loop {
                                                if pos <u len {
                                                    if in_bitset(set, s[pos] as i32_u) {
                                                        pos = pos + 1;
                                                        br 'loop;
                                                    }
                                                }
                                            }
                                            br 'continue;
                                        }
                                        // SIMPLEPLUS
                                        br_if 'prefix_match pos == len;
                                        arg = instr >>u 8;
                                        set = cpool[arg + 1] as &string;
                                        br_if 'backtrack !in_bitset(set, s[pos] as i32_u);
                                        'loop: loop {
                                            pos = pos + 1;
                                            if pos <u len {
                                                br_if 'loop in_bitset(set, s[pos] as i32_u);
                                            }
                                        }
                                        br 'continue;
                                    }
                                    // GOTO
                                    pc = pc + (instr >>s 8);
                                    br 'continue;
                                }
                                // PUSHBACK
                                stack =
                                    {pos| pos_previous: stack, pc: pc + (instr >>s 8), pos: pos };
                                br 'continue;
                            }
                            // SETMARK
                            arg = instr >>u 8;
                            stack =
                                {undo|
                                    undo_previous: stack,
                                    tbl: re_register,
                                    idx: arg,
                                    val: re_register[arg]
                                };
                            re_register[arg] = pos;
                            br 'continue;
                        }
                        // CHECKPROGRESS
                        arg = instr >>u 8;
                        br_if 'backtrack pos == re_register[arg];
                        br 'continue;
                    }
                    // prefix_match
                    br_if 'ACCEPT accept_partial_match;
                }
                // backtrack
                'loop: loop {
                    let p: &pos;
                    let u =
                        'undo: do &stack {
                            p = br_on_cast_fail 'undo &pos br_on_null 'reject stack;
                            pc = p.pc;
                            pos = p.pos;
                            stack = p.pos_previous;
                            br 'continue;
                        } as &undo;
                    u.tbl[u.idx] = u.val;
                    stack = u.undo_previous;
                    br 'loop;
                }
            }
        }
        // ACCEPT
        group_end[0] = pos;
        let res = [block|0 as &i31; (numgroups << 1) + 1];
        i = 0;
        'loop: loop {
            if i <u numgroups {
                j = i << 1;
                if (group_start[i] <s 0) | (group_end[i] <s 0) {
                    res[j + 1] = -1 as &i31;
                    res[j + 2] = -1 as &i31;
                } else {
                    res[j + 1] = group_start[i] as &i31;
                    res[j + 2] = group_end[i] as &i31;
                }
                i = i + 1;
                br 'loop;
            }
        }
        return res;
    }
    // reject
    0 as &i31;
}

data search_forward = "Str.search_forward";

#[export = "re_search_forward"]
fn re_search_forward(re: &eq, vs: &eq, vpos: &eq) -> &eq {
    // ZZZ startchars
    let s = vs as &string;
    let pos = vpos as &i31 as i32_s;
    let len = s.length();
    if pos >u len {
        caml_invalid_argument([string|search_forward @ 0; 18]);
    }
    'loop: loop {
        let res = re_match(re, s, pos, 0);
        if res is &block {
            return res;
        }
        pos = pos + 1;
        br_if 'loop pos <=u len;
    }
    [block|0 as &i31];
}

data search_backward = "Str.search_backward";

#[export = "re_search_backward"]
fn re_search_backward(re: &eq, vs: &eq, vpos: &eq) -> &eq {
    // ZZZ startchars
    let s = vs as &string;
    let pos = vpos as &i31 as i32_s;
    let len = s.length();
    if pos >u len {
        caml_invalid_argument([string|search_backward @ 0; 19]);
    }
    'loop: loop {
        let res = re_match(re, s, pos, 0);
        if res is &block {
            return res;
        }
        pos = pos - 1;
        br_if 'loop pos >=s 0;
    }
    [block|0 as &i31];
}

data string_match = "Str.string_match";

#[export = "re_string_match"]
fn re_string_match(re: &eq, vs: &eq, vpos: &eq) -> &eq {
    // ZZZ startchars
    let s = vs as &string;
    let pos = vpos as &i31 as i32_s;
    let len = s.length();
    if pos >u len {
        caml_invalid_argument([string|string_match @ 0; 16]);
    }
    let res = re_match(re, s, pos, 0);
    if res is &block {
        return res;
    }
    [block|0 as &i31];
}

data string_partial_match = "Str.string_partial_match";

#[export = "re_partial_match"]
fn re_partial_match(re: &eq, vs: &eq, vpos: &eq) -> &eq {
    // ZZZ startchars
    let s = vs as &string;
    let pos = vpos as &i31 as i32_s;
    let len = s.length();
    if pos >u len {
        caml_invalid_argument([string|string_partial_match @ 0; 24]);
    }
    let res = re_match(re, s, pos, 1);
    if res is &block {
        return res;
    }
    [block|0 as &i31];
}

data illegal_backslash = "Str.replace: illegal backslash sequence";
data unmatched_group = "Str.replace: reference to unmatched group";

#[export = "re_replacement_text"]
fn re_replacement_text(vrepl: &eq, vgroups: &eq, vorig: &eq) -> &eq {
    let repl = vrepl as &string;
    let l = repl.length();
    let groups = vgroups as &block;
    let orig = vorig as &string;
    let i: i32;
    let len: i32;
    let c: i32;
    let start: i32;
    let end: i32;
    'loop: loop {
        if i <u l {
            c = repl[i] as i32_u;
            i = i + 1;
            if c != 92 // '\\'
            {
                len = len + 1;
                br 'loop;
            }
            if i == l {
                caml_failwith([string|illegal_backslash @ 0; 39]);
            }
            c = repl[i] as i32_u;
            i = i + 1;
            if c == 92 // '\\'
            {
                len = len + 1;
                br 'loop;
            }
            c = c - 48; // '0'
            if c >u 9 {
                len = len + 2;
                br 'loop;
            }
            c = c << 1;
            if c + 1 >u groups.length() {
                caml_failwith([string|unmatched_group @ 0; 41]);
            }
            start = groups[c + 1] as &i31 as i32_s;
            end = groups[c + 2] as &i31 as i32_s;
            if start == -1 {
                caml_failwith([string|unmatched_group @ 0; 41]);
            }
            len = len + (end - start);
            br 'loop;
        }
    }
    let res = [string|0; len];
    i = 0;
    'loop: loop {
        if i <u l {
            c = repl[i] as i32_u;
            i = i + 1;
            let j: i32;
            if c != 92 // '\\'
            {
                res[j] = c;
                j = j + 1;
                br 'loop;
            }
            c = repl[i] as i32_u;
            i = i + 1;
            if c == 92 // '\\'
            {
                res[j] = c;
                j = j + 1;
                br 'loop;
            }
            c = c - 48; // '0'
            if c >u 9 {
                res[j] = 92;
                res[j + 1] = c + 48;
                j = j + 2;
                br 'loop;
            }
            c = c << 1;
            if c + 1 >u groups.length() {
                caml_failwith([string|unmatched_group @ 0; 41]);
            }
            start = groups[c + 1] as &i31 as i32_s;
            end = groups[c + 2] as &i31 as i32_s;
            len = end - start;
            res.copy(j, orig, start, len);
            j = j + len;
            br 'loop;
        }
    }
    res;
}

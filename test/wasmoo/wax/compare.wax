#[import = ("bindings", "equals")]
fn equals(&?any, &?any) -> i32;
#[import = ("obj", "forward_tag")]
const forward_tag: i32;
#[import = ("obj", "object_tag")]
const object_tag: i32;
#[import = ("obj", "double_array_tag")]
const double_array_tag: i32;
#[import = ("obj", "caml_obj_tag")]
fn caml_obj_tag(&eq) -> &eq;
#[import = ("obj", "caml_is_closure")]
fn caml_is_closure(&eq) -> i32;
#[import = ("obj", "null")]
const null_value: &eq;
#[import = ("fail", "caml_invalid_argument")]
fn caml_invalid_argument(&eq);
#[import = ("effect", "caml_is_continuation")]
fn caml_is_continuation(&eq) -> i32;
#[import = ("string", "caml_string_compare")]
fn caml_string_compare(&eq, &eq) -> &eq;
#[import = ("jsstring", "jsstring_test")]
fn jsstring_test(&?any) -> i32;
#[import = ("jsstring", "jsstring_compare")]
fn jsstring_compare(&?any, &?any) -> i32;

type block = [mut &eq];
type bytes = [mut i8];
type float = { f: f64 };
type float_array = [mut f64];
type js = { js: &?any };

type int_array = [mut i32];
type block_array = [mut &block];
type compare_stack = {
    pos: mut i32, // position in stack
    v1: &block_array, // first value
    v2: &block_array, // second value
    vpos: &int_array
}; // position in value

type compare = fn(&eq, &eq, i32) -> i32;
type hash = fn(&eq) -> i32;
type fixed_length = { bsize_32: i32, bsize_64: i32 };
type serialize = fn(&eq, &eq) -> (i32, i32);
type deserialize = fn(&eq) -> (&eq, i32);
type dup = fn(&eq) -> &eq;
type custom_operations = {
    id: &bytes,
    compare: &?compare,
    compare_ext: &?compare,
    hash: &?hash,
    fixed_length: &?fixed_length,
    serialize: &?serialize,
    deserialize: &?deserialize,
    dup: &?dup
};
type custom = open { ops: &custom_operations };

const dummy_block: &block = [0 as &i31; 0];

const default_compare_stack = { pos: -1, v1: [dummy_block; 8], v2: [dummy_block; 8], vpos: [0; 8] };

fn compare_stack_is_not_empty(stack: &compare_stack) -> i32 {
    stack.pos >=s 0;
}

fn pop_compare_stack(stack: &compare_stack) -> (&eq, &eq) {
    let i = stack.pos;
    let p = stack.vpos[i];
    let p' = p + 1;
    stack.vpos[i] = p';
    let v1 = stack.v1[i];
    let v2 = stack.v2[i];
    if p' == v1.length() {
        stack.v1[i] = dummy_block;
        stack.v2[i] = dummy_block;
        stack.pos = i - 1;
    }
    v1[p];
    v2[p];
}

fn push_compare_stack(stack: &compare_stack, v1: &block, v2: &block, p: i32) -> &compare_stack {
    let i = stack.pos + 1;
    let len = stack.v1.length();
    if i >=u len {
        let len' = len << 1;
        let stack' = { pos: i, v1: [dummy_block; len'], v2: [dummy_block; len'], vpos: [0; len'] };
        stack'.v1.copy(0, stack.v1, 0, len);
        stack'.v2.copy(0, stack.v2, 0, len);
        stack'.vpos.copy(0, stack.vpos, 0, len);
        stack = stack';
    }
    stack.pos = i;
    stack.v1[i] = v1;
    stack.v2[i] = v2;
    stack.vpos[i] = p;
    stack;
}

#[export = "unordered"]
const unordered = 0x80000000;

fn compare_bytes(s1: &bytes, s2: &bytes) -> i32 {
    if s1 == s2 {
        return 0;
    }
    let l1 = s1.length();
    let l2 = s2.length();
    let len = l1 <=u l2?l1:l2;
    let i = 0;
    while i <s len : (i += 1) {
        let c1 = s1[i] as i32_u;
        let c2 = s2[i] as i32_u;
        if c1 != c2 {
            if c1 <=u c2 {
                return -1;
            } else {
                return 1;
            }
        }
    }
    l1 - l2;
}

fn clear_compare_stack() {
    // clear stack (to avoid memory leaks)
    let stack = default_compare_stack;
    let n = stack.pos;
    if n >=s 0 {
        n += 1;
        stack.v1.fill(0, dummy_block, n);
        stack.v2.fill(0, dummy_block, n);
    }
}

fn compare_val(v1: &eq, v2: &eq, total: i32) -> i32 {
    let stack = default_compare_stack;
    stack.pos = -1;
    let res = do_compare_val(stack, v1, v2, total);
    clear_compare_stack();
    res;
}

const abstract_value = "compare: abstract value";
const functional_value = "compare: functional value";
const continuation_value = "compare: continuation value";

fn do_compare_val(stack: &compare_stack, v1: &eq, v2: &eq, total: i32) -> i32 {
    'loop: loop {
        'next_item: do {
            if total {
                br_if 'next_item v1 == v2;
            }
            if v1 == null_value {
                if v2 == null_value {
                    return 0;
                } else {
                    return -1;
                }
            }
            if v2 == null_value {
                return 1;
            }
            let b2: &block;
            let t2: i32;
            let c2: &custom;
            let res: i32;
            match v1 {
                i1: &i31 => {
                    br_if 'next_item v1 == v2;
                    match v2 {
                        i2: &i31 => {
                            // v1 and v2 are both integers
                            return i1 as i32_s - i2 as i32_s;
                        }
                        _ => {
                            // check for forward tag
                            _ =
                                'v2_not_forward: do {
                                    b2 = br_on_cast_fail 'v2_not_forward &block v2;
                                    t2 = b2[0] as i32_u;
                                    if t2 == forward_tag {
                                        v2 = b2[1];
                                        br 'loop;
                                    }
                                    1 as &i31;
                                };
                            'v2_not_comparable: do {
                                _ =
                                    'v2_not_custom: do {
                                        c2 = br_on_cast_fail 'v2_not_custom &custom v2;
                                        res =
                                            (br_on_null 'v2_not_comparable c2.ops.compare_ext)(
                                                v1,
                                                v2,
                                                total,
                                            );
                                        br_if 'next_item !res;
                                        return res;
                                    };
                            }
                            // v1 long < v2 block
                            return -1;
                        }
                    }
                }
                _ => {
                    let b1: &block;
                    let t1: i32;
                    let c1: &custom;
                    if v2 is &i31 {
                        // check for forward tag
                        _ =
                            'v1_not_forward: do {
                                b1 = br_on_cast_fail 'v1_not_forward &block v1;
                                t1 = b1[0] as i32_u;
                                if t1 == forward_tag {
                                    v1 = b1[1];
                                    br 'loop;
                                }
                                1 as &i31;
                            };
                        'v1_not_comparable: do {
                            _ =
                                'v1_not_custom: do {
                                    c1 = br_on_cast_fail 'v1_not_custom &custom v1;
                                    res =
                                        (br_on_null 'v1_not_comparable c1.ops.compare_ext)(
                                            v1,
                                            v2,
                                            total,
                                        );
                                    br_if 'next_item !res;
                                    return res;
                                };
                        }
                        // v1 block > v1 long
                        return 1;
                    }
                    _ =
                        'heterogeneous: do &eq {
                            let s1: i32;
                            let s2: i32;
                            _ =
                                'v1_not_block: do {
                                    b1 = br_on_cast_fail 'v1_not_block &block v1;
                                    t1 = b1[0] as i32_u;
                                    b2 = br_on_cast_fail 'heterogeneous &block v2;
                                    t2 = b2[0] as i32_u;
                                    _ = br_if 'heterogeneous (0 as &i31, t1 != t2);
                                    // forward tag
                                    if t1 == forward_tag {
                                        v1 = b1[1];
                                        v2 = b2[1];
                                        br 'loop;
                                    }
                                    if t1 == object_tag {
                                        v1 = b1[2];
                                        v2 = b2[2];
                                        br_if 'next_item v1 == v2;
                                        return v1 as i32_s - v2 as i32_s;
                                    }
                                    s1 = b1.length();
                                    s2 = b2.length();
                                    // compare size first
                                    if s1 != s2 {
                                        return s1 - s2;
                                    }
                                    br_if 'next_item s1 == 1;
                                    if s1 >u 2 {
                                        stack = push_compare_stack(stack, b1, b2, 2);
                                    }
                                    v1 = b1[1];
                                    v2 = b2[1];
                                    br 'loop;
                                };
                            let f1: f64;
                            let f2: f64;
                            match v1 {
                                fl1: &float => {
                                    f1 = fl1.f;
                                    f2 = (br_on_cast_fail 'heterogeneous &float v2).f;
                                    if f1 < f2 {
                                        return -1;
                                    }
                                    if f1 > f2 {
                                        return 1;
                                    }
                                    if f1 != f2 {
                                        if !total {
                                            return unordered;
                                        }
                                        if f1 == f1 {
                                            return 1;
                                        }
                                        if f2 == f2 {
                                            return -1;
                                        }
                                    }
                                    br 'next_item;
                                }
                                str1: &bytes => {
                                    let str2 = br_on_cast_fail 'heterogeneous &bytes v2;
                                    res = compare_bytes(str1, str2);
                                    br_if 'next_item !res;
                                    return res;
                                }
                                fa1: &float_array => {
                                    let fa2 = br_on_cast_fail 'heterogeneous &float_array v2;
                                    s1 = fa1.length();
                                    s2 = fa2.length();
                                    if s1 != s2 {
                                        return s1 - s2;
                                    }
                                    let i = 0;
                                    while i <s s1 : (i += 1) {
                                        f1 = fa1[i];
                                        f2 = fa2[i];
                                        if f1 < f2 {
                                            return -1;
                                        }
                                        if f1 > f2 {
                                            return 1;
                                        }
                                        if f1 != f2 {
                                            if !total {
                                                return unordered;
                                            }
                                            if f1 == f1 {
                                                return 1;
                                            }
                                            if f2 == f2 {
                                                return -1;
                                            }
                                        }
                                    }
                                    br 'next_item;
                                }
                                _ => {
                                    _ =
                                        'v1_not_custom: do {
                                            c1 = br_on_cast_fail 'v1_not_custom &custom v1;
                                            c2 = br_on_cast_fail 'heterogeneous &custom v2;
                                            if c1.ops != c2.ops {
                                                return
                                                    caml_string_compare(c1.ops.id, c2.ops.id)
                                                        as i32_s;
                                            }
                                            'not_comparable: do {
                                                res =
                                                    (br_on_null 'not_comparable c1.ops.compare)(
                                                        v1,
                                                        v2,
                                                        total,
                                                    );
                                                br_if 'next_item !res;
                                                return res;
                                            }
                                            clear_compare_stack();
                                            caml_invalid_argument(abstract_value);
                                            0 as &i31;
                                        };
                                    let jsv: &js;
                                    let js1: &?any;
                                    let js2: &?any;
                                    #[if(not(wasi))]
                                    {
                                        _ =
                                            'v1_not_js: do {
                                                jsv = br_on_cast_fail 'v1_not_js &js v1;
                                                js1 = jsv.js;
                                                js2 = (br_on_cast_fail 'heterogeneous &js v2).js;
                                                'not_jsstring: do {
                                                    br_if 'not_jsstring !jsstring_test(js1);
                                                    br_if 'not_jsstring !jsstring_test(js2);
                                                    res = jsstring_compare(js1, js2);
                                                    br_if 'next_item !res;
                                                    return res;
                                                }
                                                // We cannot order two JavaScript objects,
                                                // but we can tell whether they are equal or not
                                                if !total {
                                                    br_if 'next_item equals(js1, js2);
                                                    return unordered;
                                                }
                                                br 'heterogeneous 0 as &i31;
                                            };
                                    }
                                    if caml_is_closure(v1) {
                                        _ = br_if 'heterogeneous (0 as &i31, !caml_is_closure(v2));
                                        clear_compare_stack();
                                        caml_invalid_argument(functional_value);
                                    }
                                    if caml_is_continuation(v1) {
                                        _ =
                                            br_if 'heterogeneous
                                                (0 as &i31, !caml_is_continuation(v2));
                                        clear_compare_stack();
                                        caml_invalid_argument(continuation_value);
                                    }
                                    0 as &i31;
                                }
                            }
                        }; // fall through
                    // heterogeneous comparison
                    t1 = caml_obj_tag(v1) as i32_u;
                    t2 = caml_obj_tag(v2) as i32_u;
                    if t1 == forward_tag {
                        v1 = (v1 as &block)[1];
                        br 'loop;
                    }
                    if t2 == forward_tag {
                        v2 = (v2 as &block)[1];
                        br 'loop;
                    }
                    res = t1 - t2;
                    if !res {
                        clear_compare_stack();
                        caml_invalid_argument(abstract_value);
                    }
                    return res;
                }
            }
        }
        if compare_stack_is_not_empty(stack) {
            pop_compare_stack(stack);
            v2 = _;
            v1 = _;
            br 'loop;
        }
    }
    0;
}

#[export = "caml_compare"]
fn caml_compare(v1: &eq, v2: &eq) -> i32 {
    let res = compare_val(v1, v2, 1);
    if res <s 0 {
        return -1;
    }
    if res >s 0 {
        return 1;
    }
    0;
}

#[export = "caml_equal"]
fn caml_equal(v1: &eq, v2: &eq) -> i32 {
    !compare_val(v1, v2, 0);
}

#[export = "caml_notequal"]
fn caml_notequal(v1: &eq, v2: &eq) -> i32 {
    0 != compare_val(v1, v2, 0);
}

#[export = "caml_lessthan"]
fn caml_lessthan(v1: &eq, v2: &eq) -> i32 {
    let res = compare_val(v1, v2, 0);
    (res <s 0) & (res != unordered);
}

#[export = "caml_lessequal"]
fn caml_lessequal(v1: &eq, v2: &eq) -> i32 {
    let res = compare_val(v1, v2, 0);
    (res <=s 0) & (res != unordered);
}

#[export = "caml_greaterthan"]
fn caml_greaterthan(v1: &eq, v2: &eq) -> i32 {
    0 <s compare_val(v1, v2, 0);
}

#[export = "caml_greaterequal"]
fn caml_greaterequal(v1: &eq, v2: &eq) -> i32 {
    0 <=s compare_val(v1, v2, 0);
}

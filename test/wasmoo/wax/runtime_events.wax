#[export = "caml_runtime_events_free_cursor"]
fn caml_runtime_events_free_cursor(x: &eq) -> &eq { 0 as &i31; }

#[export = "caml_runtime_events_read_poll"]
fn caml_runtime_events_read_poll(x: &eq, x_2: &eq, x_3: &eq) -> &eq {
    0 as &i31;
}

#[export = "caml_ml_runtime_events_path"]
fn caml_ml_runtime_events_path(x: &eq) -> &eq { 0 as &i31; }

type block = [mut &eq];

let caml_custom_event_index: i32 = 0;

#[export = "caml_runtime_events_user_register"]
fn caml_runtime_events_user_register(evname: &eq, evtag: &eq, evtype: &eq) ->
&eq {
    caml_custom_event_index = caml_custom_event_index + 1;
    [block|0 as &i31, caml_custom_event_index as &i31, evname, evtag, evtype];
}

#[export = "caml_runtime_events_user_resolve"]
fn caml_runtime_events_user_resolve(x: &eq, x_2: &eq, x_3: &eq) -> &eq {
    0 as &i31;
}

#[export = "caml_runtime_events_start"]
fn caml_runtime_events_start(x: &eq) -> &eq { 0 as &i31; }

#[export = "caml_runtime_events_pause"]
fn caml_runtime_events_pause(x: &eq) -> &eq { 0 as &i31; }

#[export = "caml_runtime_events_resume"]
fn caml_runtime_events_resume(x: &eq) -> &eq { 0 as &i31; }

#[export = "caml_ml_runtime_events_are_active"]
fn caml_ml_runtime_events_are_active(x: &eq) -> &eq { 0 as &i31; }


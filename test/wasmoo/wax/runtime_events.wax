type block = [mut &eq];

let caml_custom_event_index = 0;

#[export]
fn caml_runtime_events_user_register(evname: &eq, evtag: &eq, evtype: &eq) -> &eq {
    caml_custom_event_index += 1;
    // The record is { id; name; typ; tag } -- typ comes before tag.
    [block|0 as &i31, caml_custom_event_index as &i31, evname, evtype, evtag];
}

#[if(ocaml_version >= (5, 2, 0))]
#[export]
fn caml_runtime_events_user_write(&eq, &eq, &eq) -> &eq {
    0 as &i31;
}
#[else]
#[export]
fn caml_runtime_events_user_write(&eq, &eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_runtime_events_user_resolve(&eq, &eq, &eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_ml_runtime_events_start(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_ml_runtime_events_pause(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_ml_runtime_events_resume(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_ml_runtime_events_are_active(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_ml_runtime_events_create_cursor(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_ml_runtime_events_free_cursor(&eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_ml_runtime_events_read_poll(&eq, &eq, &eq) -> &eq {
    0 as &i31;
}

#[export]
fn caml_ml_runtime_events_path(&eq) -> &eq {
    0 as &i31;
}

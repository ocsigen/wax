import "float32" const float32_ops: &custom_operations;
import "int32" { const int32_ops: &custom_operations; const nativeint_ops: &custom_operations; }
import "int64" const int64_ops: &custom_operations;
import "bigarray" const bigarray_ops: &custom_operations;
import "nat" const nat_ops: &custom_operations;
import "string" fn caml_bytes_equal(&eq, &eq) -> &eq;

type bytes = [mut i8];
type compare = fn(&eq, &eq, i32) -> i32;
type hash = fn(&eq) -> i32;
type fixed_length = { bsize_32: i32, bsize_64: i32 };
type serialize = fn(&eq, &eq) -> (i32, i32);
type deserialize = fn(&eq) -> (&eq, i32);
type dup = fn(&eq) -> &eq;
type custom_operations = {
    id: &bytes,
    compare: &?compare,
    compare_ext: &?compare,
    hash: &?hash,
    fixed_length: &?fixed_length,
    serialize: &?serialize,
    deserialize: &?deserialize,
    dup: &?dup
};
type custom = open { ops: &custom_operations };

type custom_with_id: custom = open { .., id: i64 };

#[export]
fn caml_is_custom(v: &eq) -> i32 {
    v is &custom;
}

#[export]
fn caml_dup_custom(v: &eq) -> &eq {
    ('custom: do {
         _ = br_on_cast 'custom &custom v;
         unreachable;
     }.ops.dup!)(
        v,
    );
}

#[export]
fn custom_compare_id(v1: &eq, v2: &eq, i32) -> i32 {
    let i1 = (v1 as &custom_with_id).id;
    let i2 = (v2 as &custom_with_id).id;
    (i1 >s i2) - (i1 <s i2);
}

#[export]
fn custom_hash_id(v: &eq) -> i32 {
    (v as &custom_with_id).id as i32;
}

let next_id: i64 = 0;

#[export]
fn custom_next_id() -> i64 {
    let id = next_id;
    next_id = id + 1;
    id;
}

type custom_operations_list = { ops: &custom_operations, next: &?custom_operations_list };

let custom_operations: &?custom_operations_list = null;

#[export]
fn caml_register_custom_operations(ops: &custom_operations) {
    custom_operations = { ops, next: custom_operations };
}

#[export]
fn caml_find_custom_operations(id: &bytes) -> &?custom_operations {
    'not_found: do {
        let l = br_on_null 'not_found custom_operations;
        'loop: loop {
            if caml_bytes_equal(id, l.ops.id) as i32_u {
                return l.ops;
            }
            l = br_on_null 'not_found l.next;
            br 'loop;
        }
    }
    null;
}

let initialized = 0;

#[export]
fn caml_init_custom_operations() {
    if initialized {
        return;
    }
    caml_register_custom_operations(int32_ops);
    caml_register_custom_operations(nativeint_ops);
    caml_register_custom_operations(int64_ops);
    caml_register_custom_operations(bigarray_ops);
    caml_register_custom_operations(float32_ops);
    caml_register_custom_operations(nat_ops);
    initialized = 1;
}

const empty_custom = "";

#[export]
fn caml_custom_identifier(v: &eq) -> &eq {
    _ =
        'not_custom: do {
            return (br_on_cast_fail 'not_custom &custom v).ops.id;
        };
    return empty_custom;
}

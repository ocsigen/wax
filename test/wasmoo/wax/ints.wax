#[import = ("fail", "caml_failwith")]
fn caml_failwith(&eq);
#[import = ("fail", "caml_invalid_argument")]
fn caml_invalid_argument(&eq);

type bytes = [mut i8];

#[export]
fn caml_format_int(v: &eq, n: &eq) -> &eq {
    become format_int(v, n as i32_s, 1);
}

#[export]
fn parse_sign_and_base(s: &bytes) -> (i32, i32, i32, i32) {
    let i = 0;
    let len = s.length();
    let signedness = 1;
    let sign = 1;
    let base = 10;
    let c: i32;
    if len != 0 {
        c = s[0] as i32_u;
        if c == '-' {
            sign = -1;
            i = 1;
        } else {
            if c == '+' {
                i = 1;
            }
        }
    }
    if i + 1 <s len {
        if s[i] as i32_u == 48 {
            c = s[i + 1] as i32_u;
            if (c == 'X') | (c == 'x') {
                base = 16;
                signedness = 0;
                i += 2;
            } else {
                if (c == 'O') | (c == 'o') {
                    base = 8;
                    signedness = 0;
                    i += 2;
                } else {
                    if (c == 'B') | (c == 'b') {
                        base = 2;
                        signedness = 0;
                        i += 2;
                    } else {
                        if (c == 'U') | (c == 'u') {
                            signedness = 0;
                            i += 2;
                        }
                    }
                }
            }
        }
    }
    i;
    signedness;
    sign;
    base;
}

#[export]
fn parse_digit(c: i32) -> i32 {
    if (c >=u '0') & (c <=u '9') {
        return c - '0';
    }
    if (c >=u 'A') & (c <=u 'Z') {
        return c - 55;
    }
    if (c >=u 'a') & (c <=u 'z') {
        return c - 87;
    }
    return -1;
}

#[export]
fn parse_int(v: &eq, nbits: i32, errmsg: &eq) -> i32 {
    let s = v as &bytes;
    let len = s.length();
    if !len {
        caml_failwith(errmsg);
    }
    let (i, signedness, sign, base) = parse_sign_and_base(s);
    let threshold = -1 /u base;
    if i >=s len {
        caml_failwith(errmsg);
    }
    let d = parse_digit(s[i] as i32_u);
    if d >=u base {
        caml_failwith(errmsg);
    }
    let res = d;
    'loop: loop {
        i += 1;
        if i <s len {
            let c = s[i] as i32_u;
            br_if 'loop c == '_';
            d = parse_digit(c);
            if d >=u base {
                caml_failwith(errmsg);
            }
            if res >u threshold {
                caml_failwith(errmsg);
            }
            res = res * base + d;
            if res <u d {
                caml_failwith(errmsg);
            }
            br 'loop;
        }
    }
    if signedness {
        threshold = 1 << (nbits - 1);
        if sign >s 0 {
            if res >=u threshold {
                caml_failwith(errmsg);
            }
        } else {
            if res >u threshold {
                caml_failwith(errmsg);
            }
        }
    } else {
        if (nbits <u 32) & (res >=u 1 << nbits) {
            caml_failwith(errmsg);
        }
    }
    if sign <s 0 {
        res = 0 - res;
    }
    res;
}

const INT_ERRMSG = "int_of_string";

#[export]
fn caml_int_of_string(v: &eq) -> &eq {
    parse_int(v, 31, INT_ERRMSG) as &i31;
}

const INT8_ERRMSG = "Int8.of_string";

#[export]
fn caml_int8_of_string(v: &eq) -> &eq {
    parse_int(v, 8, INT8_ERRMSG).extend8_s() as &i31;
}

const INT16_ERRMSG = "Int16.of_string";

#[export]
fn caml_int16_of_string(v: &eq) -> &eq {
    parse_int(v, 16, INT16_ERRMSG).extend16_s() as &i31;
}

#[export]
fn caml_bswap16(vx: &eq) -> &eq {
    let x = vx as i32_s;
    ((x & 0xFF) << 8 | x >>u 8 & 0xFF) as &i31;
}

type chars = [i8];

#[export]
const lowercase_hex_table: &chars = "0123456789abcdef";

#[export]
const uppercase_hex_table: &chars = "0123456789ABCDEF";

fn format_int_default(d: i32) -> &eq {
    let negative: i32;
    let i: i32;
    if d <s 0 {
        negative = 1;
        i = 1;
        d = 0 - d;
    }
    let n = d;
    'count: loop {
        i += 1;
        n /u= 10;
        br_if 'count n;
    }
    let s: &bytes = [0; i];
    'write: loop {
        i -= 1;
        s[i] = '0' + d %u 10;
        d /u= 10;
        br_if 'write d;
    }
    if negative {
        s[0] = '-';
    }
    s;
}

const format_error = "format_int: bad format";

#[export]
fn parse_int_format(s: &bytes) -> (i32, i32, i32, i32, i32) {
    let len = s.length();
    let i = 1;
    let sign_style: i32;
    let alternate: i32;
    let base: i32;
    let signed: i32;
    let uppercase: i32;
    'return: do {
        'bad_format: do {
            br_if 'bad_format len <u 2;
            br_if 'bad_format s[0] as i32_u != '%';
            let c = s[1] as i32_u;
            if c == '+' {
                sign_style = 1;
                i += 1;
            }
            if c == ' ' {
                sign_style = 2;
                i += 1;
            }
            if c == '#' {
                alternate = 1;
                i += 1;
            }
            br_if 'bad_format i == len;
            c = s[i] as i32_u;
            if (c == 'L') | (c == 'l') | (c == 'n') {
                i += 1;
                br_if 'bad_format i == len;
                c = s[i] as i32_u;
            }
            br_if 'bad_format i + 1 != len;
            if (c == 'd') | (c == 'i') {
                base = 10;
                signed = 1;
            } else {
                if c == 'u' {
                    base = 10;
                } else {
                    if c == 'x' {
                        base = 16;
                    } else {
                        if c == 'X' {
                            base = 16;
                            uppercase = 1;
                        } else {
                            if c == 'o' {
                                base = 8;
                            } else {
                                br 'bad_format;
                            }
                        }
                    }
                }
            }
            br 'return;
        }
        caml_invalid_argument(format_error);
    }
    sign_style;
    alternate;
    signed;
    base;
    uppercase;
}

#[export]
fn format_int(vs: &eq, d: i32, small: i32) -> &eq {
    let s = vs as &bytes;
    if s.length() == 2 {
        if s[1] as i32_u == 'd' {
            become format_int_default(d);
        }
    }
    let (sign_style, alternate, signed, base, uppercase) = parse_int_format(s);
    let negative: i32;
    if d <s 0 {
        if signed {
            negative = 1;
            d = 0 - d;
        } else {
            if small {
                d &= 0x7fffffff;
            }
        }
    }
    let n = d;
    let i: i32;
    'count: loop {
        i += 1;
        n /u= base;
        br_if 'count n;
    }
    if negative | sign_style {
        i += 1;
    }
    if alternate {
        if d {
            if base == 16 {
                i += 2;
            }
            if base == 8 {
                i += 1;
            }
        }
    }
    let chars = uppercase?uppercase_hex_table:lowercase_hex_table;
    s = [0; i];
    'write: loop {
        i -= 1;
        s[i] = chars[d %u base] as i32_u;
        d /u= base;
        br_if 'write d;
    }
    if negative {
        s[0] = '-';
    } else {
        if sign_style {
            if sign_style == 1 {
                s[0] = '+';
            } else {
                s[0] = ' ';
            }
        }
    }
    // The "#" flag only prefixes octal/hex; for base 10 it is ignored (as
    // in C). Guarding on base here also stops the "0" from overwriting the
    // sign, since the digit-count phase above only reserves prefix room for
    // base 8/16.
    if alternate & (base != 10) {
        if i {
            s[0] = '0';
            if base == 16 {
                s[1] = uppercase?'X':'x';
            }
        }
    }
    s;
}

#[export = "caml_ba_uint8_set64"]
fn caml_ba_uint8_set64(vba: &eq, i: &eq, d: i64) -> &eq {
    let ba = vba as &bigarray;
    let data_2 = ba.ba_data;
    let p = i as &i31 as i32_s;
    if p <s 0 {
        caml_bound_error();
    }
    if p + 7 >=u ba.ba_dim[0] {
        caml_bound_error();
    }
    ta_set32_ui8(data_2, p, d as i32);
    ta_set32_ui8(data_2, p + 4, (d >>u 32) as i32);
    0 as &i31;
}

#[export = "caml_string_of_array"]
#[export = "caml_bytes_of_array"]
fn caml_string_of_array(x: &eq) -> &eq {
    // used to convert a typed array to a string
    let a = (unwrap(x) as &?extern)!;
    let len = ta_length(a);
    let s: &string = [0; len];
    ta_blit_to_string(a, 0, s, 0, len);
    s;
}

#[export = "caml_uint8_array_of_string"]
#[export = "caml_uint8_array_of_bytes"]
fn caml_uint8_array_of_string(x: &eq) -> &eq {
    // Convert a string to a typed array
    let s = x as &string;
    let len = s.length();
    let ta =
        ta_create(
            3, // Uint8Array
            len,
        );
    ta_blit_from_string(s, 0, ta, 0, len);
    wrap(ta as &any);
}

#[export = "caml_ba_get_kind"]
fn caml_ba_get_kind(x: &eq) -> i32 {
    (x as &bigarray).ba_kind as i32_u;
}

#[export = "caml_ba_get_layout"]
fn caml_ba_get_layout(x: &eq) -> i32 {
    (x as &bigarray).ba_layout as i32_u;
}

#[export = "caml_ba_get_data"]
fn caml_ba_get_data(x: &eq) -> &extern {
    (x as &bigarray).ba_data;
}

#[export = "caml_ba_set_data"]
fn caml_ba_set_data(x: &eq, x_2: &extern) {
    (x as &bigarray).ba_data = x_2;
}

#[export = "caml_ba_get_dim"]
fn caml_ba_get_dim(x: &eq) -> &int_array {
    (x as &bigarray).ba_dim;
}

#[export = "caml_ba_alloc"]
fn caml_ba_alloc(kind: i32, layout: i32, num_dims: i32, data_2: &extern, dim: &int_array) -> &eq {
    {
        f: bigarray_ops,
        ba_data: data_2,
        ba_dim: dim,
        ba_num_dims: num_dims,
        ba_kind: kind,
        ba_layout: layout,
    };
}

#[export = "string_set"]
fn string_set(s: &?extern, i: i32, v: i32) {
    (s as &?any as &?string)[i] = v;
}

#[export = "string_get"]
fn string_get(s: &?extern, i: i32) -> i32 {
    (s as &?any as &?string)[i] as i32_u;
}

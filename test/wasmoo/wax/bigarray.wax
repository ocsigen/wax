fn caml_deserialize_sint_1(&eq) -> i32;
#[import = ("marshal", "caml_deserialize_uint_2")]
fn caml_deserialize_uint_2(&eq) -> i32;
#[import = ("marshal", "caml_deserialize_sint_2")]
fn caml_deserialize_sint_2(&eq) -> i32;

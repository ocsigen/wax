#[import = ("ints", "parse_sign_and_base")]
fn parse_sign_and_base(&bytes) -> (i32, i32, i32, i32);
#[import = ("ints", "parse_digit")]
fn parse_digit(i32) -> i32;
#[import = ("ints", "parse_int_format")]
fn parse_int_format(&bytes) -> (i32, i32, i32, i32, i32);
#[import = ("fail", "caml_failwith")]
fn caml_failwith(&eq);
#[import = ("marshal", "caml_serialize_int_8")]
fn caml_serialize_int_8(&eq, i64);
#[import = ("marshal", "caml_deserialize_int_8")]
fn caml_deserialize_int_8(&eq) -> i64;
#[import = ("ints", "lowercase_hex_table")]
const lowercase_hex_table: &chars;
#[import = ("ints", "uppercase_hex_table")]
const uppercase_hex_table: &chars;

type bytes = [mut i8];
type compare = fn(&eq, &eq, i32) -> i32;
type hash = fn(&eq) -> i32;
type fixed_length = { bsize_32: i32, bsize_64: i32 };
type serialize = fn(&eq, &eq) -> (i32, i32);
type deserialize = fn(&eq) -> (&eq, i32);
type dup = fn(&eq) -> &eq;
type custom_operations = {
    id: &bytes,
    compare: &?compare,
    compare_ext: &?compare,
    hash: &?hash,
    fixed_length: &?fixed_length,
    serialize: &?serialize,
    deserialize: &?deserialize,
    dup: &?dup
};
type custom = open { ops: &custom_operations };

#[export = "int64_ops"]
const int64_ops =
    {
        id: "_j",
        compare: int64_cmp,
        compare_ext: null,
        hash: int64_hash,
        fixed_length: { bsize_32: 8, bsize_64: 8 },
        serialize: int64_serialize,
        deserialize: int64_deserialize,
        dup: int64_dup,
    };

type int64: custom = { ops: &custom_operations, i64: i64 };

fn int64_cmp(v1: &eq, v2: &eq, i32) -> i32 {
    let i1 = (v1 as &int64).i64;
    let i2 = (v2 as &int64).i64;
    (i1 >s i2) - (i1 <s i2);
}

fn int64_hash(v: &eq) -> i32 {
    let i = (v as &int64).i64;
    i as i32 ^ (i >>u 32) as i32;
}

fn int64_serialize(s: &eq, v: &eq) -> (i32, i32) {
    caml_serialize_int_8(s, (v as &int64).i64);
    8;
    8;
}

fn int64_deserialize(s: &eq) -> (&eq, i32) {
    { ops: int64_ops, i64: caml_deserialize_int_8(s) };
    8;
}

fn int64_dup(v: &eq) -> &eq {
    { ops: int64_ops, i64: (v as &int64).i64 };
}

#[export = "caml_copy_int64"]
fn caml_copy_int64(i: i64) -> &eq {
    { ops: int64_ops, i64: i };
}

#[export = "Int64_val"]
fn Int64_val(v: &eq) -> i64 {
    (v as &int64).i64;
}

#[export = "caml_int64_bswap"]
fn caml_int64_bswap(i: i64) -> i64 {
    (i & 0x000000FF000000FF).rotr(8) | (i & 0x0000FF000000FF00).rotr(24)
        | ((i & 0x00FF000000FF0000).rotl(24) | (i & 0xFF000000FF000000).rotl(8));
}

#[export = "caml_int64_compare"]
fn caml_int64_compare(i1: i64, i2: i64) -> i32 {
    (i1 >s i2) - (i1 <s i2);
}

const INT64_ERRMSG = "Int64.of_string";

// Parse a sequence of digits into an i64 as dicted by $base,
// $signedness and $sign. The sequence is read in $s starting from $i.
// In case of failure raise [Failure $errmsg].
// Used by $caml_int64_of_string below and by $caml_uint64_of_string in
// package "integers".
#[export = "caml_i64_of_digits"]
fn caml_i64_of_digits(
    base: i32,
    signedness: i32,
    sign: i32,
    s: &bytes,
    i: i32,
    errmsg: &eq,
) -> i64 {
    let len = s.length();
    if i >=s len {
        caml_failwith(errmsg);
    }
    let threshold = -1 /u base as i64_u;
    let d = parse_digit(s[i] as i32_u);
    if d >=u base {
        caml_failwith(errmsg);
    }
    let res = d as i64_u;
    'loop: loop {
        i += 1;
        if i <s len {
            let c = s[i] as i32_u;
            br_if 'loop c == '_';
            d = parse_digit(c);
            if d >=u base {
                caml_failwith(errmsg);
            }
            if res >u threshold {
                caml_failwith(errmsg);
            }
            res = res * base as i64_u + d as i64_u;
            if res <u d as i64_u {
                caml_failwith(errmsg);
            }
            br 'loop;
        }
    }
    if signedness {
        if sign >s 0 {
            if res >=u 1 << 63 {
                caml_failwith(errmsg);
            }
        } else {
            if res >u 1 << 63 {
                caml_failwith(errmsg);
            }
        }
    }
    if sign <s 0 {
        res = 0 - res;
    }
    res;
}

#[export = "caml_int64_of_string"]
fn caml_int64_of_string(v: &eq) -> &eq {
    let s = v as &bytes;
    let (i, signedness, sign, base) = parse_sign_and_base(s);
    become caml_copy_int64(caml_i64_of_digits(base, signedness, sign, s, i, INT64_ERRMSG));
}

fn format_int64_default(d: i64) -> &eq {
    let negative: i32;
    let i: i32;
    if d <s 0 {
        negative = 1;
        i = 1;
        d = 0 - d;
    }
    let n = d;
    'count: loop {
        i += 1;
        n /u= 10;
        br_if 'count n != 0;
    }
    let s: &bytes = [0; i];
    'write: loop {
        i -= 1;
        s[i] = '0' + (d %u 10) as i32;
        d /u= 10;
        br_if 'write d != 0;
    }
    if negative {
        s[0] = '-';
    }
    s;
}

type chars = [i8];

#[export = "caml_int64_format"]
fn caml_int64_format(vs: &eq, vd: &eq) -> &eq {
    let s = vs as &bytes;
    let d = (vd as &int64).i64;
    if s.length() == 2 {
        if s[1] as i32_u == 'd' {
            become format_int64_default(d);
        }
    }
    let (sign_style, alternate, signed, format_3, uppercase) = parse_int_format(s);
    let base = format_3 as i64_u;
    let negative: i32;
    if signed & (d <s 0) {
        negative = 1;
        d = 0 - d;
    }
    let n = d;
    let i: i32;
    'count: loop {
        i += 1;
        n /u= base;
        br_if 'count n != 0;
    }
    if negative | sign_style {
        i += 1;
    }
    if alternate {
        if d != 0 {
            if base == 16 {
                i += 2;
            }
            if base == 8 {
                i += 1;
            }
        }
    }
    let chars = uppercase?uppercase_hex_table:lowercase_hex_table;
    s = [0; i];
    'write: loop {
        i -= 1;
        s[i] = chars[(d %u base) as i32] as i32_u;
        d /u= base;
        br_if 'write d != 0;
    }
    if negative {
        s[0] = '-';
    } else {
        if sign_style {
            if sign_style == 1 {
                s[0] = '+';
            } else {
                s[0] = ' ';
            }
        }
    }
    // The "#" flag only prefixes octal/hex; for base 10 it is ignored (as
    // in C). Guarding on base here also stops the "0" from overwriting the
    // sign, since the digit-count phase above only reserves prefix room for
    // base 8/16.
    if alternate & (base != 10) {
        if i {
            s[0] = '0';
            if base == 16 {
                s[1] = uppercase?'X':'x';
            }
        }
    }
    s;
}

const unsupported = "caml_reinterpret_unboxed_int64_as_tagged_int63 is not supported in wasm.";

#[export = "caml_reinterpret_unboxed_int64_as_tagged_int63"]
fn caml_reinterpret_unboxed_int64_as_tagged_int63(&eq) -> &eq {
    caml_failwith(unsupported);
    0 as &i31;
}

#[if(wasi)]
{
    #[import = ("io", "IO_BUFFER_SIZE")]
    const IO_BUFFER_SIZE: i32;
    #[import = ("libc", "memory")]
    memory m: i32 [2];
    #[import = ("libc", "free")]
    fn free(i32);
    #[import = ("libc", "format_float")]
    fn format_float(i32, i32, i32, f64) -> i32;
    #[import = ("libc", "strtod")]
    fn strtod(i32, i32) -> f64;
    #[import = ("libc", "exp")]
    fn exp(f64) -> f64;
    #[import = ("wasi_memory", "checked_malloc")]
    fn checked_malloc(i32) -> i32;
    #[import = ("wasi_memory", "get_buffer")]
    fn get_buffer() -> i32;
    #[import = ("wasi_memory", "write_string_to_memory")]
    fn write_string_to_memory(i32, i32, &eq) -> i32;
    #[import = ("wasi_memory", "release_memory")]
    fn release_memory(i32, i32);
    #[import = ("wasi_memory", "blit_string_to_memory")]
    fn blit_string_to_memory(i32, &bytes);
    #[import = ("wasi_memory", "blit_memory_to_string")]
    fn blit_memory_to_string(i32, i32) -> &bytes;
}
#[else]
{
    #[import = ("bindings", "format_float")]
    fn format_float(i32, i32, i32, f64) -> &?any;
    #[import = ("bindings", "identity")]
    fn parse_float(&?any) -> f64;
    #[import = ("Math", "exp")]
    fn exp(f64) -> f64;
}
#[import = ("fail", "caml_failwith")]
fn caml_failwith(&eq);
#[import = ("fail", "caml_invalid_argument")]
fn caml_invalid_argument(&eq);
#[import = ("ints", "lowercase_hex_table")]
const lowercase_hex_table: &chars;
#[import = ("jsstring", "jsstring_of_bytes")]
fn jsstring_of_bytes(&bytes) -> &?any;
#[import = ("jsstring", "bytes_of_jsstring")]
fn bytes_of_jsstring(&?any) -> &bytes;

type float = { f: f64 };
type bytes = [mut i8];
type block = [mut &eq];

type chars = [i8];

const infinity: &chars = "infinity";

const nan_chars: &chars = "nan";

#[export = "Double_val"]
fn Double_val(v: &eq) -> f64 {
    (v as &float).f;
}

#[export = "caml_hexstring_of_float"]
fn caml_hexstring_of_float(v: &eq, vprec: &eq, vstyle: &eq) -> &eq {
    let prec = vprec as i32_s;
    let style = vstyle as i32_s;
    let b = (v as &float).f.to_bits();
    let sign = (b >>u 63) as i32;
    let exp = (b >>u 52) as i32 & 0x7FF;
    let m = b & (1 << 52) - 1;
    let i = sign | (style != '-');
    let s: &bytes;
    s =
        'sign: do {
            let len: i32;
            if exp == 0x7FF {
                let txt =
                    if !m {
                        infinity;
                    } else {
                        nan_chars;
                    };
                len = txt.length();
                s = [0; i + len];
                s.copy(i, txt, 0, len);
                br 'sign s;
            }
            if !exp {
                if m != 0 {
                    exp = -1022;
                }
            } else {
                exp = exp - 1023;
                m = m | 1 << 52;
            }
            let frac: i64;
            if (prec >=s 0) & (prec <s 13) {
                let unit = 1 << (52 - (prec << 2)) as i64_s;
                let half = unit >>u 1;
                let mask = unit - 1;
                frac = m & mask;
                m = m & (-1 ^ mask);
                if (frac >u half) | (frac == half) & (m & unit != 0) {
                    m = m + unit;
                }
            }
            frac = m << 12;
            let j = 0;
            while frac != 0 {
                j = j + 1;
                frac = frac << 4;
            }
            if prec <s j {
                prec = j;
            }
            let d: i32;
            if exp >=s 0 {
                d = exp;
            } else {
                d = 0 - exp;
            }
            j = 0;
            'count: loop {
                j = j + 1;
                d = d /u 10;
                br_if 'count d;
            }
            len = i + prec + (6 + j);
            if !prec {
                len = len - 1;
            }
            s = [0; len];
            if exp >=s 0 {
                d = exp;
            } else {
                d = 0 - exp;
            }
            'write: loop {
                len = len - 1;
                s[len] = '0' + d %u 10;
                d = d /u 10;
                br_if 'write d;
            }
            s[len - 1] = exp >=s 0?'+':'-';
            s[i] = '0';
            s[i + 1] = 'x';
            s[i + 2] = (m >>u 52) as i32 + '0';
            i = i + 3;
            if prec >s 0 {
                s[i] = '.';
                i = i + 1;
                frac = m << 12;
                'write: loop {
                    s[i] = lowercase_hex_table[(frac >>u 60) as i32] as i32_u;
                    frac = frac << 4;
                    prec = prec - 1;
                    i = i + 1;
                    br_if 'write prec >s 0;
                }
            }
            s[i] = 'p';
            s;
        };
    if sign {
        s[0] = '-';
    } else {
        if style != '-' {
            s[0] = style;
        }
    }
    s;
}

const format_error = "format_float: bad format";

fn parse_format(s: &bytes) -> (i32, i32, i32, i32) {
    let len = s.length();
    let i = 1;
    let sign_style: i32;
    let precision: i32;
    let conversion: i32;
    let uppercase: i32;
    'return: do {
        'bad_format: do {
            br_if 'bad_format len <u 2;
            br_if 'bad_format s[0] as i32_u != '%';
            let c = s[1] as i32_u;
            if c == '+' {
                sign_style = 1;
                i = i + 1;
            }
            if c == ' ' {
                sign_style = 2;
                i = i + 1;
            }
            br_if 'bad_format i == len;
            if s[i] as i32_u == '.' {
                'precision: loop {
                    i = i + 1;
                    br_if 'bad_format i == len;
                    c = s[i] as i32_u;
                    if (c >=u '0') & (c <=u '9') {
                        precision = precision * 10 + (c - '0');
                        br 'precision;
                    }
                }
            } else {
                // No precision: [$c] still holds the char read for the "."
                // test (a sign flag like "+"/" " when one was consumed), not
                // the conversion letter. Load it so the checks below see the
                // real conversion, otherwise "%+f"/"% f" wrongly raise.
                c = s[i] as i32_u;
                precision = 6;
            }
            br_if 'bad_format i + 1 != len;
            uppercase = c <s 'a';
            conversion = (c & 0xdf) - 'E';
            br_if 'return conversion <=u 2;
        }
        caml_invalid_argument(format_error);
    }
    sign_style;
    precision;
    conversion;
    uppercase;
}

const inf_chars: &chars = "inf";

#[if(wasi)]
#[export = "caml_format_float"]
fn caml_format_float(vfmt: &eq, arg: &eq) -> &eq {
    let fmt = vfmt as &bytes;
    let d = (arg as &float).f;
    let buffer = get_buffer();
    let fmt_len = fmt.length();
    blit_string_to_memory(buffer, fmt);
    m.store8(buffer + fmt_len, 0);
    let out_buffer = buffer + (fmt_len + 1);
    let avail = IO_BUFFER_SIZE - fmt_len;
    let len = format_float(out_buffer, avail, buffer, d);
    if len >=u avail {
        out_buffer = checked_malloc(len + 1);
        _ = format_float(out_buffer, len + 1, buffer, d);
    }
    let res = blit_memory_to_string(out_buffer, len);
    if len >=u avail {
        free(out_buffer);
    }
    res;
}
#[else]
#[export = "caml_format_float"]
fn caml_format_float(vfmt: &eq, arg: &eq) -> &eq {
    let f = (arg as &float).f;
    let b = f.to_bits();
    let (sign_style, precision, conversion, uppercase) = parse_format(vfmt as &bytes);
    let negative = (b >>u 63) as i32;
    let i = negative | (sign_style != 0);
    let len: i32;
    let s: &bytes;
    s =
        'sign: do {
            let exp = (b >>u 52) as i32 & 0x7FF;
            if exp == 0x7FF {
                let m = b << 12;
                let txt =
                    if !m {
                        inf_chars;
                    } else {
                        negative = 0;
                        i = sign_style != 0;
                        nan_chars;
                    };
                len = txt.length();
                s = [0; i + len];
                s.copy(i, txt, 0, len);
                br 'sign s;
            }
            let num = format_float(precision, conversion, i, f.abs());
            s = bytes_of_jsstring(num);
            br 'sign s;
        };
    if negative {
        s[0] = '-';
    } else {
        if sign_style {
            if sign_style == 1 {
                s[0] = '+';
            } else {
                s[0] = ' ';
            }
        }
    }
    if uppercase {
        i = 0;
        len = s.length();
        'uppercase: loop {
            let c = s[i] as i32_u;
            if (c >=u 'a') & (c <=u 'z') {
                s[i] = c - 32;
            }
            i = i + 1;
            br_if 'uppercase i <u len;
        }
    }
    s;
}

fn caml_float_of_hex(err_msg: &eq, s: &bytes, i: i32) -> f64 {
    let len = s.length();
    let dec_point = -1;
    'error: do {
        let d: i32;
        let m: i64;
        let exp: i32;
        let n_bits: i32;
        let m_bits: i32;
        let x_bits: i32;
        'parse: while i <u len {
            let c = s[i] as i32_u;
            i = i + 1;
            if c == '.' {
                br_if 'error dec_point >=s 0;
                dec_point = n_bits;
                br 'parse;
            }
            if (c == 'p') | (c == 'P') {
                br_if 'error i == len;
                c = s[i] as i32_u;
                i = i + 1;
                let negative: i32;
                if c == '-' {
                    negative = 1;
                    br_if 'error i == len;
                    c = s[i] as i32_u;
                    i = i + 1;
                }
                if c == '+' {
                    br_if 'error i == len;
                    c = s[i] as i32_u;
                    i = i + 1;
                }
                'overflow: do {
                    'parse_exponent: loop {
                        br_if 'error (c <u '0') | (c >u '9');
                        d = c - '0';
                        exp = exp * 10 + d;
                        br_if 'overflow exp <u d;
                        // Any exponent this large saturates the double
                        // to inf/0; stop accumulating before [exp * 10]
                        // can wrap around 2^32 and slip back into range.
                        br_if 'overflow exp >=u 0x10000000;
                        if i != len {
                            c = s[i] as i32_u;
                            i = i + 1;
                            br 'parse_exponent;
                        }
                    }
                    if negative {
                        br_if 'overflow exp >=u 0x80000000;
                        exp = 0 - exp;
                    } else {
                        br_if 'overflow exp >=u 0x80000000;
                    }
                    br 'parse;
                }
                if negative | !m {
                    return 0;
                } else {
                    return inf;
                }
            }
            if (c >=u '0') & (c <=u '9') {
                d = c - '0';
            } else {
                if (c >=u 'a') & (c <=u 'f') {
                    d = c - 87;
                } else {
                    if (c >=u 'A') & (c <=u 'F') {
                        d = c - 55;
                    } else {
                        br 'error;
                    }
                }
            }
            n_bits = n_bits + 4;
            br_if 'parse !d & !m;
            if m_bits <u 60 {
                m = (m << 4) + d as i64_u;
                m_bits = m_bits + 4;
            } else {
                if d {
                    m = m | 1;
                }
                x_bits = x_bits + 4;
            }
        }
        br_if 'error !n_bits;
        let f = m as f64_s;
        let adj = x_bits;
        if dec_point >=s 0 {
            adj = adj + (dec_point - n_bits);
        }
        if (adj >s 0) & (exp >s 0x7fffffff - adj) {
            exp = 0x7fffffff;
        } else {
            if (adj <s 0) & (exp <s 0x80000000 - adj) {
                exp = 0x80000000;
            } else {
                exp = exp + adj;
            }
        }
        if exp {
            f = ldexp(f, exp);
        }
        return f;
    }
    caml_failwith(err_msg);
    0;
}

fn on_whitespace(s: &bytes, i: i32) -> i32 {
    let c = s[i] as i32_u;
    (c == ' ') | (c - 9 <=u 4);
}

#[export = "caml_parse_float"]
fn caml_parse_float(err_msg: &eq, v: &eq) -> &eq {
    let s = v as &bytes;
    let len = s.length();
    let i: i32;
    let j: i32;
    while i <u len {
        if '_' == s[i] as i32_u {
            j = j + 1;
        }
        i = i + 1;
    }
    let c: i32;
    if j {
        let s': &bytes = [0; len - j];
        i = 0;
        j = 0;
        while i <u len {
            c = s[i] as i32_u;
            i = i + 1;
            if c != '_' {
                s'[j] = c;
                j = j + 1;
            }
        }
        len = s'.length();
        s = s';
    }
    i = 0;
    'skip_spaces: loop {
        if i <u len {
            if on_whitespace(s, i) {
                i = i + 1;
                br 'skip_spaces;
            }
        }
    }
    let start = i;
    'error: do {
        br_if 'error i == len;
        br_if 'error on_whitespace(s, len - 1);
        c = s[i] as i32_u;
        let negative: i32;
        if c == '-' {
            negative = 1;
            i = i + 1;
        }
        if c == '+' {
            i = i + 1;
        }
        let f: f64;
        if i + 2 <u len {
            if s[i] as i32_u == '0' {
                if s[i + 1] as i32_u & 0xdf == 'X' {
                    f = caml_float_of_hex(err_msg, s, i + 2);
                    if negative {
                        f = -f;
                    }
                    return { f: f };
                }
            }
        }
        if i + 3 == len {
            c = s[i] as i32_u;
            if c & 0xdf == 'N' {
                i = i + 1;
                c = s[i] as i32_u;
                if c & 0xdf == 'A' {
                    i = i + 1;
                    c = s[i] as i32_u;
                    if c & 0xdf == 'N' {
                        return { f: nan };
                    }
                }
            } else {
                if c & 0xdf == 'I' {
                    i = i + 1;
                    c = s[i] as i32_u;
                    if c & 0xdf == 'N' {
                        i = i + 1;
                        c = s[i] as i32_u;
                        if c & 0xdf == 'F' {
                            return { f: negative?-inf:inf };
                        }
                    }
                }
            }
        }
        if i + 8 == len {
            c = s[i] as i32_u;
            if c & 0xdf == 'I' {
                i = i + 1;
                c = s[i] as i32_u;
                if c & 0xdf == 'N' {
                    i = i + 1;
                    c = s[i] as i32_u;
                    if c & 0xdf == 'F' {
                        i = i + 1;
                        c = s[i] as i32_u;
                        if c & 0xdf == 'I' {
                            i = i + 1;
                            c = s[i] as i32_u;
                            if c & 0xdf == 'N' {
                                i = i + 1;
                                c = s[i] as i32_u;
                                if c & 0xdf == 'I' {
                                    i = i + 1;
                                    c = s[i] as i32_u;
                                    if c & 0xdf == 'T' {
                                        i = i + 1;
                                        c = s[i] as i32_u;
                                        if c & 0xdf == 'Y' {
                                            return { f: negative?-inf:inf };
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        let buffer: i32;
        let buf: i32;
        #[if(wasi)]
        {
            buffer = get_buffer();
            buf = write_string_to_memory(buffer + 4, IO_BUFFER_SIZE, s);
            f = strtod(buf, buffer);
            release_memory(buffer + 4, buf);
            br_if 'error m.load32(buffer) != buf + len;
        }
        #[else]
        {
            // The JS number coercion below accepts things OCaml does not,
            // e.g. binary/octal literals ("0b101", "0o17"); only a plain
            // decimal float can reach this point, so reject any character
            // that cannot appear in one. Start after the leading spaces already
            // skipped above.
            i = start;
            while i <u len {
                c = s[i] as i32_u;
                br_if 'error
                    !((c >=u '0') & (c <=u '9')
                          | ((c == '.') | ((c & 0xdf == 'E') | ((c == '+') | (c == '-')))));
                i = i + 1;
            }
            f = parse_float(jsstring_of_bytes(s));
            br_if 'error f != f;
        }
        return { f: f };
    }
    caml_failwith(err_msg);
    return 0 as &i31;
}

const float_of_string = "float_of_string";

#[export = "caml_float_of_string"]
fn caml_float_of_string(s: &eq) -> &eq {
    become caml_parse_float(float_of_string, s);
}

#[export = "caml_nextafter_float"]
fn caml_nextafter_float(x: f64, y: f64) -> f64 {
    if x != x {
        return x;
    }
    if y != y {
        return y;
    }
    if x == y {
        return y;
    }
    if x == 0 {
        if y >= 0 {
            return 0x1p-1074;
        } else {
            return -0x1p-1074;
        }
    } else {
        let i = x.to_bits();
        let j = y.to_bits();
        if (i <s j) & (i <u j) {
            i = i + 1;
        } else {
            i = i - 1;
        }
        return i.from_bits();
    }
}

#[export = "caml_classify_float"]
fn caml_classify_float(x: f64) -> i32 {
    let a = x.abs();
    if a >= 0x1p-1022 {
        if a < inf {
            0; // normal
        } else {
            3;
        } // infinity
    } else {
        if a == 0 {
            2; // zero
        } else {
            if a == a {
                1; // subnormal
            } else {
                4;
            }
        }
    }
} // nan
#[export = "caml_modf_float"]
fn caml_modf_float(v: &eq) -> &eq {
    let x = (v as &float).f;
    let a = x.abs();
    let i: f64;
    let f: f64;
    if a >= 0 {
        if a < inf { // normal
            i = a.floor();
            f = a - i;
            i = i.copysign(x);
            f = f.copysign(x);
        } else { // infinity
            i = x;
            f = (0).copysign(x);
        }
    } else { // zero or nan
        i = x;
        f = x;
    }
    [block|0 as &i31, { f: f }, { f: i }];
}

#[export = "caml_ldexp_float"]
fn ldexp(x: f64, n: i32) -> f64 {
    if n >s 1023 {
        x = x * 0x1p1023;
        n = n - 1023;
        if n >s 1023 {
            // subnormal
            x = x * 0x1p1023;
            n = n - 1023;
            if n >s 1023 {
                n = 1023;
            }
        }
    } else {
        if n <s -1022 {
            x = x * 0x1p-969;
            n = n + 969;
            if n <s -1022 {
                x = x * 0x1p-969;
                n = n + 969;
                if n <s -1022 {
                    n = -1022;
                }
            }
        }
    }
    x * (n as i64_s + 0x3ff << 52).from_bits();
}

fn frexp(x: f64) -> (f64, i32) {
    let y = x.to_bits();
    let e = 0x7ff & (y >>u 52) as i32;
    if !e {
        if x != 0 {
            let (r_0, r_1) = frexp(x * 0x1p64);
            return (r_0, r_1 - 64);
        } else {
            return (x, 0);
        }
    } else {
        if e == 0x7ff {
            return (x, 0);
        }
    }
    (y & 0x800fffffffffffff | 0x3fe0000000000000).from_bits();
    e - 0x3fe;
}

#[export = "caml_frexp_float"]
fn caml_frexp_float(v: &eq) -> &eq {
    let (r_0, r_1) = frexp((v as &float).f);
    [block|0 as &i31, { f: r_0 }, r_1 as &i31];
}

#[export = "caml_erf_float"]
fn erf(x: f64) -> f64 {
    let a1 = 0.254829592;
    let a2 = -0.284496736;
    let a3 = 1.421413741;
    let a4 = -1.453152027;
    let a5 = 1.061405429;
    let p = 0.3275911;
    let t = 1 / (1 + p * x.abs());
    let y = 1 - ((((a5 * t + a4) * t + a3) * t + a2) * t + a1) * (t * exp(-(x * x)));
    y.copysign(x);
}

#[export = "caml_erfc_float"]
fn caml_erfc_float(x: f64) -> f64 {
    1 - erf(x);
}

#[export = "caml_fma_float"]
fn caml_fma_float(vx: &eq, vy: &eq, vz: &eq) -> &eq {
    let x = (vx as &float).f;
    let y = (vy as &float).f;
    let z = (vz as &float).f;
    let x_2: i64;
    let x_3: i64;
    let x_4: i64;
    let x_5: i64;
    let x_6 =
        (x_3 := (x_2 := y.to_bits()) >>u 52 & 2047) + (x_5 := (x_4 := x.to_bits()) >>u 52 & 2047);
    let x_7 = z.to_bits();
    let x_8: i32;
    let x_9: i32;
    'l_2: do {
        'l_3: do {
            br_if 'l_3 x_3 >u 1993;
            br_if 'l_3 x_5 >u 1993;
            br_if 'l_3 x_6 >u 3016;
            br_if 'l_3 x_7 & 0x7fe0000000000000 >u 0x7c90000000000000;
            x_8 = 0;
            br_if 'l_3 x_6 <=u 1076;
            x_9 = 0;
            br 'l_2;
        }
        x_7 = x_7 >>u 52 & 2047;
        'cont: do {

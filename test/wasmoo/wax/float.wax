#[export = "caml_float_compare"]
fn caml_float_compare(x: f64, y: f64) -> i32 {
    (x > y) - (x < y) + ((x == x) - (y == y));
}

#[export = "caml_round_float"]
fn caml_round_float(x: f64) -> f64 {
    let y: f64;
    if x >= 0 {
        y = x.floor();
        if x - y >= 0.5 {
            y + 1;
        } else {
            y;
        }
    } else {
        y = x.ceil();
        if y - x >= 0.5 {
            y - 1;
        } else {
            y;
        }
    }
}

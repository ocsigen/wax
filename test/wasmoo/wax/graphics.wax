    #[export = "caml_gr_text_size"]
    fn caml_gr_text_size(s: &eq) -> &eq {
        check_state();
        [block|
            0 as &i31,
            gr_text_size_w(unwrap(caml_jsstring_of_string(s))) as &i31,
            gr_text_size_h() as &i31,
        ];
    }

    // --- Polygon ---

    #[export = "caml_gr_fill_poly"]
    fn caml_gr_fill_poly(ar: &eq) -> &eq {
        check_state();
        let a = ar as &block;
        let n = a.length() - 1;
        let flat = new_array(n * 2);
        let i = 0;
        while i <u n : (i += 1) {
            let p = a[i + 1] as &block;
            array_set(flat, i * 2, from_int32(p[1] as i32_s));
            array_set(flat, i * 2 + 1, from_int32(p[2] as i32_s));
        }
        gr_fill_poly(flat as &any, n);
        0 as &i31;
    }

    // --- Image operations ---

    #[export = "caml_gr_create_image"]
    fn caml_gr_create_image(w: &eq, h: &eq) -> &eq {
        check_state();
        { js: gr_create_image(w as i32_s, h as i32_s) };
    }

    #[export = "caml_gr_draw_image"]
    fn caml_gr_draw_image(im: &eq, x: &eq, y: &eq) -> &eq {
        check_state();
        gr_draw_image(unwrap(im), x as i32_s, y as i32_s);
        0 as &i31;
    }

    #[export = "caml_gr_blit_image"]
    fn caml_gr_blit_image(im: &eq, x: &eq, y: &eq) -> &eq {
        check_state();
        gr_blit_image(unwrap(im), x as i32_s, y as i32_s);
        0 as &i31;
    }

    #[export = "caml_gr_make_image"]
    fn caml_gr_make_image(arr: &eq) -> &eq {
        check_state();
        let a = arr as &block;
        let h = a.length() - 1;
        let row = a[1] as &block;
        let w = row.length() - 1;
        let flat = new_array(h * w);
        let idx = 0;
        let i = 0;
        while i <u h : (i += 1) {
            row = a[i + 1] as &block;
            let j = 0;
            while j <u w : (j += 1) {
                array_set(flat, idx, from_int32(row[j + 1] as i32_s));
                idx += 1;
            }
        }
        { js: gr_make_image(flat as &any, w, h) };
    }

    #[export = "caml_gr_dump_image"]
    fn caml_gr_dump_image(im: &eq) -> &eq {
        let js_im = unwrap(im);
        let w = gr_dump_image_width(js_im);
        let h = gr_dump_image_height(js_im);
        let result: &block = [0 as &i31; h + 1];
        let i = 0;
        while i <u h : (i += 1) {
            let row: &block = [0 as &i31; w + 1];
            let j = 0;
            while j <u w : (j += 1) {
                row[j + 1] = gr_dump_image_pixel(js_im, i, j) as &i31;
            }
            result[i + 1] = row;
        }
        result;
    }

    // --- Graphics_js state management ---

    #[export = "caml_gr_state_get"]
    fn caml_gr_state_get(&eq) -> &eq {
        check_state();
        wrap(gr_state());
    }

    #[export = "caml_gr_state_set"]
    fn caml_gr_state_set(s: &eq) -> &eq {
        gr_state_set(unwrap(s));
        0 as &i31;
    }

    #[export = "caml_gr_state_create"]
    fn caml_gr_state_create(s: &eq, w: &eq, h: &eq) -> &eq {
        wrap(gr_state_create(unwrap(s), w as i32_s, h as i32_s));
    }

    #[export = "caml_gr_doc_of_state"]
    fn caml_gr_doc_of_state(s: &eq) -> &eq {

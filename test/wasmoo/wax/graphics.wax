    // Types
    type block = [mut &eq];
    type bytes = [mut i8];
    type js = { js: &?any };

    // String constants
    const graphic_failure = "Graphics.Graphic_failure";
    const not_initialized = "Not initialized";
    const open_failed = "Graphics.open_graph: cannot open the window";
    const wait_event = "caml_gr_wait_event not Implemented: use Graphics_js instead";
    const synchronize = "caml_gr_synchronize not Implemented";
    const remember_mode = "caml_gr_remember_mode not Implemented";
    const display_mode = "caml_gr_display_mode not Implemented";
    const window_id = "caml_gr_window_id not Implemented";
    const open_subwindow = "caml_gr_open_subwindow not Implemented";
    const close_subwindow = "caml_gr_close_subwindow not Implemented";

    // State check helper: raises Graphics.Graphic_failure if not initialized
    fn check_state() {
        if !gr_state() {
            'no_named_value: do {
                caml_raise_with_arg(
                    br_on_null 'no_named_value caml_named_value(graphic_failure),
                    not_initialized,
                );
                return;
            }
            caml_failwith(not_initialized);
        }
    }

    // --- Open / Close / Clear ---

    #[export = "caml_gr_open_graph"]
    fn caml_gr_open_graph(s: &eq) -> &eq {
        if gr_open(unwrap(caml_jsstring_of_string(s))) {
            caml_failwith(open_failed);
        }
        0 as &i31;
    }

    #[export = "caml_gr_close_graph"]
    fn caml_gr_close_graph(&eq) -> &eq {
        check_state();
        gr_close();
        0 as &i31;
    }

    #[export = "caml_gr_clear_graph"]
    fn caml_gr_clear_graph(&eq) -> &eq {
        check_state();
        gr_clear();
        0 as &i31;
    }


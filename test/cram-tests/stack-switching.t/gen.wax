type ft0 = fn() -> i32;
type k0 = cont ft0;
type ft1 = fn(i32) -> i32;
type k1 = cont ft1;
tag yield(i32) -> i32;
tag myexn(i32);

fn g1(x: i32) -> i32 { suspend yield(x); }

fn t_new() -> &k1 { cont_new k1 (g1); }
fn t_bind(c: &k1) -> &k0 { cont_bind k1 k0 (7, c); }
fn t_resume(c: &k0) -> i32 { resume k0 [] (c); }
fn t_resume_throw(c: &k0) -> i32 { resume_throw k0 myexn [] (8, c); }
fn t_resume_throw_ref(c: &k0, e: &?exn) -> i32 { resume_throw_ref k0 [] (e, c); }

// the abstract cont / nocont heap types are written &cont / &nocont
fn abstract_refs(a: &?cont, b: &nocont) -> i32 { 0; }

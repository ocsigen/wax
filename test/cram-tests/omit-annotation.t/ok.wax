type point = {x: i32, y: i32};
type box = {v: i32};
type ints = [i32];

// The struct/array type name may be omitted when an expected type supplies it.

fn from_let() -> &point {
    let p: &point = {x: 1, y: 2,};
    return p;
}

// A single-field struct may also be written name-less.
fn from_let_box() -> &box {
    let b: &box = {v: 42};
    return b;
}

// An assignment target's type works as a context too.
fn from_set() -> &point {
    let p: &point;
    p = {x: 5, y: 6,};
    return p;
}

type holder = { p: mut &point };

fn take(p: &point) -> i32 {
    return p.x;
}

// A call argument takes its context from the parameter type.
fn from_arg() -> i32 {
    return take({x: 1, y: 2,});
}

// A struct field assignment takes its context from the field type.
fn from_field_set(h: &holder) {
    h.p = {x: 3, y: 4,};
}

fn from_let_array() -> &ints {
    let a: &ints = [0; 8];
    return a;
}

const origin: &point = {x: 0, y: 0,};
const zeros: &ints = [0; 4];

#[export = "arms"]
fn arms(x: i32, r: &any) -> i32 {
  dispatch x ['a, else 'b] { 'a: { return 1; } ; 'b: { return 2; } ; };
  match r { &any => { return 0; }; ; null => { return 1; } _ => { return 2; } };
  'l: try { nop; } catch { ; _ => { nop; } };

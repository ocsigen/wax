(rule
 (deps %{bin:wax} simd.wat atomics.wat bulk.wat)
 (targets simd.wasm atomics.wasm bulk.wasm)
 (action
  (progn
   (run wax -f wasm simd.wat -o simd.wasm)
   (run wax -f wasm atomics.wat -o atomics.wasm)
   (run wax -f wasm bulk.wat -o bulk.wasm))))

(rule
 (deps
  check_coherence.exe
  bigarray.wasm
  custom.wasm
  effect-native.wasm
  float.wasm
  float32.wasm
  hash.wasm
  int32.wasm
  int64.wasm
  ints.wasm
  io.wasm
  jsstring.wasm
  marshal.wasm
  nat.wasm
  str.wasm
  unix.wasm
  simd.wasm
  atomics.wasm
  bulk.wasm)
 (action
  (with-stdout-to
   link_coherence.output
   (run
    ./check_coherence.exe
    bigarray.wasm
    custom.wasm
    effect-native.wasm
    float.wasm
    float32.wasm
    hash.wasm
    int32.wasm
    int64.wasm
    ints.wasm
    io.wasm
    jsstring.wasm
    marshal.wasm
    nat.wasm
    str.wasm
    unix.wasm
    simd.wasm
    atomics.wasm
    bulk.wasm))))

(rule
 (alias runtest)
 (action
  (diff link_coherence.expected link_coherence.output)))
